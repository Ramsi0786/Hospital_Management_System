<nav class="navbar navbar-expand-lg bg-white navbar-light shadow-sm sticky-top">

  <div class="container-fluid">

    <!-- LOGO -->
    <a href="/" class="navbar-brand d-flex align-items-center">
      <img src="/images/logo-1.jpg" height="60">
    </a>

    <!-- RIGHT SIDE (Login + Toggle) -->
    <div class="d-flex align-items-center">

      <!-- LOGIN BUTTON (ALWAYS VISIBLE) -->
      <% if (!locals.user) { %>
        <a href="/login" class="btn btn-primary rounded-pill px-3 py-2 me-2 d-lg-none">
          Login
        </a>
      <% } %>

      <!-- TOGGLER -->
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
      </button>

    </div>

    <!-- COLLAPSIBLE MENU -->
    <div class="collapse navbar-collapse custom-mobile-menu" id="navbarCollapse">

      <!-- CENTER MENU -->
      <ul class="navbar-nav mx-auto text-center text-lg-start">

        <li class="nav-item">
          <a href="/" class="nav-link <%= locals.currentPath === '/' ? 'active fw-bold' : '' %>">Home</a>
        </li>

        <li class="nav-item">
          <a href="/doctors" class="nav-link <%= locals.currentPath?.startsWith('/doctors') ? 'active fw-bold' : '' %>">Doctors</a>
        </li>

        <li class="nav-item">
          <a href="/departments" class="nav-link <%= locals.currentPath?.startsWith('/departments') ? 'active fw-bold' : '' %>">Departments</a>
        </li>

        <li class="nav-item">
          <a href="/services" class="nav-link <%= locals.currentPath === '/services' ? 'active fw-bold' : '' %>">Services</a>
        </li>

        <li class="nav-item">
          <a href="/about-us" class="nav-link <%= locals.currentPath === '/about-us' ? 'active fw-bold' : '' %>">About Us</a>
        </li>

        <li class="nav-item">
          <a href="/contact" class="nav-link <%= locals.currentPath === '/contact' ? 'active fw-bold' : '' %>">Contact</a>
        </li>

      </ul>

      <!-- DESKTOP LOGIN / USER -->
      <ul class="navbar-nav ms-auto text-center">

        <% if (locals.user) { %>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle d-flex align-items-center"
             href="#"
             data-bs-toggle="dropdown">

            <div class="user-avatar me-2">
              <%= user.name.charAt(0).toUpperCase() %>
            </div>

            <span class="d-none d-lg-inline"><%= user.name %></span>
          </a>

          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/patient/dashboard">Dashboard</a></li>
            <li><a class="dropdown-item" href="/patient/profile">Profile</a></li>
            <li>
              <form action="/patient/logout" method="POST">
                <button class="dropdown-item text-danger">Logout</button>
              </form>
            </li>
          </ul>
        </li>

        <% } else { %>

        <!-- DESKTOP LOGIN -->
        <li class="nav-item d-none d-lg-block">
         <% if (!locals.user) { %>
          <a href="/login" class="btn btn-primary rounded-pill px-4 py-2">Login</a>
         <% } %>
        </li>

        <% } %>

      </ul>

    </div>

  </div>
</nav>