<nav class="navbar navbar-expand-lg bg-white navbar-light shadow-sm sticky-top">

  <div class="container-fluid">

    <!-- LOGO -->
    <a href="/" class="navbar-brand d-flex align-items-center">
      <img src="/images/logo-1.jpg" height="60">
    </a>

    <!-- RIGHT SIDE (Login + Toggle) -->
    <div class="d-flex align-items-center">

      <!-- LOGIN BUTTON (ALWAYS VISIBLE) -->
      <% if (!locals.user) { %>
        <a href="/login" class="btn btn-primary rounded-pill px-3 py-2 me-2 d-lg-none">
          Login
        </a>
      <% } %>

      <!-- TOGGLER -->
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
      </button>

    </div>

    <!-- COLLAPSIBLE MENU -->
    <div class="collapse navbar-collapse custom-mobile-menu" id="navbarCollapse">

      <!-- CENTER MENU -->
      <ul class="navbar-nav mx-auto text-center text-lg-start">

        <li class="nav-item">
          <a href="/" class="nav-link <%= locals.currentPath === '/' ? 'active fw-bold' : '' %>">Home</a>
        </li>

        <li class="nav-item">
          <a href="/doctors" class="nav-link <%= locals.currentPath?.startsWith('/doctors') ? 'active fw-bold' : '' %>">Doctors</a>
        </li>

        <li class="nav-item">
          <a href="/departments" class="nav-link <%= locals.currentPath?.startsWith('/departments') ? 'active fw-bold' : '' %>">Departments</a>
        </li>

        <li class="nav-item">
          <a href="/services" class="nav-link <%= locals.currentPath === '/services' ? 'active fw-bold' : '' %>">Services</a>
        </li>

        <li class="nav-item">
          <a href="/about-us" class="nav-link <%= locals.currentPath === '/about-us' ? 'active fw-bold' : '' %>">About Us</a>
        </li>

        <li class="nav-item">
          <a href="/contact" class="nav-link <%= locals.currentPath === '/contact' ? 'active fw-bold' : '' %>">Contact</a>
        </li>

      </ul>

      <!-- DESKTOP LOGIN / USER -->
      <ul class="navbar-nav ms-auto text-center">

        <% if (locals.user) { %>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle d-flex align-items-center"
             href="#"
             data-bs-toggle="dropdown">

            <div class="user-avatar me-2">
              <%= user.name.charAt(0).toUpperCase() %>
            </div>

            <span class="d-none d-lg-inline"><%= user.name %></span>
          </a>

          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/patient/dashboard">Dashboard</a></li>
            <li><a class="dropdown-item" href="/patient/profile">Profile</a></li>
            <li>
              <button class="dropdown-item text-danger" onclick="document.getElementById('logoutModal').style.display='flex'">
                 Logout
              </button>
            </li>
          </ul>
        </li>

        <% } else { %>

        <!-- DESKTOP LOGIN -->
        <li class="nav-item d-none d-lg-block">
          <a href="/login" class="btn btn-primary rounded-pill px-4 py-2">Login</a>
        </li>

        <% } %>

      </ul>

    </div>

  </div>

  <!-- Logout Confirmation Modal -->
<div id="logoutModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
  <div style="background:white; border-radius:16px; padding:32px; max-width:380px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
    
    <div style="width:56px; height:56px; background:#fff0f0; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg width="24" height="24" fill="none" stroke="#dc3545" stroke-width="2" viewBox="0 0 24 24">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </div>

    <h5 style="margin:0 0 8px; font-weight:700; color:#1a202c;">Logging out?</h5>
    <p style="margin:0 0 24px; color:#64748b; font-size:14px;">You'll need to log in again to access your account.</p>

    <div style="display:flex; gap:12px; justify-content:center;">
      <button 
        onclick="document.getElementById('logoutModal').style.display='none'"
        style="flex:1; padding:10px 20px; border:2px solid #e2e8f0; background:white; border-radius:10px; font-weight:600; cursor:pointer; color:#374151;">
        Cancel
      </button>
      <form action="/patient/logout" method="POST" style="flex:1;">
        <button type="submit"
          style="width:100%; padding:10px 20px; background:#dc3545; border:none; border-radius:10px; color:white; font-weight:600; cursor:pointer;">
          Yes, Logout
        </button>
      </form>
    </div>

  </div>
</div>
</nav>