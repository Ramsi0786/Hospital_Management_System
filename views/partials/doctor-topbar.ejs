<div class="doctor-topbar">
  <div class="dtb-left">
    <% if (typeof backUrl !== 'undefined' && backUrl) { %>
      <a href="<%= backUrl %>" class="dtb-back">
        <i class="fas fa-arrow-left"></i>
        <span><%= typeof backLabel !== 'undefined' && backLabel ? backLabel : 'Back' %></span>
      </a>
    <% } %>
    <div class="dtb-title-wrap">
      <h1 class="dtb-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h1>
      <% if (typeof pageSubtitle !== 'undefined' && pageSubtitle) { %>
        <p class="dtb-subtitle"><%= pageSubtitle %></p>
      <% } %>
    </div>
  </div>

  <div class="dtb-right">
    <!-- Bell -->
    <div class="dtb-notif-wrap" id="dtbNotifWrap">
      <button class="dtb-notif-btn" id="dtbNotifBtn" onclick="toggleDtbNotif()">
        <i class="fas fa-bell"></i>
        <span class="dtb-notif-badge" id="dtbNotifBadge" style="display:none;">0</span>
      </button>
      <div class="dtb-notif-dropdown" id="dtbNotifDropdown">
        <div class="dtb-notif-header">
          <span class="dtb-notif-title">Notifications</span>
          <button class="dtb-notif-mark-all" onclick="markAllDtbRead()">Mark all read</button>
        </div>
        <div class="dtb-notif-tabs">
          <button class="dtb-notif-tab active" data-tab="unread" onclick="switchDtbTab('unread')" id="dtb-tab-unread">Unread</button>
          <button class="dtb-notif-tab" data-tab="all" onclick="switchDtbTab('all')" id="dtb-tab-all">All</button>
        </div>
        <div class="dtb-notif-list" id="dtbNotifList">
          <div class="dtb-notif-loading"><i class="fas fa-spinner fa-spin"></i></div>
        </div>
      </div>
    </div>

    <!-- User -->
    <div class="dtb-user">
      <div class="dtb-avatar">
        <% if (locals.user && user.profileImage) { %>
          <img src="<%= user.profileImage %>" alt="<%= user.name %>">
        <% } else { %>
          <%= locals.user ? user.name.charAt(0).toUpperCase() : 'D' %>
        <% } %>
      </div>
      <div class="dtb-user-info">
        <span class="dtb-greeting">Dr.</span>
        <span class="dtb-name"><%= locals.user ? user.name.split(' ')[0] : 'Doctor' %></span>
      </div>
    </div>
  </div>
</div>

<style>
  .doctor-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
    flex-wrap: wrap;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .dtb-left {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .dtb-back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    background: white;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    color: #374151;
    text-decoration: none;
    transition: all .2s;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }

  .dtb-back:hover {
    background: #0f4c75;
    color: white;
    border-color: #0f4c75;
    transform: translateX(-2px);
    text-decoration: none;
  }

  .dtb-back i { font-size: 12px; }
  .dtb-title-wrap { min-width: 0; }

  .dtb-title {
    font-size: 24px;
    font-weight: 800;
    color: #1a202c;
    margin: 0;
    line-height: 1.2;
  }

  .dtb-subtitle {
    font-size: 13px;
    color: #94a3b8;
    margin: 3px 0 0;
    font-weight: 500;
  }

  .dtb-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  /* Bell */
  .dtb-notif-wrap { position: relative; }

  .dtb-notif-btn {
    position: relative;
    width: 40px; height: 40px;
    border-radius: 50%;
    background: white;
    border: 1.5px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 16px;
    color: #374151;
    transition: all .2s;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }

  .dtb-notif-btn:hover  { background: #f8fafc; border-color: #0f4c75; color: #0f4c75; }
  .dtb-notif-btn.active { background: #0f4c75; border-color: #0f4c75; color: white; }

  .dtb-notif-badge {
    position: absolute;
    top: -4px; right: -4px;
    min-width: 18px; height: 18px;
    background: #dc2626;
    color: white;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid white;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .dtb-notif-dropdown {
    position: absolute;
    top: 48px; right: 0;
    width: 340px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,.14);
    border: 1.5px solid #f0f2f5;
    z-index: 9999;
    display: none;
    overflow: hidden;
  }

  .dtb-notif-dropdown.show { display: block; animation: dtbFadeIn .2s ease; }

  @keyframes dtbFadeIn {
    from { opacity:0; transform:translateY(-8px); }
    to   { opacity:1; transform:translateY(0); }
  }

  .dtb-notif-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px 12px;
    border-bottom: 1.5px solid #f0f2f5;
  }

  .dtb-notif-title { font-size: 14px; font-weight: 800; color: #1a202c; }

  .dtb-notif-mark-all {
    font-size: 12px;
    font-weight: 600;
    color: #0f4c75;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .dtb-notif-mark-all:hover { text-decoration: underline; }

  .dtb-notif-tabs {
    display: flex;
    border-bottom: 1.5px solid #f0f2f5;
    padding: 0 4px;
  }

  .dtb-notif-tab {
    flex: 1;
    padding: 10px 8px;
    background: none;
    border: none;
    border-bottom: 2.5px solid transparent;
    font-size: 13px;
    font-weight: 600;
    color: #94a3b8;
    cursor: pointer;
    font-family: inherit;
    transition: all .2s;
    margin-bottom: -1.5px;
  }

  .dtb-notif-tab:hover  { color: #374151; }
  .dtb-notif-tab.active { color: #0f4c75; border-bottom-color: #0f4c75; }

  .dtb-notif-list {
    max-height: 360px;
    overflow-y: auto;
  }

  .dtb-notif-list::-webkit-scrollbar { width: 4px; }
  .dtb-notif-list::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 2px; }

  .dtb-notif-loading {
    text-align: center;
    padding: 30px;
    color: #94a3b8;
    font-size: 20px;
  }

  .dtb-notif-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 18px;
    border-bottom: 1px solid #f8fafc;
    cursor: pointer;
    transition: background .15s;
  }

  .dtb-notif-item:last-child { border-bottom: none; }
  .dtb-notif-item:hover       { background: #f8fafc; }
  .dtb-notif-item.unread      { background: #f0f9ff; }
  .dtb-notif-item.unread:hover{ background: #e0f2fe; }

  .dtb-notif-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
  }

  .dtb-ni-booked    { background: #ecfdf5; color: #059669; }
  .dtb-ni-cancelled { background: #fef2f2; color: #dc2626; }
  .dtb-ni-confirmed { background: #eff6ff; color: #2563eb; }
  .dtb-ni-default   { background: #f8fafc; color: #64748b; }

  .dtb-notif-content { flex: 1; min-width: 0; }

  .dtb-notif-item-title {
    font-size: 13px;
    font-weight: 700;
    color: #1a202c;
    margin-bottom: 2px;
  }

  .dtb-notif-item-msg {
    font-size: 12px;
    color: #64748b;
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dtb-notif-item-time {
    font-size: 11px;
    color: #94a3b8;
    margin-top: 4px;
    font-weight: 500;
  }

  .dtb-notif-dot {
    width: 8px; height: 8px;
    background: #0f4c75;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .dtb-notif-empty {
    text-align: center;
    padding: 36px 20px;
    color: #94a3b8;
  }

  .dtb-notif-empty i { font-size: 30px; margin-bottom: 10px; display: block; }
  .dtb-notif-empty p { font-size: 13px; margin: 0 0 4px; font-weight: 700; color: #374151; }
  .dtb-notif-empty span { font-size: 11px; color: #94a3b8; }

  /* User pill */
  .dtb-user {
    display: flex;
    align-items: center;
    gap: 10px;
    background: white;
    padding: 8px 16px 8px 8px;
    border-radius: 50px;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    border: 1.5px solid #f0f2f5;
  }

  .dtb-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0f4c75, #1a7f8e);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .dtb-avatar img { width:100%; height:100%; object-fit:cover; border-radius:50%; }

  .dtb-user-info { display:flex; flex-direction:column; line-height:1.3; }
  .dtb-greeting  { font-size:11px; color:#94a3b8; font-weight:500; }
  .dtb-name      { font-size:14px; font-weight:700; color:#1a202c; }

  @media (max-width:768px) {
    .dtb-title     { font-size:20px; }
    .dtb-user-info { display:none; }
    .dtb-user      { padding:6px; border-radius:50%; }
    .dtb-notif-dropdown { width:300px; right:-50px; }
    .doctor-topbar { margin-bottom:20px; }
  }
</style>

<script>
  const DTB_ICONS = {
    appointment_booked:    { cls: 'dtb-ni-booked',    icon: 'fa-calendar-plus' },
    appointment_confirmed: { cls: 'dtb-ni-confirmed', icon: 'fa-check-circle'  },
    appointment_cancelled: { cls: 'dtb-ni-cancelled', icon: 'fa-times-circle'  },
    appointment_completed: { cls: 'dtb-ni-confirmed', icon: 'fa-check-double'  },
    refund_processed:      { cls: 'dtb-ni-default',   icon: 'fa-wallet'        },
    appointment_reminder:  { cls: 'dtb-ni-default',   icon: 'fa-bell'          }
  };

  function dtbTimeAgo(d) {
    const diff = (Date.now() - new Date(d)) / 1000;
    if (diff < 60)    return 'Just now';
    if (diff < 3600)  return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    return `${Math.floor(diff/86400)}d ago`;
  }

  function dtbRenderItem(n) {
    const ic = DTB_ICONS[n.type] || DTB_ICONS.appointment_reminder;
    return `
      <div class="dtb-notif-item ${n.isRead ? '' : 'unread'}"
           onclick="handleDtbClick('${n._id}','${n.link||''}')">
        <div class="dtb-notif-icon ${ic.cls}"><i class="fas ${ic.icon}"></i></div>
        <div class="dtb-notif-content">
          <div class="dtb-notif-item-title">${n.title}</div>
          <div class="dtb-notif-item-msg">${n.message}</div>
          <div class="dtb-notif-item-time">${dtbTimeAgo(n.createdAt)}</div>
        </div>
        ${!n.isRead ? '<div class="dtb-notif-dot"></div>' : ''}
      </div>`;
  }

  let _dtbNotifs = [];
  let _dtbTab    = 'unread';

  async function loadDtbNotifs() {
    try {
      const res  = await fetch('/doctor/notifications');
      const data = await res.json();
      if (!data.success) return;
      _dtbNotifs = data.notifications;
      dtbUpdateBadge(data.unreadCount);
      dtbRenderTab();
    } catch {}
  }

  function dtbRenderTab() {
    const unread = _dtbNotifs.filter(n => !n.isRead);
    const all    = _dtbNotifs;

    const ut = document.getElementById('dtb-tab-unread');
    const at = document.getElementById('dtb-tab-all');
    if (ut) ut.textContent = unread.length > 0 ? `Unread (${unread.length})` : 'Unread';
    if (at) at.textContent = all.length    > 0 ? `All (${all.length})`        : 'All';

    const list  = document.getElementById('dtbNotifList');
    if (!list) return;
    const items = _dtbTab === 'unread' ? unread : all;

    if (_dtbTab === 'unread' && !unread.length) {
      list.innerHTML = `<div class="dtb-notif-empty"><i class="fas fa-check-circle" style="color:#059669;"></i><p>All caught up!</p><span>No unread notifications</span></div>`;
      return;
    }
    if (_dtbTab === 'all' && !all.length) {
      list.innerHTML = `<div class="dtb-notif-empty"><i class="fas fa-bell-slash"></i><p>No notifications yet</p><span>You'll see updates here</span></div>`;
      return;
    }
    list.innerHTML = items.map(dtbRenderItem).join('');
  }

  function switchDtbTab(tab) {
    _dtbTab = tab;
    document.querySelectorAll('.dtb-notif-tab').forEach(t =>
      t.classList.toggle('active', t.dataset.tab === tab)
    );
    dtbRenderTab();
  }

  async function handleDtbClick(id, link) {
    await fetch(`/doctor/notifications/${id}/read`, { method: 'PATCH' }).catch(()=>{});
    const n = _dtbNotifs.find(n => n._id === id);
    if (n) n.isRead = true;
    dtbUpdateBadge(_dtbNotifs.filter(n => !n.isRead).length);
    dtbRenderTab();
    if (link) window.location.href = link;
  }

  async function markAllDtbRead() {
    await fetch('/doctor/notifications/read', { method: 'PATCH' }).catch(()=>{});
    _dtbNotifs.forEach(n => n.isRead = true);
    dtbUpdateBadge(0);
    dtbRenderTab();
  }

  function dtbUpdateBadge(count) {
    const b = document.getElementById('dtbNotifBadge');
    if (!b) return;
    if (count > 0) { b.textContent = count > 99 ? '99+' : count; b.style.display = 'flex'; }
    else b.style.display = 'none';
  }

  function toggleDtbNotif() {
    const d   = document.getElementById('dtbNotifDropdown');
    const btn = document.getElementById('dtbNotifBtn');
    if (d.classList.contains('show')) {
      d.classList.remove('show'); btn.classList.remove('active');
    } else {
      _dtbTab = 'unread';
      document.querySelectorAll('.dtb-notif-tab').forEach(t =>
        t.classList.toggle('active', t.dataset.tab === 'unread')
      );
      d.classList.add('show'); btn.classList.add('active');
      loadDtbNotifs();
    }
  }

  document.addEventListener('click', function(e) {
    const wrap = document.getElementById('dtbNotifWrap');
    if (wrap && !wrap.contains(e.target)) {
      document.getElementById('dtbNotifDropdown')?.classList.remove('show');
      document.getElementById('dtbNotifBtn')?.classList.remove('active');
    }
  });

  // Load badge on page load
  (async () => {
    try {
      const res  = await fetch('/doctor/notifications');
      const data = await res.json();
      if (data.success) { _dtbNotifs = data.notifications; dtbUpdateBadge(data.unreadCount); }
    } catch {}
  })();
</script>