<div class="doc-sidebar" id="docSidebar">

  <div class="doc-sidebar-logo">
    <a href="/" class="doc-logo-link">Healora</a>
  </div>

  <nav class="doc-sidebar-nav">
    <div class="doc-nav-section">
      <span class="doc-nav-label">MAIN</span>
      <a href="/doctor/dashboard"
        class="doc-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
        <i class="fas fa-home"></i><span>Dashboard</span>
      </a>
      <a href="/doctor/appointments"
        class="doc-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'appointments' ? 'active' : '' %>">
        <i class="fas fa-calendar-check"></i><span>Appointments</span>
      </a>
      <a href="/doctor/patients"
        class="doc-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'patients' ? 'active' : '' %>">
        <i class="fas fa-users"></i><span>My Patients</span>
      </a>
    </div>

    <div class="doc-nav-section">
      <span class="doc-nav-label">MANAGE</span>
      <a href="/doctor/availability"
        class="doc-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'availability' ? 'active' : '' %>">
        <i class="fas fa-clock"></i><span>Availability</span>
      </a>
    </div>

    <div class="doc-nav-section">
      <span class="doc-nav-label">ACCOUNT</span>
      <a href="/doctor/profile"
        class="doc-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'profile' ? 'active' : '' %>">
        <i class="fas fa-user-md"></i><span>My Profile</span>
      </a>
      <a href="/doctor/settings"
        class="doc-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'settings' ? 'active' : '' %>">
        <i class="fas fa-cog"></i><span>Settings</span>
      </a>
    </div>
  </nav>

  <!-- Bottom profile + logout -->
  <div class="doc-sidebar-foot">
    <div class="doc-foot-profile">
      <div class="doc-foot-avatar">
        <% if (locals.user && user.profileImage) { %>
          <img src="<%= user.profileImage %>" alt="<%= user.name %>">
        <% } else { %>
          <%= locals.user ? user.name.charAt(0).toUpperCase() : 'D' %>
        <% } %>
      </div>
      <div class="doc-foot-info">
        <div class="doc-foot-name"><%= locals.user ? user.name.split(' ')[0] : 'Doctor' %></div>
        <div class="doc-foot-role"><%= locals.user && user.specialization ? user.specialization : 'Specialist' %></div>
      </div>
    </div>
    <button class="doc-foot-logout" onclick="showDoctorLogoutModal()" title="Logout">
      <i class="fas fa-sign-out-alt"></i>
    </button>
  </div>
</div>

<!-- Mobile overlay -->
<div class="doc-sidebar-overlay" id="docSidebarOverlay" onclick="toggleDocSidebar()"></div>

<!-- Mobile toggle button -->
<button class="doc-mobile-toggle" id="docMobileToggle" onclick="toggleDocSidebar()">
  <i class="fas fa-bars"></i>
</button>

<!-- Logout Modal -->
<div class="doc-logout-modal" id="doctorLogoutModal">
  <div class="doc-logout-box">
    <div class="doc-logout-icon"><i class="fas fa-sign-out-alt"></i></div>
    <h3>Confirm Logout</h3>
    <p>Are you sure you want to logout from your doctor account?</p>
    <div class="doc-logout-btns">
      <button onclick="closeDoctorLogoutModal()">Cancel</button>
      <button onclick="confirmDoctorLogout()" class="doc-logout-confirm">Logout</button>
    </div>
  </div>
</div>

<style>
  /* ── Sidebar ── */
  .doc-sidebar {
    position: fixed;
    top: 0; left: 0;
    height: 100vh;
    width: 230px;
    background: linear-gradient(180deg, #0f4c75 0%, #0a3553 100%);
    display: flex;
    flex-direction: column;
    z-index: 1000;
    box-shadow: 2px 0 16px rgba(0,0,0,.15);
    transition: transform .3s ease;
  }

  /* ── Logo ── */
  .doc-sidebar-logo {
    padding: 22px 20px 18px;
    border-bottom: 1px solid rgba(255,255,255,.1);
    flex-shrink: 0;
  }

  .doc-logo-link {
    font-size: 22px;
    font-weight: 800;
    color: white;
    text-decoration: none;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* ── Nav ── */
  .doc-sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 18px 10px;
  }

  .doc-sidebar-nav::-webkit-scrollbar { width: 3px; }
  .doc-sidebar-nav::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,.15);
    border-radius: 2px;
  }

  .doc-nav-section { margin-bottom: 24px; }

  .doc-nav-label {
    font-size: 10px;
    font-weight: 700;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    padding: 0 14px;
    display: block;
    margin-bottom: 6px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .doc-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    margin-bottom: 2px;
    border-radius: 10px;
    text-decoration: none;
    color: rgba(255,255,255,.65);
    font-size: 14px;
    font-weight: 600;
    transition: all .2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
    position: relative;
  }

  .doc-nav-item i {
    width: 18px;
    text-align: center;
    font-size: 15px;
    flex-shrink: 0;
  }

  .doc-nav-item:hover {
    background: rgba(255,255,255,.1);
    color: white;
    text-decoration: none;
  }

  .doc-nav-item.active {
    background: rgba(255,255,255,.15);
    color: white;
    border-left: 3px solid #1a7f8e;
    padding-left: 11px;
  }

  /* ── Footer ── */
  .doc-sidebar-foot {
    padding: 14px 16px;
    border-top: 1px solid rgba(255,255,255,.1);
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .doc-foot-profile {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }

  .doc-foot-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a7f8e, #0f4c75);
    color: white;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .doc-foot-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .doc-foot-info { min-width: 0; }

  .doc-foot-name {
    font-size: 13px;
    font-weight: 700;
    color: white;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .doc-foot-role {
    font-size: 11px;
    color: rgba(255,255,255,.45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .doc-foot-logout {
    width: 34px; height: 34px;
    border-radius: 8px;
    background: rgba(239,68,68,.12);
    border: none;
    color: #fca5a5;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    transition: all .2s;
    flex-shrink: 0;
  }

  .doc-foot-logout:hover {
    background: rgba(239,68,68,.25);
    color: #f87171;
  }

  /* ── Mobile toggle ── */
  .doc-mobile-toggle {
    display: none;
    position: fixed;
    top: 14px;
    left: 14px;
    z-index: 1100;
    width: 40px; height: 40px;
    border-radius: 10px;
    background: #0f4c75;
    border: none;
    color: white;
    font-size: 16px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 10px rgba(0,0,0,.2);
  }

  /* ── Overlay ── */
  .doc-sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.5);
    z-index: 999;
  }

  .doc-sidebar-overlay.show { display: block; }

  /* ── Logout Modal ── */
  .doc-logout-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.6);
    backdrop-filter: blur(4px);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .doc-logout-modal.show { display: flex; }

  .doc-logout-box {
    background: white;
    border-radius: 16px;
    padding: 32px 28px;
    text-align: center;
    max-width: 360px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0,0,0,.2);
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .doc-logout-icon {
    width: 56px; height: 56px;
    background: #fef2f2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: #dc2626;
    margin: 0 auto 16px;
  }

  .doc-logout-box h3 {
    font-size: 18px;
    font-weight: 800;
    color: #1a202c;
    margin-bottom: 8px;
  }

  .doc-logout-box p {
    font-size: 13px;
    color: #64748b;
    margin-bottom: 20px;
  }

  .doc-logout-btns { display: flex; gap: 10px; }

  .doc-logout-btns button {
    flex: 1;
    padding: 11px;
    border-radius: 10px;
    border: none;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    background: #f1f5f9;
    color: #64748b;
    transition: all .2s;
    font-family: inherit;
  }

  .doc-logout-btns button:hover { background: #e2e8f0; }

  .doc-logout-confirm {
    background: #dc2626 !important;
    color: white !important;
  }

  .doc-logout-confirm:hover { background: #b91c1c !important; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .doc-sidebar {
      transform: translateX(-100%);
      width: 260px;
    }

    .doc-sidebar.open {
      transform: translateX(0);
    }

    .doc-mobile-toggle { display: flex; }

    .main-content {
      margin-left: 0 !important;
      padding-top: 70px !important;
    }
  }
</style>

<script>
  function toggleDocSidebar() {
    const sidebar = document.getElementById('docSidebar');
    const overlay = document.getElementById('docSidebarOverlay');
    sidebar.classList.toggle('open');
    overlay.classList.toggle('show');
  }

  function showDoctorLogoutModal() {
    document.getElementById('doctorLogoutModal').classList.add('show');
  }

  function closeDoctorLogoutModal() {
    document.getElementById('doctorLogoutModal').classList.remove('show');
  }

  function confirmDoctorLogout() {
    fetch('/doctor/logout', { method: 'POST' })
      .then(() => window.location.href = '/doctor/login')
      .catch(() => window.location.href = '/doctor/login');
  }

  document.getElementById('doctorLogoutModal').addEventListener('click', function(e) {
    if (e.target === this) closeDoctorLogoutModal();
  });
</script>