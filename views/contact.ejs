<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/logo.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --blue:     #1250b0;
      --blue-mid: #1a6fd4;
      --sky:      #0ea5d4;
      --navy:     #071730;
      --ink:      #0f1f3d;
      --slate:    #475569;
      --muted:    #94a3b8;
      --border:   #e2e8f0;
      --surface:  #f8fafd;
      --white:    #ffffff;
      --accent:   #05c8a4;
    }

    body {
      font-family: 'Sora', sans-serif;
      background: var(--surface);
      color: var(--ink);
      overflow-x: hidden;
    }

    /* ── HERO ── */
    .page-hero {
      position: relative;
      background: var(--navy);
      padding: 110px 0 72px;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 56px 56px;
    }

    .page-hero::after {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(26,111,212,.3) 0%, transparent 70%);
      top: -180px; right: -120px;
      pointer-events: none;
    }

    .hero-inner {
      position: relative; z-index: 2;
      display: flex; flex-direction: column; align-items: flex-start;
    }

    .hero-pill {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.13);
      color: var(--accent);
      padding: 6px 16px; border-radius: 40px;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 1.2px;
      margin-bottom: 22px;
    }

    .hero-title {
      font-family: 'Lora', serif;
      font-size: clamp(2.2rem, 4.5vw, 3.4rem);
      font-weight: 500; color: var(--white);
      line-height: 1.15; margin-bottom: 14px;
    }

    .hero-title em { font-style: italic; color: var(--sky); }

    .hero-sub {
      font-size: 14.5px; color: rgba(255,255,255,.55);
      line-height: 1.8; font-weight: 300;
      max-width: 440px; margin-bottom: 28px;
    }

    .hero-breadcrumb {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px; color: rgba(255,255,255,.38);
    }
    .hero-breadcrumb a { color: rgba(255,255,255,.55); text-decoration: none; transition: color .2s; }
    .hero-breadcrumb a:hover { color: var(--white); }
    .hero-breadcrumb i { font-size: 8px; opacity: .7; }

    /* ── MAIN LAYOUT ── */
    .contact-section { padding: 72px 0 90px; }

    .contact-grid {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 28px;
      align-items: start;
    }

    /* ── INFO SIDEBAR ── */
    .info-sidebar { display: flex; flex-direction: column; gap: 14px; }

    .info-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 22px 20px;
      display: flex; align-items: flex-start; gap: 15px;
      transition: border-color .2s, box-shadow .2s, transform .2s;
    }

    .info-card:hover {
      border-color: var(--blue-mid);
      box-shadow: 0 8px 28px rgba(18,80,176,.08);
      transform: translateY(-2px);
    }

    .info-icon {
      width: 46px; height: 46px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }

    .ii-blue   { background: #e8f1fb; color: var(--blue-mid); }
    .ii-green  { background: rgba(5,200,164,.1); color: #059669; }
    .ii-amber  { background: rgba(245,158,11,.1); color: #b45309; }
    .ii-purple { background: rgba(139,92,246,.1); color: #7c3aed; }

    .info-label {
      font-size: 11px; font-weight: 700;
      color: var(--muted); text-transform: uppercase;
      letter-spacing: .8px; margin-bottom: 5px;
    }

    .info-value {
      font-size: 13.5px; color: var(--ink);
      font-weight: 500; line-height: 1.65;
    }

    .info-value a {
      color: var(--ink); text-decoration: none;
    }
    .info-value a:hover { color: var(--blue-mid); }

    /* Emergency badge */
    .emergency-card {
      background: linear-gradient(135deg, var(--navy), #0d3878);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 14px;
      padding: 22px 20px;
      display: flex; align-items: center; gap: 15px;
      position: relative; overflow: hidden;
    }

    .emergency-card::before {
      content: '';
      position: absolute;
      width: 140px; height: 140px; border-radius: 50%;
      background: radial-gradient(circle, rgba(14,165,212,.18) 0%, transparent 70%);
      right: -30px; top: -40px;
    }

    .emerg-icon {
      width: 46px; height: 46px; border-radius: 12px;
      background: rgba(239,68,68,.2);
      color: #f87171;
      display: flex; align-items: center; justify-content: center;
      font-size: 17px; flex-shrink: 0;
    }

    .emerg-label {
      font-size: 11px; font-weight: 700;
      color: rgba(255,255,255,.45); text-transform: uppercase;
      letter-spacing: .8px; margin-bottom: 4px;
    }

    .emerg-number {
      font-family: 'Lora', serif;
      font-size: 1.25rem; color: var(--white);
      font-weight: 500; letter-spacing: .03em;
    }

    /* ── FORM CARD ── */
    .form-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 40px;
      box-shadow: 0 4px 24px rgba(7,23,48,.06);
    }

    .form-header { margin-bottom: 30px; }

    .form-title {
      font-family: 'Lora', serif;
      font-size: 1.6rem; font-weight: 500;
      color: var(--ink); margin-bottom: 6px;
    }

    .form-sub {
      font-size: 13px; color: var(--muted);
      font-weight: 300; line-height: 1.65;
    }

    /* Form fields */
    .fg { margin-bottom: 18px; }

    .fg label {
      display: block;
      font-size: 11px; font-weight: 700;
      color: var(--slate); text-transform: uppercase;
      letter-spacing: .7px; margin-bottom: 7px;
    }

    .fi {
      width: 100%; padding: 12px 15px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 13.5px; font-family: 'Sora', sans-serif;
      color: var(--ink); background: var(--white);
      outline: none; transition: border-color .2s, box-shadow .2s;
    }

    .fi::placeholder { color: var(--muted); font-weight: 300; }
    .fi:focus {
      border-color: var(--blue-mid);
      box-shadow: 0 0 0 3px rgba(26,111,212,.09);
    }

    textarea.fi { resize: vertical; min-height: 130px; }

    .fg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* Divider */
    .form-divider {
      height: 1px; background: var(--border);
      margin: 24px 0;
    }

    /* Submit */
    .btn-send {
      width: 100%; padding: 14px;
      background: var(--blue); color: var(--white);
      border: none; border-radius: 10px;
      font-size: 14px; font-weight: 700;
      font-family: 'Sora', sans-serif; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 9px;
      transition: background .2s, transform .15s, box-shadow .2s;
      letter-spacing: .2px;
    }

    .btn-send:hover {
      background: var(--blue-mid);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(18,80,176,.28);
    }

    .btn-send:disabled { opacity: .65; cursor: not-allowed; transform: none; }

    /* Success alert */
    .form-alert {
      padding: 13px 16px;
      border-radius: 10px;
      font-size: 13px; font-weight: 600;
      display: none; align-items: center; gap: 9px;
      margin-bottom: 20px;
    }
    .form-alert.show { display: flex; }
    .form-alert.success {
      background: rgba(5,200,164,.08);
      border: 1.5px solid rgba(5,200,164,.3);
      color: #059669;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 991px) {
      .contact-grid { grid-template-columns: 1fr; }
      .fg-row { grid-template-columns: 1fr 1fr; }
      .form-card { padding: 28px 24px; }
    }

    @media (max-width: 640px) {
      .page-hero { padding: 90px 0 56px; }
      .hero-title { font-size: 1.9rem; }
      .fg-row { grid-template-columns: 1fr; }
      .form-card { padding: 24px 18px; }
      .contact-section { padding: 48px 0 70px; }
    }
  </style>
</head>
<body>
<%- include('partials/navbar') %>

<!-- ── Hero ── -->
<section class="page-hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-pill">
        <i class="fas fa-headset"></i> Get in Touch
      </div>
      <h1 class="hero-title">We're here whenever<br><em>you need us</em></h1>
      <p class="hero-sub">
        Reach out to our team for appointments, inquiries, or support.
        We respond within 24 hours — emergencies answered immediately.
      </p>
      <div class="hero-breadcrumb">
        <a href="/"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <span>Contact</span>
      </div>
    </div>
  </div>
</section>

<!-- ── Contact Layout ── -->
<section class="contact-section">
  <div class="container">
    <div class="contact-grid">

      <!-- Left: Info -->
      <div class="info-sidebar">

        <div class="info-card">
          <div class="info-icon ii-blue"><i class="fas fa-map-marker-alt"></i></div>
          <div>
            <div class="info-label">Our Location</div>
            <div class="info-value">0122 Some Place, Medical District<br>Some Country</div>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon ii-green"><i class="fas fa-phone-alt"></i></div>
          <div>
            <div class="info-label">Phone</div>
            <div class="info-value">
              <a href="tel:237881812255">(237) 881-812-255</a>
            </div>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon ii-amber"><i class="fas fa-envelope"></i></div>
          <div>
            <div class="info-label">Email</div>
            <div class="info-value">
              <a href="mailto:healora777@gmail.com">healora777@gmail.com</a><br>
              <a href="mailto:support@healora.com">support@healora.com</a>
            </div>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon ii-purple"><i class="fas fa-clock"></i></div>
          <div>
            <div class="info-label">Opening Hours</div>
            <div class="info-value">Mon – Fri: 6:00 AM – 10:00 PM<br>Emergency: 24/7</div>
          </div>
        </div>

        <!-- Emergency strip -->
        <div class="emergency-card">
          <div class="emerg-icon"><i class="fas fa-ambulance"></i></div>
          <div style="position:relative;z-index:1;">
            <div class="emerg-label">Emergency Hotline</div>
            <div class="emerg-number">1-800-HEALORA</div>
          </div>
        </div>

      </div>

      <!-- Right: Form -->
      <div class="form-card">
        <div class="form-header">
          <div class="form-title">Send us a message</div>
          <div class="form-sub">Fill in the form below and we'll get back to you within 24 hours.</div>
        </div>

        <div class="form-alert success" id="formSuccess">
          <i class="fas fa-check-circle"></i> Your message was sent successfully. We'll be in touch soon!
        </div>

        <div class="fg-row">
          <div class="fg">
            <label>First Name</label>
            <input type="text" class="fi" id="firstName" placeholder="John">
          </div>
          <div class="fg">
            <label>Last Name</label>
            <input type="text" class="fi" id="lastName" placeholder="Doe">
          </div>
        </div>

        <div class="fg-row">
          <div class="fg">
            <label>Email Address</label>
            <input type="email" class="fi" id="contactEmail" placeholder="john@example.com">
          </div>
          <div class="fg">
            <label>Phone <span style="color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span></label>
            <input type="tel" class="fi" id="contactPhone" placeholder="+91 98765 43210">
          </div>
        </div>

        <div class="fg">
          <label>Subject</label>
          <input type="text" class="fi" id="contactSubject" placeholder="How can we help?">
        </div>

        <div class="fg">
          <label>Message</label>
          <textarea class="fi" id="contactMessage" placeholder="Tell us more about your inquiry..."></textarea>
        </div>

        <div class="form-divider"></div>

        <button class="btn-send" id="sendBtn" onclick="sendMessage()">
          <i class="fas fa-paper-plane"></i> Send Message
        </button>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  async function sendMessage() {
    const fields = ['firstName', 'lastName', 'contactEmail', 'contactSubject', 'contactMessage'];
    const empty = fields.filter(id => !document.getElementById(id).value.trim());
    if (empty.length) {
      document.getElementById(empty[0]).focus();
      return;
    }

    const btn = document.getElementById('sendBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';

    try {
      const response = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName:      document.getElementById('firstName').value.trim(),
          lastName:       document.getElementById('lastName').value.trim(),
          contactEmail:   document.getElementById('contactEmail').value.trim(),
          contactPhone:   document.getElementById('contactPhone').value.trim(),
          contactSubject: document.getElementById('contactSubject').value.trim(),
          contactMessage: document.getElementById('contactMessage').value.trim(),
        })
      });

      const data = await response.json();

      if (data.success) {
        document.getElementById('formSuccess').classList.add('show');
        [...fields, 'contactPhone'].forEach(id => document.getElementById(id).value = '');
        setTimeout(() => document.getElementById('formSuccess').classList.remove('show'), 5000);
      } else {
        alert(data.error || 'Something went wrong. Please try again.');
      }
    } catch (err) {
      console.error('Contact form error:', err);
      alert('Network error. Please try again.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Message';
    }
  }
</script>
</body>
</html>
