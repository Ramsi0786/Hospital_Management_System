<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/Logo-browser.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; }
    .page-hero { background: linear-gradient(135deg, #0D3D8F 0%, #1A6FD4 100%); padding: 60px 0; color: white; text-align: center; }
    .page-hero h1 { font-size: 38px; font-weight: 800; margin-bottom: 12px; }
    .page-hero p  { font-size: 15px; color: rgba(255,255,255,.75); }
    .breadcrumb-hero { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,.6); margin-top: 14px; }
    .breadcrumb-hero a { color: rgba(255,255,255,.75); text-decoration: none; }

    .contact-section { padding: 60px 0; }
    .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 32px; align-items: start; }

    /* Info cards */
    .contact-info { display: flex; flex-direction: column; gap: 16px; }
    .contact-info-card {
      background: white; border-radius: 14px;
      border: 1.5px solid #e4eaf3;
      padding: 20px; display: flex; align-items: flex-start; gap: 14px;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
    }
    .contact-info-icon {
      width: 44px; height: 44px; border-radius: 12px;
      background: #E8F0FD; color: #1459C8;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .contact-info-title { font-size: 13px; font-weight: 800; color: #0B1120; margin-bottom: 3px; }
    .contact-info-val   { font-size: 13px; color: #64748b; font-weight: 500; line-height: 1.6; }

    /* Form */
    .contact-form-card {
      background: white; border-radius: 16px;
      border: 1.5px solid #e4eaf3;
      padding: 32px;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
    }
    .form-title { font-size: 20px; font-weight: 800; color: #0B1120; margin-bottom: 6px; }
    .form-sub   { font-size: 13px; color: #94a3b8; margin-bottom: 24px; }

    .fg { margin-bottom: 16px; }
    .fg label { display: block; font-size: 11px; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
    .fi {
      width: 100%; padding: 11px 14px;
      border: 1.5px solid #e2e8f0; border-radius: 10px;
      font-size: 13px; font-family: inherit; color: #374151;
      outline: none; background: white; transition: border-color .2s;
    }
    .fi:focus { border-color: #1459C8; box-shadow: 0 0 0 3px rgba(20,89,200,.08); }
    textarea.fi { resize: vertical; min-height: 120px; }

    .fg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    .btn-send {
      width: 100%; padding: 13px;
      background: #1459C8; color: white;
      border: none; border-radius: 10px;
      font-size: 14px; font-weight: 700;
      font-family: inherit; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: background .2s, transform .15s;
    }
    .btn-send:hover { background: #0D3D8F; transform: translateY(-1px); }

    .form-alert {
      padding: 12px 14px; border-radius: 10px;
      font-size: 13px; font-weight: 600;
      display: none; align-items: center; gap: 8px;
      margin-bottom: 16px;
    }
    .form-alert.show { display: flex; }
    .form-alert.success { background: rgba(13,191,126,.08); border: 1.5px solid rgba(13,191,126,.25); color: #0a9962; }

    @media (max-width: 991px) {
      .contact-grid { grid-template-columns: 1fr; }
      .fg-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<%- include('partials/navbar') %>

<div class="page-hero">
  <h1>Contact Us</h1>
  <p>We're here to help — reach out to us anytime</p>
  <div class="breadcrumb-hero">
    <a href="/">Home</a>
    <i class="fas fa-chevron-right" style="font-size:10px;"></i>
    <span>Contact</span>
  </div>
</div>

<div class="contact-section">
  <div class="container">
    <div class="contact-grid">

      <!-- Contact Info -->
      <div class="contact-info">
        <div class="contact-info-card">
          <div class="contact-info-icon"><i class="fas fa-map-marker-alt"></i></div>
          <div>
            <div class="contact-info-title">Our Location</div>
            <div class="contact-info-val">0122 Some Place, Medical District<br>Some Country</div>
          </div>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon"><i class="fas fa-phone-alt"></i></div>
          <div>
            <div class="contact-info-title">Phone</div>
            <div class="contact-info-val">(237) 881-812-255<br>Emergency: 1-800-HEALORA</div>
          </div>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon"><i class="fas fa-envelope"></i></div>
          <div>
            <div class="contact-info-title">Email</div>
            <div class="contact-info-val">healora777@gmail.com<br>support@healora.com</div>
          </div>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon"><i class="fas fa-clock"></i></div>
          <div>
            <div class="contact-info-title">Opening Hours</div>
            <div class="contact-info-val">Mon – Fri: 6:00 AM – 10:00 PM<br>Emergency: 24/7</div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-card">
        <div class="form-title">Send Us a Message</div>
        <div class="form-sub">Fill in the form and we'll get back to you within 24 hours.</div>

        <div class="form-alert success" id="formSuccess">
          <i class="fas fa-check-circle"></i> Your message was sent successfully. We'll be in touch soon!
        </div>

        <div class="fg-row">
          <div class="fg">
            <label>First Name</label>
            <input type="text" class="fi" id="firstName" placeholder="John">
          </div>
          <div class="fg">
            <label>Last Name</label>
            <input type="text" class="fi" id="lastName" placeholder="Doe">
          </div>
        </div>
        <div class="fg">
          <label>Email Address</label>
          <input type="email" class="fi" id="contactEmail" placeholder="john@example.com">
        </div>
        <div class="fg">
          <label>Phone (optional)</label>
          <input type="tel" class="fi" id="contactPhone" placeholder="+91 98765 43210">
        </div>
        <div class="fg">
          <label>Subject</label>
          <input type="text" class="fi" id="contactSubject" placeholder="How can we help?">
        </div>
        <div class="fg">
          <label>Message</label>
          <textarea class="fi" id="contactMessage" placeholder="Tell us more about your inquiry..."></textarea>
        </div>
        <button class="btn-send" id="sendBtn" onclick="sendMessage()">
          <i class="fas fa-paper-plane"></i> Send Message
        </button>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  async function sendMessage() {
    const fields = ['firstName', 'lastName', 'contactEmail', 'contactSubject', 'contactMessage'];
    const empty = fields.filter(id => !document.getElementById(id).value.trim());
    if (empty.length) {
      document.getElementById(empty[0]).focus();
      return;
    }

    const btn = document.getElementById('sendBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';

    try {
      const response = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName:      document.getElementById('firstName').value.trim(),
          lastName:       document.getElementById('lastName').value.trim(),
          contactEmail:   document.getElementById('contactEmail').value.trim(),
          contactPhone:   document.getElementById('contactPhone').value.trim(),
          contactSubject: document.getElementById('contactSubject').value.trim(),
          contactMessage: document.getElementById('contactMessage').value.trim(),
        })
      });

      const data = await response.json();

      if (data.success) {
        document.getElementById('formSuccess').classList.add('show');
        [...fields, 'contactPhone'].forEach(id => document.getElementById(id).value = '');
        setTimeout(() => document.getElementById('formSuccess').classList.remove('show'), 5000);
      } else {
        alert(data.error || 'Something went wrong. Please try again.');
      }
    } catch (err) {
      console.error('Contact form error:', err);
      alert('Network error. Please try again.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Message';
    }
  }
</script>
</body>
</html>
