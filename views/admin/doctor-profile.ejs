<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <title>Doctor Profile - Healora</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin/dashboard.css">
  <link rel="stylesheet" href="/css/admin/profile.css">
</head>
<body>

<%
  const appts = (typeof appointments !== 'undefined' && Array.isArray(appointments)) ? appointments : [];
  let badgeClass = 'active', badgeText = 'Active';
  if (doctor.status === 'blocked')       { badgeClass = 'blocked';  badgeText = 'Blocked'; }
  else if (doctor.status === 'inactive') { badgeClass = 'inactive'; badgeText = 'Inactive'; }
%>

<%- include('../partials/admin-sidebar', { currentPage: 'doctors' }) %>
<%- include('../partials/admin-topbar', { admin: admin, breadcrumb: 'Doctor Profile' }) %>

<div class="main-content">
  <a href="/admin/doctors-management" class="back-button">
    <i class="fas fa-arrow-left"></i> Back to Doctors
  </a>

  <!-- ═══════════════ HERO HEADER ═══════════════ -->
  <div class="profile-header">
    <div class="profile-content">
      <div class="profile-top">
        <div class="profile-main">
          <div class="profile-avatar-large">
            <% if (doctor.profileImage) { %>
              <img src="<%= doctor.profileImage %>" alt="Doctor Avatar" class="avatar-img">
            <% } else { %>
              <i class="fas fa-user-doctor avatar-icon"></i>
            <% } %>
          </div>
          <div class="profile-info">
            <div class="profile-name-row">
              <h1>Dr. <%= doctor.name %></h1>
              <span class="status-pill <%= badgeClass %>">
                <% if (doctor.status === 'blocked') { %><i class="fas fa-ban"></i>
                <% } else { %><i class="fas fa-circle status-dot"></i><% } %>
                <%= badgeText %>
              </span>
            </div>
            <div class="profile-meta">
              <div class="meta-item"><i class="fas fa-id-card"></i><span>ID: <%= doctor._id.toString().substring(0,7).toUpperCase() %></span></div>
              <div class="meta-item"><i class="fas fa-stethoscope"></i><span><%= doctor.specialization %></span></div>
              <div class="meta-item"><i class="fas fa-building"></i><span><%= doctor.department %></span></div>
              <div class="meta-item"><i class="fas fa-calendar"></i><span>Joined <%= new Date(doctor.createdAt).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></span></div>
            </div>
          </div>
        </div>
        <div class="profile-actions">
          <button class="btn-action btn-edit" onclick="showEditModal()"><i class="fas fa-pen"></i> Edit</button>
          <button class="btn-action <%= doctor.status === 'blocked' ? 'btn-unblock' : 'btn-block' %>" onclick="toggleBlock()">
            <i class="fas fa-<%= doctor.status === 'blocked' ? 'unlock' : 'ban' %>"></i>
            <%= doctor.status === 'blocked' ? 'Unblock' : 'Block' %>
          </button>
        </div>
      </div>
    </div>
    <div class="profile-stats">
      <div class="stat-item">
        <span class="stat-value"><%= appts.length %></span>
        <span class="stat-label">Total Appointments</span>
      </div>
      <div class="stat-item">
        <span class="stat-value"><%= appts.filter(a => a.status === 'completed').length %></span>
        <span class="stat-label">Completed</span>
      </div>
      <div class="stat-item">
        <span class="stat-value"><%= doctor.experience || 2 %> yrs</span>
        <span class="stat-label">Experience</span>
      </div>
      <div class="stat-item">
        <span class="stat-value"><%= doctor.rating || 4.8 %> ★</span>
        <span class="stat-label">Rating</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════ INFO CARDS ═══════════════ -->
  <div class="content-grid">
    <div class="info-card">
      <h3><i class="fas fa-user-doctor"></i> Basic Information</h3>
      <div class="info-row"><span class="info-label">Full Name</span><span class="info-value">Dr. <%= doctor.name %></span></div>
      <div class="info-row"><span class="info-label">Status</span><span class="info-value">
        <span class="status-pill <%= badgeClass %>">
          <% if (doctor.status === 'blocked') { %><i class="fas fa-ban"></i><% } else { %><i class="fas fa-circle status-dot"></i><% } %>
          <%= badgeText %>
        </span>
      </span></div>
      <div class="info-row"><span class="info-label">Email</span><span class="info-value"><%= doctor.email %></span></div>
      <div class="info-row"><span class="info-label">Phone</span><span class="info-value"><%= doctor.phone %></span></div>
      <div class="info-row"><span class="info-label">Specialization</span><span class="info-value"><%= doctor.specialization %></span></div>
      <div class="info-row"><span class="info-label">Department</span><span class="info-value"><%= doctor.department %></span></div>
      <div class="info-row"><span class="info-label">Qualification</span><span class="info-value"><%= doctor.qualification || '—' %></span></div>
      <div class="info-row"><span class="info-label">Experience</span><span class="info-value"><%= doctor.experience ? doctor.experience + ' Years' : '2 Years' %></span></div>
    </div>

    <div class="info-card">
      <h3><i class="fas fa-briefcase-medical"></i> Professional Details</h3>
      <div class="info-row"><span class="info-label">Consultation Fee</span><span class="info-value"><%= doctor.consultationFee ? '₹' + doctor.consultationFee : '—' %></span></div>
      <div class="info-row"><span class="info-label">Rating</span><span class="info-value"><%= doctor.rating ? doctor.rating + ' ★ / 5' : '4.7 ★' %></span></div>
      <div class="info-row"><span class="info-label">Featured</span><span class="info-value">
        <span class="badge <%= doctor.isFeatured ? 'active' : 'inactive' %>">&nbsp;<%= doctor.isFeatured ? 'Yes' : 'No' %>&nbsp;</span>
      </span></div>
      <div class="info-row"><span class="info-label">Member Since</span><span class="info-value"><%= new Date(doctor.createdAt).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) %></span></div>
      <div class="info-row"><span class="info-label">Last Updated</span><span class="info-value"><%= doctor.updatedAt ? new Date(doctor.updatedAt).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) : 'N/A' %></span></div>
      <h3 style="margin-top:0; border-top:1px solid #e8ecf1;"><i class="fas fa-file-alt"></i> Biography</h3>
      <div style="padding:14px 22px;">
        <p style="color:#64748b;font-size:13.5px;line-height:1.7;margin:0;"><%= doctor.bio || '—' %></p>
      </div>
    </div>
  </div>

  <!-- ═══════════════ APPOINTMENTS ═══════════════ -->
  <div class="info-card" style="margin-bottom:18px;">
    <h3><i class="fas fa-calendar-check"></i> Recent Appointments</h3>
    <% if (appts.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-calendar-times"></i>
        <p>No appointments found</p>
      </div>
    <% } else { %>
      <div style="overflow-x:auto;">
        <table class="appointments-table">
          <thead>
            <tr>
              <th>Date</th><th>Patient</th><th>Time</th><th>Reason</th><th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% appts.slice(0,10).forEach(a => { %>
              <tr>
                <td><%= new Date(a.date).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) %></td>
                <td><%= a.patientName || 'Unknown' %></td>
                <td><%= a.timeSlot || '—' %></td>
                <td><%= a.reason || '—' %></td>
                <td><span class="abadge <%= a.status || 'pending' %>"><%= (a.status||'pending').toUpperCase() %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- ═══════════════ AVAILABILITY MANAGEMENT ═══════════════ -->
  <div class="avail-card">
    <div class="avail-card-header">
      <div class="avail-card-title">
        <i class="fas fa-clock"></i>
        <h3>Availability Management</h3>
      </div>
      <div class="avail-tabs">
        <button class="avail-tab active" onclick="switchTab('weekly',this)">
          <i class="fas fa-calendar-week"></i> Weekly Template
        </button>
        <button class="avail-tab" onclick="switchTab('monthly',this)">
          <i class="fas fa-calendar-alt"></i> Monthly Override
        </button>
        <button class="avail-tab" onclick="switchTab('exceptions',this)">
          <i class="fas fa-calendar-times"></i> Daily Exceptions
        </button>
      </div>
    </div>

    <div class="avail-body">

      <!-- WEEKLY TAB -->
      <div id="tab-weekly">
        <p class="avail-desc">
          <i class="fas fa-info-circle" style="color:#203f6a;margin-right:4px;"></i>
          Default recurring schedule. Applies to all dates unless overridden by a monthly or daily setting.
        </p>
        <div class="duration-box">
          <label><i class="fas fa-hourglass-half" style="margin-right:6px;"></i> Slot Duration</label>
          <div style="display:flex;gap:8px;flex-wrap:wrap;" id="durationPicker">
            <button type="button" class="dur-btn" data-min="15" onclick="setDuration(15)">15 min</button>
            <button type="button" class="dur-btn active" data-min="30" onclick="setDuration(30)">30 min</button>
            <button type="button" class="dur-btn" data-min="45" onclick="setDuration(45)">45 min</button>
            <button type="button" class="dur-btn" data-min="60" onclick="setDuration(60)">60 min</button>
          </div>
          <p class="duration-note">
            <i class="fas fa-triangle-exclamation"></i>
            Changing duration regenerates all slot options. Re-select your slots after changing.
          </p>
        </div>
        <div id="weekly-schedule"></div>
        <button class="save-btn" onclick="saveWeekly()"><i class="fas fa-save"></i> Save Weekly Schedule</button>
      </div>

      <!-- MONTHLY TAB -->
      <div id="tab-monthly" style="display:none;">
        <p class="avail-desc">
          <i class="fas fa-info-circle" style="color:#203f6a;margin-right:4px;"></i>
          Override the weekly schedule for a specific month. Uses the same slot duration set in Weekly.
        </p>
        <div class="month-controls">
          <select id="monthSelect" class="avail-select" onchange="loadMonthly()">
            <option value="1">January</option><option value="2">February</option><option value="3">March</option>
            <option value="4">April</option><option value="5">May</option><option value="6">June</option>
            <option value="7">July</option><option value="8">August</option><option value="9">September</option>
            <option value="10">October</option><option value="11">November</option><option value="12">December</option>
          </select>
          <select id="yearSelect" class="avail-select" onchange="loadMonthly()"></select>
          <button class="copy-btn" onclick="copyFromWeekly()"><i class="fas fa-copy"></i> Copy from Weekly</button>
        </div>
        <div id="monthly-schedule"></div>
        <button class="save-btn" onclick="saveMonthly()"><i class="fas fa-save"></i> Save Monthly Override</button>
      </div>

      <!-- EXCEPTIONS TAB -->
      <div id="tab-exceptions" style="display:none;">
        <p class="avail-desc">
          <i class="fas fa-info-circle" style="color:#203f6a;margin-right:4px;"></i>
          Override specific dates — mark as holiday, leave, or a special working day with custom slots.
        </p>
        <div class="exception-form">
          <h4><i class="fas fa-plus-circle"></i> Add / Edit Exception</h4>
          <div class="ex-grid">
            <div>
              <label class="ex-label">Date</label>
              <input type="date" id="exceptionDate" class="ex-input" min="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <div>
              <label class="ex-label">Status</label>
              <select id="exceptionWorking" class="ex-input" onchange="toggleExSlots()">
                <option value="false">Not Working (Holiday / Leave)</option>
                <option value="true">Working (Special Day)</option>
              </select>
            </div>
          </div>
          <div style="margin-bottom:14px;">
            <label class="ex-label">Reason (optional)</label>
            <input type="text" id="exceptionReason" class="ex-input" placeholder="e.g. Public Holiday, Conference, Leave">
          </div>
          <div id="exSlotsWrapper" style="display:none;margin-bottom:4px;">
            <label class="ex-label" style="margin-bottom:8px;">Select Slots</label>
            <div id="exceptionSlots" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
          </div>
          <button class="save-btn" onclick="saveException()" style="margin-top:14px;">
            <i class="fas fa-check"></i> Save Exception
          </button>
        </div>
        <h4 style="font-size:13px;font-weight:800;color:#1a2a3a;margin-bottom:14px;text-transform:uppercase;letter-spacing:.5px;">
          Existing Exceptions
        </h4>
        <div id="exceptions-list"></div>
      </div>

    </div>
  </div>
</div>

<!-- ═══════════════ EDIT MODAL ═══════════════ -->
<div class="modal-overlay" id="editModal">
  <div class="modal-content-custom">
    <div class="modal-header">
      <h3><i class="fas fa-pen" style="color:#203f6a;margin-right:8px;font-size:15px;"></i> Edit Doctor</h3>
      <button class="btn-close-modal" onclick="closeEditModal()"><i class="fas fa-times"></i></button>
    </div>
    <form id="editForm">
      <div class="modal-body">
        <div class="form-group"><label>Full Name *</label><input type="text" id="editName" value="<%= doctor.name %>" required></div>
        <div class="form-group"><label>Email *</label><input type="email" id="editEmail" value="<%= doctor.email %>" required></div>
        <div class="form-group"><label>Phone *</label><input type="tel" id="editPhone" value="<%= doctor.phone %>" required></div>
        <div class="form-group"><label>Specialization *</label><input type="text" id="editSpecialization" value="<%= doctor.specialization %>" required></div>
        <div class="form-group">
          <label>Department *</label>
          <select id="editDepartment" required>
            <option value="">Select Department</option>
            <option value="Cardiology"       <%= doctor.department==='Cardiology'?'selected':''       %>>Cardiology</option>
            <option value="Neurology"        <%= doctor.department==='Neurology'?'selected':''        %>>Neurology</option>
            <option value="Orthopedics"      <%= doctor.department==='Orthopedics'?'selected':''      %>>Orthopedics</option>
            <option value="Pediatrics"       <%= doctor.department==='Pediatrics'?'selected':''       %>>Pediatrics</option>
            <option value="Dermatology"      <%= doctor.department==='Dermatology'?'selected':''      %>>Dermatology</option>
            <option value="Psychiatry"       <%= doctor.department==='Psychiatry'?'selected':''       %>>Psychiatry</option>
            <option value="General Medicine" <%= doctor.department==='General Medicine'?'selected':'' %>>General Medicine</option>
          </select>
        </div>
        <div class="form-group"><label>Qualification</label><input type="text" id="editQualification" value="<%= doctor.qualification || '' %>" placeholder="e.g. MBBS, MD"></div>
        <div class="form-group"><label>Experience (years)</label><input type="number" id="editExperience" value="<%= doctor.experience || '' %>" min="0" max="60"></div>
        <div class="form-group"><label>Consultation Fee (₹) *</label><input type="number" id="editConsultationFee" value="<%= doctor.consultationFee || '' %>" min="0" required placeholder="e.g. 500"></div>
        <div class="form-group"><label>Password (leave blank to keep current)</label><input type="password" id="editPassword" placeholder="Enter new password"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-modal btn-cancel" onclick="closeEditModal()">Cancel</button>
        <button type="submit" class="btn-modal btn-submit">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/logout-modal') %>
<%- include('../partials/loading') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/alerts.js"></script>
<script src="/js/loader.js"></script>
<%- include('../partials/admin-scripts') %>

<script type="application/json" id="doctor-data">
  <%- JSON.stringify({ id: doctor._id, status: doctor.status }) %>
</script>

<script>
  const DOCTOR_DATA = JSON.parse(document.getElementById('doctor-data').textContent);
  const doctorId    = DOCTOR_DATA.id;

  // ── Edit & Block ────────────────────────────────────────────────
  function showEditModal()  { document.getElementById('editModal').classList.add('show'); }
  function closeEditModal() { document.getElementById('editModal').classList.remove('show'); }
  document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) closeEditModal();
  });
  document.getElementById('editForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = {
  name:            document.getElementById('editName').value.trim(),
  email:           document.getElementById('editEmail').value.trim(),
  phone:           document.getElementById('editPhone').value.trim(),
  specialization:  document.getElementById('editSpecialization').value.trim(),
  department:      document.getElementById('editDepartment').value,
  qualification:   document.getElementById('editQualification').value.trim(),
  experience:      document.getElementById('editExperience').value,
  consultationFee: document.getElementById('editConsultationFee').value,
  password:        document.getElementById('editPassword').value
};
    Loader.show('Updating doctor...');
    try {
      const res  = await fetch(`/admin/api/doctors/${doctorId}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(formData) });
      const data = await res.json();
      Loader.hide();
      if (res.ok) { Alert.success('Doctor updated successfully!').then(() => window.location.reload()); }
      else Alert.error(data.error || 'Failed to update doctor');
    } catch(err) { Loader.hide(); Alert.error('Error updating doctor. Please try again.'); }
  });

  async function toggleBlock() {
    const isBlocked = DOCTOR_DATA.status === 'blocked';
    const action    = isBlocked ? 'unblock' : 'block';
    const result    = await Alert.confirm(`Are you sure you want to ${action} this doctor?`, `${action.charAt(0).toUpperCase()+action.slice(1)} Doctor`);
    if (!result.isConfirmed) return;
    Loader.show(`${action}ing doctor...`);
    try {
      const res  = await fetch(`/admin/api/doctors/${doctorId}/block`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ block: !isBlocked }) });
      const data = await res.json();
      Loader.hide();
      if (res.ok && data.success) { Alert.success(`Doctor ${action}ed successfully!`).then(() => window.location.reload()); }
      else Alert.error(data.error || `Failed to ${action} doctor`);
    } catch(err) { Loader.hide(); Alert.error(`Error ${action}ing doctor. Please try again.`); }
  }

  // ── Availability constants ──────────────────────────────────────
  const DOCTOR_ID  = '<%= doctor._id %>';
  const DAYS       = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
  const DAY_LABELS = { monday:'Monday', tuesday:'Tuesday', wednesday:'Wednesday', thursday:'Thursday', friday:'Friday', saturday:'Saturday', sunday:'Sunday' };

  let currentDuration = 30;
  let weeklyData      = null;

  function generateSlots(duration) {
    const slots  = [];
    const start  = 9 * 60;
    const end    = 17 * 60 + 30;
    const lunchS = 12 * 60 + 30;
    const lunchE = 14 * 60;
    for (let t = start; t < end; t += duration) {
      if (t >= lunchS && t < lunchE) continue;
      const h = String(Math.floor(t / 60)).padStart(2, '0');
      const m = String(t % 60).padStart(2, '0');
      slots.push(`${h}:${m}`);
    }
    return slots;
  }

  function setDuration(min) {
    currentDuration = min;
    document.querySelectorAll('.dur-btn').forEach(b => {
      b.classList.toggle('active', parseInt(b.dataset.min) === min);
    });
    buildDaySchedule('weekly-schedule', null, generateSlots(min));
  }

  function switchTab(tab, btn) {
    document.querySelectorAll('.avail-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('#tab-weekly,#tab-monthly,#tab-exceptions').forEach(c => c.style.display = 'none');
    btn.classList.add('active');
    document.getElementById(`tab-${tab}`).style.display = 'block';
    if (tab === 'weekly')     loadWeekly();
    if (tab === 'monthly')    loadMonthly();
    if (tab === 'exceptions') loadExceptions();
  }

  function buildDaySchedule(containerId, scheduleData, slotsArr) {
    const slots = slotsArr || generateSlots(currentDuration);
    const el    = document.getElementById(containerId);
    el.innerHTML = DAYS.map(day => {
      const d   = scheduleData?.[day] || { isWorking: false, slots: [] };
      const cnt = d.isWorking ? `${d.slots.length} slots` : 'Day off';
      return `
        <div class="day-row ${d.isWorking ? 'is-working' : ''}" id="${containerId}-row-${day}">
          <div class="day-toggle">
            <label class="toggle-sw">
              <input type="checkbox" ${d.isWorking ? 'checked' : ''} onchange="toggleDay('${containerId}','${day}',this.checked)">
              <span class="toggle-knob"></span>
            </label>
            <span class="day-name">${DAY_LABELS[day]}</span>
            <span class="slots-count" id="${containerId}-cnt-${day}">${cnt}</span>
          </div>
          <div class="day-slots ${!d.isWorking ? 'slots-hidden' : ''}" id="${containerId}-slots-${day}">
            ${slots.map(s => `
              <label class="slot-pill">
                <input type="checkbox" value="${s}" ${(d.slots || []).includes(s) ? 'checked' : ''} onchange="updateCount('${containerId}','${day}')">
                <span>${s}</span>
              </label>`).join('')}
            <div class="quick-btns">
              <button type="button" class="qbtn" onclick="selAll('${containerId}','${day}')">All</button>
              <button type="button" class="qbtn" onclick="selMorning('${containerId}','${day}')">Morning</button>
              <button type="button" class="qbtn" onclick="selAfternoon('${containerId}','${day}')">Afternoon</button>
              <button type="button" class="qbtn" onclick="selNone('${containerId}','${day}')">Clear</button>
            </div>
          </div>
        </div>`;
    }).join('');
  }

  function toggleDay(cid, day, on) {
    document.getElementById(`${cid}-slots-${day}`).classList.toggle('slots-hidden', !on);
    document.getElementById(`${cid}-row-${day}`).classList.toggle('is-working', on);
    updateCount(cid, day);
  }
  function updateCount(cid, day) {
    const on  = document.querySelector(`#${cid}-row-${day} .toggle-sw input`).checked;
    const cnt = on ? document.querySelectorAll(`#${cid}-slots-${day} input:checked`).length : 0;
    document.getElementById(`${cid}-cnt-${day}`).textContent = on ? `${cnt} slots` : 'Day off';
  }
  function getSchedule(cid) {
    const s = {};
    DAYS.forEach(day => {
      const on    = document.querySelector(`#${cid}-row-${day} .toggle-sw input`)?.checked || false;
      const slots = on ? [...document.querySelectorAll(`#${cid}-slots-${day} input:checked`)].map(cb => cb.value) : [];
      s[day] = { isWorking: on, slots };
    });
    return s;
  }

  function selAll(cid, day)       { document.querySelectorAll(`#${cid}-slots-${day} input[type=checkbox]`).forEach(cb => cb.checked = true);  updateCount(cid, day); }
  function selMorning(cid, day)   { document.querySelectorAll(`#${cid}-slots-${day} input[type=checkbox]`).forEach(cb => { cb.checked = parseInt(cb.value) < 12; }); updateCount(cid, day); }
  function selAfternoon(cid, day) { document.querySelectorAll(`#${cid}-slots-${day} input[type=checkbox]`).forEach(cb => { cb.checked = parseInt(cb.value) >= 12; }); updateCount(cid, day); }
  function selNone(cid, day)      { document.querySelectorAll(`#${cid}-slots-${day} input[type=checkbox]`).forEach(cb => cb.checked = false); updateCount(cid, day); }

  async function loadWeekly() {
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/weekly`);
      const data = await res.json();
      weeklyData = data.weekly?.schedule || null;
      if (data.slotDuration) {
        currentDuration = data.slotDuration;
        document.querySelectorAll('.dur-btn').forEach(b => {
          b.classList.toggle('active', parseInt(b.dataset.min) === data.slotDuration);
        });
      }
      buildDaySchedule('weekly-schedule', weeklyData, data.allSlots);
    } catch(e) { console.error(e); }
  }

  async function saveWeekly() {
    const schedule = getSchedule('weekly-schedule');
    Loader.show('Saving weekly schedule...');
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/weekly`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ schedule, slotDuration: currentDuration })
      });
      const data = await res.json();
      Loader.hide();
      if (data.success) { Alert.success('Weekly schedule saved!'); weeklyData = schedule; }
      else Alert.error(data.error || 'Failed to save');
    } catch(e) { Loader.hide(); Alert.error('Error saving weekly schedule'); }
  }

  function initYearSelect() {
    const sel = document.getElementById('yearSelect');
    const yr  = new Date().getFullYear();
    for (let y = yr; y <= yr + 2; y++) sel.innerHTML += `<option value="${y}">${y}</option>`;
    document.getElementById('monthSelect').value = new Date().getMonth() + 1;
  }

  async function loadMonthly() {
    const m = document.getElementById('monthSelect').value;
    const y = document.getElementById('yearSelect').value;
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/monthly?month=${m}&year=${y}`);
      const data = await res.json();
      buildDaySchedule('monthly-schedule', data.monthly?.schedule || null, data.allSlots);
    } catch(e) { console.error(e); }
  }

  function copyFromWeekly() {
    buildDaySchedule('monthly-schedule', weeklyData, generateSlots(currentDuration));
  }

  async function saveMonthly() {
    const schedule = getSchedule('monthly-schedule');
    const month    = parseInt(document.getElementById('monthSelect').value);
    const year     = parseInt(document.getElementById('yearSelect').value);
    Loader.show('Saving monthly override...');
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/monthly`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ month, year, schedule })
      });
      const data = await res.json();
      Loader.hide();
      if (data.success) Alert.success('Monthly override saved!');
      else Alert.error(data.error || 'Failed to save');
    } catch(e) { Loader.hide(); Alert.error('Error saving monthly schedule'); }
  }

  function toggleExSlots() {
    const on = document.getElementById('exceptionWorking').value === 'true';
    document.getElementById('exSlotsWrapper').style.display = on ? 'block' : 'none';
    if (on) {
      const slots = generateSlots(currentDuration);
      document.getElementById('exceptionSlots').innerHTML =
        slots.map(s => `<label class="slot-pill"><input type="checkbox" value="${s}"><span>${s}</span></label>`).join('');
    }
  }

  async function saveException() {
    const date      = document.getElementById('exceptionDate').value;
    const isWorking = document.getElementById('exceptionWorking').value === 'true';
    const reason    = document.getElementById('exceptionReason').value;
    if (!date) { Alert.error('Please select a date'); return; }
    const slots = isWorking ? [...document.querySelectorAll('#exceptionSlots input:checked')].map(cb => cb.value) : [];
    Loader.show('Saving exception...');
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/exceptions`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ date, isWorking, slots, reason })
      });
      const data = await res.json();
      Loader.hide();
      if (data.success) {
        Alert.success('Exception saved!');
        loadExceptions();
        document.getElementById('exceptionDate').value    = '';
        document.getElementById('exceptionReason').value  = '';
        document.getElementById('exceptionWorking').value = 'false';
        document.getElementById('exSlotsWrapper').style.display = 'none';
      } else Alert.error(data.error || 'Failed to save');
    } catch(e) { Loader.hide(); Alert.error('Error saving exception'); }
  }

  async function loadExceptions() {
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/exceptions`);
      const data = await res.json();
      if (data.slotDuration) currentDuration = data.slotDuration;
      renderExceptions(data.exceptions || []);
    } catch(e) { console.error(e); }
  }

  function renderExceptions(list) {
    const el = document.getElementById('exceptions-list');
    if (!list.length) {
      el.innerHTML = `<div class="empty-state"><i class="fas fa-calendar-check"></i><p>No exceptions set</p></div>`;
      return;
    }
    el.innerHTML = list.map(ex => `
      <div class="exception-item">
        <div class="ex-info">
          <span class="ex-date">${ex.date}</span>
          <span class="${ex.isWorking ? 'ex-badge-working' : 'ex-badge-off'}">${ex.isWorking ? 'Working' : 'Not Working'}</span>
          ${ex.reason ? `<span class="ex-reason">${ex.reason}</span>` : ''}
          ${ex.isWorking && ex.slots.length ? `<span class="ex-slots-text">${ex.slots.join(', ')}</span>` : ''}
        </div>
        <button class="del-btn" onclick="deleteException('${ex.date}')"><i class="fas fa-trash"></i></button>
      </div>`).join('');
  }

  async function deleteException(date) {
    const result = await Alert.confirm(`Remove exception for ${date}?`, 'Delete Exception');
    if (!result.isConfirmed) return;
    Loader.show('Removing exception...');
    try {
      const res  = await fetch(`/admin/api/doctors/${DOCTOR_ID}/availability/exceptions/${date}`, { method:'DELETE' });
      const data = await res.json();
      Loader.hide();
      if (data.success) { Alert.success('Exception removed!'); loadExceptions(); }
      else Alert.error(data.error || 'Failed to delete');
    } catch(e) { Loader.hide(); Alert.error('Error deleting exception'); }
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadWeekly();
    initYearSelect();
  });
</script>
</body>
</html>
