<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin/dashboard.css">
</head>
<body>

  <%- include('../partials/admin-sidebar', { currentPage: 'dashboard' }) %>
  <%- include('../partials/admin-topbar', { admin: admin, breadcrumb: null }) %>

  <div class="main-content">

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
        <h3><%= totalAppointments %></h3>
        <p>Total Appointments</p>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-user-injured"></i></div>
        <h3><%= totalPatients %></h3>
        <p>Total Patients</p>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-user-doctor"></i></div>
        <h3><%= totalDoctors %></h3>
        <p>Total Doctors</p>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
        <h3>₹0</h3>
        <p>Total Revenue</p>
      </div>
    </div>

    <div class="recent-grid">

      <div class="recent-card">
        <h3><i class="fas fa-calendar-check"></i> Today's Appointments</h3>
        <div class="empty-state">
          <i class="fas fa-calendar-times"></i>
          <p>Visit Appointments page for details</p>
        </div>
      </div>

      <div class="recent-card">
        <h3><i class="fas fa-history"></i> Recent Activities</h3>
        <div id="activitiesList">
          <% if (!recentActivities || recentActivities.length === 0) { %>
            <div class="empty-state">
              <i class="fas fa-history"></i>
              <p>No recent activities</p>
            </div>
          <% } else { %>
            <% recentActivities.forEach(activity => { %>
              <div class="activity-item">
                <p>
                  <strong><%= activity.type %>:</strong>
                  <%= activity.message %>
                </p>
                <div class="activity-time">
                  <%= new Date(activity.date).toLocaleString('en-US', {
                    month: 'short', day: 'numeric',
                    hour: '2-digit', minute: '2-digit'
                  }) %>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>

    </div>

  </div>

  <%- include('../partials/logout-modal') %>
  <%- include('../partials/admin-scripts') %>

</body>
</html>