<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link rel="stylesheet" href="/css/admin/dashboard.css">
</head>
<body>

<%- include('../partials/admin-sidebar', { currentPage: 'dashboard' }) %>
<%- include('../partials/admin-topbar', { admin: admin, breadcrumb: null }) %>

<div class="main-content">

  <%
    const hour       = new Date().getHours();
    const greeting   = hour < 12 ? 'Good Morning' : hour < 17 ? 'Good Afternoon' : 'Good Evening';
    const todayLabel = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
  %>

  <!-- Page Header -->
  <div class="page-header fade-up">
    <div>
      <div class="page-date"><%= todayLabel %></div>
      <div class="page-greeting"><%= greeting %>, <span><%= admin.name.split(' ')[0] %></span> 👋</div>
      <div class="page-sub">System Administrator &middot; Healora Hospital Management</div>
    </div>
    <div class="header-pills">
      <div class="header-pill">
        <div class="header-pill-icon hpi-green"><i class="fas fa-user-plus"></i></div>
        <div>
          <div class="header-pill-lbl">New Patients</div>
          <div class="header-pill-val"><%= newPatientsThisMonth %> this month</div>
        </div>
      </div>
      <div class="header-pill">
        <div class="header-pill-icon hpi-purple"><i class="fas fa-user-md"></i></div>
        <div>
          <div class="header-pill-lbl">New Doctors</div>
          <div class="header-pill-val"><%= newDoctorsThisMonth %> this month</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="stats-row">
    <div class="stat-card c-blue fade-up d1">
      <div class="stat-top">
        <div class="stat-icon si-blue"><i class="fas fa-users"></i></div>
        <span class="stat-badge sb-blue">Total</span>
      </div>
      <div class="stat-val"><%= totalPatients %></div>
      <div class="stat-lbl">Total Patients</div>
    </div>
    <div class="stat-card c-purple fade-up d2">
      <div class="stat-top">
        <div class="stat-icon si-purple"><i class="fas fa-user-md"></i></div>
        <span class="stat-badge sb-purple">Active</span>
      </div>
      <div class="stat-val"><%= totalDoctors %></div>
      <div class="stat-lbl">Total Doctors</div>
    </div>
    <div class="stat-card c-amber fade-up d3">
      <div class="stat-top">
        <div class="stat-icon si-amber"><i class="fas fa-calendar-alt"></i></div>
        <span class="stat-badge sb-amber">All</span>
      </div>
      <div class="stat-val"><%= totalAppointments %></div>
      <div class="stat-lbl">All Appointments</div>
    </div>
    <div class="stat-card c-green fade-up d4">
      <div class="stat-top">
        <div class="stat-icon si-green"><i class="fas fa-calendar-day"></i></div>
        <span class="stat-badge sb-green">Today</span>
      </div>
      <div class="stat-val"><%= todayCount %></div>
      <div class="stat-lbl">Today's Appointments</div>
    </div>
    <div class="stat-card c-green fade-up d5">
      <div class="stat-top">
        <div class="stat-icon si-green"><i class="fas fa-indian-rupee-sign"></i></div>
        <span class="stat-badge sb-green">Revenue</span>
      </div>
      <div class="stat-val">₹<%= totalRevenue >= 100000 ? (totalRevenue/100000).toFixed(1)+'L' : totalRevenue >= 1000 ? (totalRevenue/1000).toFixed(1)+'k' : totalRevenue %></div>
      <div class="stat-lbl">Total Revenue</div>
    </div>
  </div>

  <!-- Main Grid: Chart + Activity Feed -->
  <div class="main-grid fade-up d2">

    <!-- Analytics Chart -->
    <div class="card">
      <div class="card-head">
        <div class="card-title"><i class="fas fa-chart-line"></i> Analytics</div>
        <div class="tab-row">
          <button class="tab-btn active" onclick="switchChart('appointments',this)">Appointments</button>
          <button class="tab-btn" onclick="switchChart('revenue',this)">Revenue</button>
          <button class="tab-btn" onclick="switchChart('monthly',this)">Monthly</button>
        </div>
      </div>
      <div class="card-body">
        <canvas id="dashChart" height="115"></canvas>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="card">
      <div class="card-head">
        <div class="card-title"><i class="fas fa-bolt"></i> Recent Activity</div>
        <span class="badge-count"><%= recentActivities.length %></span>
      </div>
      <div class="activity-list">
        <% if (recentActivities.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-bell-slash"></i>
            <p>No activity in last 24h</p>
          </div>
        <% } else { %>
          <% recentActivities.forEach(act => { %>
            <%
              const iconClass = act.type === 'Patient'
                ? 'ai-patient'
                : act.type === 'Doctor'
                  ? 'ai-doctor'
                  : 'ai-appointment';
              const timeAgo = (() => {
                const diff = Date.now() - new Date(act.date).getTime();
                const mins = Math.floor(diff / 60000);
                if (mins < 1)  return 'just now';
                if (mins < 60) return `${mins}m ago`;
                const hrs = Math.floor(mins / 60);
                if (hrs < 24)  return `${hrs}h ago`;
                return `${Math.floor(hrs/24)}d ago`;
              })();
            %>
            <div class="activity-item">
              <div class="activity-icon-wrap <%= iconClass %>">
                <i class="fas <%= act.icon %>"></i>
              </div>
              <div>
                <div class="activity-msg"><%= act.message %></div>
                <div class="activity-time"><%= timeAgo %></div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  </div>

  <!-- Bottom Grid -->
  <div class="bottom-grid fade-up d3">

    <!-- Admin Profile -->
    <div class="card">
      <div class="profile-hero">
        <div class="profile-avatar">
          <%= admin.name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0,2) %>
        </div>
        <div class="profile-info">
          <div class="profile-name"><%= admin.name %></div>
          <div class="profile-spec"><%= admin.email %></div>
        </div>
        <span class="admin-badge"><i class="fas fa-shield-halved"></i> Admin</span>
      </div>
      <div class="profile-rows">
        <div class="profile-row">
          <span class="pr-lbl">Role</span>
          <span class="pr-val">System Administrator</span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Status</span>
          <span class="pr-val">
            <span class="status-dot"><span class="dot"></span> Active</span>
          </span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Last Login</span>
          <span class="pr-val">
            <% if (admin.lastLogin) { %>
              <%= new Date(admin.lastLogin).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
            <% } else { %>
              —
            <% } %>
          </span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Phone</span>
          <span class="pr-val"><%= admin.phone || '—' %></span>
        </div>
      </div>
    </div>

    <!-- Appointment Breakdown Donut -->
    <div class="card">
      <div class="card-head">
        <div class="card-title"><i class="fas fa-chart-pie"></i> Appointment Summary</div>
      </div>
      <div class="card-body">
        <div class="donut-wrap">
          <canvas id="pieChart"></canvas>
          <div class="donut-center">
            <div class="donut-val"><%= stats.total %></div>
            <div class="donut-lbl">Total</div>
          </div>
        </div>
        <div class="legend-grid">
          <div class="legend-item"><span class="legend-dot" style="background:var(--green)"></span>Confirmed &nbsp;<b><%= stats.confirmed %></b></div>
          <div class="legend-item"><span class="legend-dot" style="background:var(--amber)"></span>Pending &nbsp;<b><%= stats.pending %></b></div>
          <div class="legend-item"><span class="legend-dot" style="background:var(--blue)"></span>Completed &nbsp;<b><%= stats.completed %></b></div>
          <div class="legend-item"><span class="legend-dot" style="background:var(--red)"></span>Cancelled &nbsp;<b><%= stats.cancelled %></b></div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="card">
      <div class="card-head">
        <div class="card-title"><i class="fas fa-grip"></i> Quick Actions</div>
      </div>
      <div class="qa-grid">
        <a href="/admin/patients"            class="qa-item"><i class="fas fa-users"></i><span class="qa-lbl">Patients</span></a>
        <a href="/admin/doctors-management"  class="qa-item"><i class="fas fa-user-md"></i><span class="qa-lbl">Doctors</span></a>
        <a href="/admin/appointments"        class="qa-item"><i class="fas fa-calendar-alt"></i><span class="qa-lbl">Appointments</span></a>
        <a href="/admin/departments"         class="qa-item"><i class="fas fa-building"></i><span class="qa-lbl">Departments</span></a>
        <a href="/admin/invoice"             class="qa-item"><i class="fas fa-file-invoice"></i><span class="qa-lbl">Invoices</span></a>
        <a href="/admin/settings"            class="qa-item"><i class="fas fa-cog"></i><span class="qa-lbl">Settings</span></a>
      </div>
    </div>

  </div>
</div>

<script>
  const WEEKLY  = JSON.parse(`<%- JSON.stringify(weeklyData) %>`);
  const MONTHLY = JSON.parse(`<%- JSON.stringify(monthlyEarnings) %>`);

  const BASE = {
    responsive: true,
    plugins: {
      legend: { display: false },
      tooltip: {
        backgroundColor: '#0B1120',
        titleFont: { family: 'Plus Jakarta Sans', weight: '700', size: 12 },
        bodyFont:  { family: 'Plus Jakarta Sans', size: 12 },
        padding: 10, cornerRadius: 8, displayColors: false
      }
    },
    scales: {
      x: {
        grid: { display: false },
        ticks: { font: { family: 'Plus Jakarta Sans', size: 11, weight: '600' }, color: '#6B7E99' },
        border: { display: false }
      },
      y: {
        grid: { color: '#E4EAF3' },
        ticks: { font: { family: 'Plus Jakarta Sans', size: 11, weight: '600' }, color: '#6B7E99' },
        border: { display: false },
        beginAtZero: true
      }
    }
  };

  let dashChart = null;

  function buildChart(type) {
    const ctx = document.getElementById('dashChart').getContext('2d');
    if (dashChart) dashChart.destroy();

    let labels, data, label, color, prefix = '';
    if (type === 'appointments') {
      labels = WEEKLY.map(d => d.label); data = WEEKLY.map(d => d.appointments);
      label = 'Appointments'; color = '#1459C8';
    } else if (type === 'revenue') {
      labels = WEEKLY.map(d => d.label); data = WEEKLY.map(d => d.revenue);
      label = 'Revenue'; color = '#0DBF7E'; prefix = '₹';
    } else {
      labels = MONTHLY.map(d => d.label); data = MONTHLY.map(d => d.earnings);
      label = 'Earnings'; color = '#7C5CFC'; prefix = '₹';
    }

    const grad = ctx.createLinearGradient(0, 0, 0, 200);
    grad.addColorStop(0, color + '28');
    grad.addColorStop(1, color + '00');

    dashChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label, data,
          backgroundColor: grad,
          borderColor: color,
          borderWidth: 2,
          borderRadius: 6,
          borderSkipped: false
        }]
      },
      options: {
        ...BASE,
        plugins: {
          ...BASE.plugins,
          tooltip: {
            ...BASE.plugins.tooltip,
            callbacks: { label: c => ` ${prefix}${c.parsed.y.toLocaleString('en-IN')}` }
          }
        }
      }
    });
  }

  function switchChart(type, btn) {
    document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    buildChart(type);
  }

  /* ── Donut chart ── */
  const pieData = [
    parseInt(`<%- stats.confirmed %>`),
    parseInt(`<%- stats.pending %>`),
    parseInt(`<%- stats.completed %>`),
    parseInt(`<%- stats.cancelled %>`)
  ];
  const hasData = pieData.some(v => v > 0);

  if (hasData) {
    new Chart(document.getElementById('pieChart').getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: ['Confirmed', 'Pending', 'Completed', 'Cancelled'],
        datasets: [{
          data: pieData,
          backgroundColor: ['#0DBF7E', '#F5A623', '#1459C8', '#E8354A'],
          borderWidth: 0, hoverOffset: 6
        }]
      },
      options: {
        responsive: true, cutout: '72%',
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#0B1120',
            titleFont: { family: 'Plus Jakarta Sans', weight: '700' },
            bodyFont:  { family: 'Plus Jakarta Sans' },
            padding: 10, cornerRadius: 8
          }
        }
      }
    });
  } else {
    document.getElementById('pieChart').style.display = 'none';
    document.getElementById('pieChart').insertAdjacentHTML('afterend',
      `<div style="text-align:center;padding:28px;color:#6B7E99;">
        <i class="fas fa-chart-pie" style="font-size:26px;color:#E4EAF3;display:block;margin-bottom:8px;"></i>
        <p style="font-size:12px;font-weight:600;margin:0;">No data yet</p>
      </div>`
    );
  }

  buildChart('appointments');
</script>

<%- include('../partials/logout-modal') %>
<%- include('../partials/admin-scripts') %>

</body>
</html>
