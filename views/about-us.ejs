<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/Logo-browser.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; }
    .page-hero { background: linear-gradient(135deg, #0D3D8F 0%, #1A6FD4 100%); padding: 60px 0; color: white; text-align: center; }
    .page-hero h1 { font-size: 38px; font-weight: 800; margin-bottom: 12px; }
    .page-hero p  { font-size: 15px; color: rgba(255,255,255,.75); max-width: 560px; margin: 0 auto; }
    .breadcrumb-hero { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,.6); margin-top: 14px; }
    .breadcrumb-hero a { color: rgba(255,255,255,.75); text-decoration: none; }

    /* About */
    .about-section { padding: 70px 0; }
    .about-img img { border-radius: 20px; box-shadow: 0 8px 30px rgba(20,89,200,.12); width: 100%; }
    .about-text h2 { font-size: 32px; font-weight: 800; color: #0B1120; margin-bottom: 16px; }
    .about-text h2 span { color: #1459C8; }
    .about-text p  { font-size: 14px; color: #64748b; line-height: 1.9; margin-bottom: 16px; }

    .about-badges { display: flex; flex-wrap: wrap; gap: 10px; margin: 24px 0; }
    .about-badge {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 8px 16px; border-radius: 20px;
      background: #E8F0FD; color: #1459C8;
      font-size: 13px; font-weight: 700;
    }

    .mission-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
      padding: 40px 0;
    }
    .mission-card {
      background: white; border-radius: 16px;
      border: 1.5px solid #e4eaf3;
      padding: 24px; text-align: center;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
      transition: transform .2s;
    }
    .mission-card:hover { transform: translateY(-3px); }
    .mission-icon {
      width: 52px; height: 52px; border-radius: 14px;
      background: #E8F0FD; color: #1459C8;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; margin: 0 auto 14px;
    }
    .mission-card h5 { font-size: 15px; font-weight: 800; color: #0B1120; margin-bottom: 8px; }
    .mission-card p  { font-size: 13px; color: #64748b; line-height: 1.7; margin: 0; }

    .team-section { padding: 50px 0; background: white; }
    .section-head { text-align: center; margin-bottom: 40px; }
    .section-head h2 { font-size: 30px; font-weight: 800; color: #0B1120; margin-bottom: 8px; }
    .section-head p  { font-size: 14px; color: #64748b; max-width: 500px; margin: 0 auto; }
    .section-tag { font-size: 12px; font-weight: 700; color: #1459C8; text-transform: uppercase; letter-spacing: .8px; display: block; margin-bottom: 8px; }

    @media (max-width: 768px) {
      .mission-grid { grid-template-columns: 1fr; }
      .page-hero h1 { font-size: 28px; }
    }
  </style>
</head>
<body>
<%- include('partials/navbar') %>

<div class="page-hero">
  <h1>About Healora</h1>
  <p>Where compassion meets digital precision — building the future of healthcare</p>
  <div class="breadcrumb-hero">
    <a href="/">Home</a>
    <i class="fas fa-chevron-right" style="font-size:10px;"></i>
    <span>About Us</span>
  </div>
</div>

<!-- About Section -->
<div class="about-section">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6 about-img">
        <img src="/images/about_us.jpg" alt="About Healora">
      </div>
      <div class="col-lg-6 about-text">
        <h2>Healing with <span>Innovation</span></h2>
        <p>At Healora Hospital, we're dedicated to providing world-class healthcare with compassion and innovation. Our team of expert doctors, nurses, and staff ensures the best treatment for every patient with advanced facilities and personalized care.</p>
        <p>We believe that great healthcare is not just about treating illness — it's about building lasting relationships with our patients and their families, and guiding them through every step of their health journey.</p>
        <div class="about-badges">
          <span class="about-badge"><i class="fas fa-shield-halved"></i> ISO Certified</span>
          <span class="about-badge"><i class="fas fa-award"></i> Award Winning</span>
          <span class="about-badge"><i class="fas fa-clock"></i> 24/7 Emergency</span>
          <span class="about-badge"><i class="fas fa-users"></i> Expert Team</span>
        </div>
        <a href="/doctors" class="btn btn-primary px-4 py-2 rounded-pill" style="font-weight:700;">Meet Our Doctors</a>
      </div>
    </div>
  </div>
</div>

<!-- Mission/Vision/Values -->
<div style="background: #f8fafc; padding: 20px 0 60px;">
  <div class="container">
    <div class="section-head">
      <span class="section-tag">Our Foundation</span>
      <h2>Mission, Vision & Values</h2>
      <p>The principles that guide everything we do at Healora</p>
    </div>
    <div class="mission-grid">
      <div class="mission-card">
        <div class="mission-icon"><i class="fas fa-bullseye"></i></div>
        <h5>Our Mission</h5>
        <p>To deliver compassionate, high-quality healthcare with innovative technology that makes medical care accessible and efficient for every patient.</p>
      </div>
      <div class="mission-card">
        <div class="mission-icon" style="background:rgba(13,191,126,.1);color:#0a9962;"><i class="fas fa-eye"></i></div>
        <h5>Our Vision</h5>
        <p>To be the most trusted healthcare system in the region — where every patient feels seen, heard, and cared for with dignity and respect.</p>
      </div>
      <div class="mission-card">
        <div class="mission-icon" style="background:rgba(124,92,252,.1);color:#6d28d9;"><i class="fas fa-heart"></i></div>
        <h5>Our Values</h5>
        <p>Integrity, compassion, excellence, and innovation. We hold ourselves to the highest standards in every patient interaction and clinical outcome.</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
