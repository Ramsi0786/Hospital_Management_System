<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:#f1f5f9; min-height:100vh; font-family:'Plus Jakarta Sans',sans-serif; }
  .main-content { margin-left:230px; padding:30px; min-height:100vh; }
  .wrap { max-width:560px; margin:0 auto; padding-bottom:40px; }
  .hero { text-align:center; padding:28px 0 20px; }
  .icon-circle { width:72px; height:72px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; margin-bottom:16px; }
  .icon-circle svg { width:32px; height:32px; }
  .ic-success { background:#ecfdf5; }
  .ic-pending  { background:#fffbeb; }
  .ic-cancelled{ background:#fff1f2; }
  .hero-title { font-size:22px; font-weight:700; color:#1a202c; margin:0 0 6px; }
  .hero-sub   { font-size:14px; color:#64748b; margin:0; }
  .card { background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:20px; margin-bottom:12px; }
  .row-between { display:flex; justify-content:space-between; align-items:center; }
  .booking-id { font-size:12px; color:#94a3b8; }
  .booking-id code { color:#374151; font-size:12px; }
  .badge { font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:.4px; }
  .badge-confirmed { background:#ecfdf5; color:#059669; }
  .badge-pending   { background:#fffbeb; color:#d97706; }
  .badge-cancelled { background:#fff1f2; color:#e11d48; }
  .divider { border:none; border-top:1px solid #f0f2f5; margin:16px 0; }
  .doc-row { display:flex; align-items:center; gap:12px; }
  .doc-avatar { width:48px; height:48px; border-radius:50%; background:#eff6ff; display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:700; color:#2563eb; flex-shrink:0; }
  .doc-name { font-size:15px; font-weight:700; color:#1a202c; margin:0 0 2px; }
  .doc-spec { font-size:12px; color:#64748b; margin:0; }
  .details-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .detail-box { background:#f8fafc; border-radius:10px; padding:12px; }
  .detail-label { font-size:11px; color:#94a3b8; margin:0 0 4px; text-transform:uppercase; letter-spacing:.4px; }
  .detail-value { font-size:14px; font-weight:700; color:#1a202c; margin:0; }
  .pay-row { display:flex; align-items:center; justify-content:space-between; padding:12px 14px; background:#f8fafc; border-radius:10px; }
  .pay-method { display:flex; align-items:center; gap:8px; font-size:14px; font-weight:600; color:#374151; }
  .pay-method svg { width:16px; height:16px; color:#64748b; }
  .cash-note { border:1px solid #fde68a; border-radius:10px; padding:12px 14px; font-size:13px; color:#92400e; display:flex; gap:10px; line-height:1.6; margin-top:10px; }
  .refund-box { border:1px solid #fecdd3; border-radius:10px; padding:12px 14px; font-size:13px; color:#e11d48; margin-top:10px; }
  .refund-box p { margin:0 0 4px; font-weight:600; }
  .refund-box span { font-size:12px; color:#64748b; }
  .email-card { display:flex; align-items:center; gap:12px; background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:12px 14px; margin-bottom:12px; }
  .email-card svg { width:16px; height:16px; color:#2563eb; flex-shrink:0; }
  .email-title { font-size:13px; font-weight:700; color:#1e40af; margin:0 0 2px; }
  .email-sub   { font-size:12px; color:#3b82f6; margin:0; }
  .btn-row { display:flex; gap:10px; }
  .btn { flex:1; padding:12px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; text-align:center; text-decoration:none; display:flex; align-items:center; justify-content:center; gap:6px; transition:all .2s; }
  .btn-primary { background:#1a202c; color:#fff; border:none; }
  .btn-primary:hover { background:#2d3748; color:#fff; }
  .btn-outline { background:#fff; color:#1a202c; border:1.5px solid #e2e8f0; }
  .btn-outline:hover { background:#f8fafc; color:#1a202c; }
  @media(max-width:768px){
    .main-content { margin-left:70px; padding:20px; }
    .details-grid { grid-template-columns:1fr; }
    .btn-row { flex-direction:column; }
  }
</style>
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'appointments' }) %>

<div class="main-content">
  <%- include('../partials/patient-topbar', {
    backUrl:      '/patient/appointments',
    backLabel:    'Appointments'
  }) %>

  <div class="wrap">

    <!-- Hero -->
    <div class="hero">
      <% if (appointment.status === 'cancelled') { %>
        <div class="icon-circle ic-cancelled">
          <svg viewBox="0 0 24 24" fill="none" stroke="#e11d48" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </div>
        <p class="hero-title">Appointment cancelled</p>
        <p class="hero-sub">This appointment has been cancelled.</p>
      <% } else if (appointment.paymentMethod === 'cash') { %>
        <div class="icon-circle ic-pending">
          <svg viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <p class="hero-title">Appointment booked</p>
        <p class="hero-sub">Pending confirmation. Please pay at the clinic.</p>
      <% } else { %>
        <div class="icon-circle ic-success">
          <svg viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <p class="hero-title">Booking confirmed</p>
        <p class="hero-sub">Payment received. You're all set.</p>
      <% } %>
    </div>

    <!-- Card -->
    <div class="card">

      <div class="row-between">
        <p class="booking-id">Booking ID: <code>#<%= appointment._id.toString().slice(-8).toUpperCase() %></code></p>
        <span class="badge badge-<%= appointment.status === 'cancelled' ? 'cancelled' : appointment.paymentMethod === 'cash' ? 'pending' : 'confirmed' %>">
          <%= appointment.status === 'cancelled' ? 'Cancelled' : appointment.paymentMethod === 'cash' ? 'Pending' : 'Confirmed' %>
        </span>
      </div>

      <hr class="divider">

      <!-- Doctor -->
      <div class="doc-row">
        <% if (appointment.doctor.profileImage) { %>
          <img src="<%= appointment.doctor.profileImage %>" style="width:48px;height:48px;border-radius:50%;object-fit:cover;" alt="">
        <% } else { %>
          <div class="doc-avatar">
            <%= appointment.doctor.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
          </div>
        <% } %>
        <div>
          <p class="doc-name">Dr. <%= appointment.doctor.name %></p>
          <p class="doc-spec"><%= appointment.doctor.specialization %> · <%= appointment.doctor.department %></p>
        </div>
      </div>

      <hr class="divider">

      <!-- Details -->
      <%
        const [th, tm] = appointment.timeSlot.split(':').map(Number);
        const ampm = th >= 12 ? 'PM' : 'AM';
        const fmt  = `${th % 12 || 12}:${String(tm).padStart(2,'0')} ${ampm}`;
      %>
      <div class="details-grid">
        <div class="detail-box">
          <p class="detail-label">Date</p>
          <p class="detail-value"><%= new Date(appointment.date + 'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'}) %></p>
        </div>
        <div class="detail-box">
          <p class="detail-label">Time</p>
          <p class="detail-value"><%= fmt %></p>
        </div>
        <div class="detail-box">
          <p class="detail-label">Department</p>
          <p class="detail-value"><%= appointment.department || appointment.doctor.department %></p>
        </div>
        <div class="detail-box">
          <p class="detail-label">Fee</p>
          <p class="detail-value">₹<%= appointment.consultationFee %></p>
        </div>
      </div>

      <hr class="divider">

      <!-- Payment -->
      <div class="pay-row">
        <div class="pay-method">
          <% if (appointment.paymentMethod === 'cash') { %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M22 10H2"/></svg>
            Pay at clinic
          <% } else if (appointment.paymentMethod === 'wallet') { %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/></svg>
            Healora wallet
          <% } else { %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Online payment
          <% } %>
        </div>
        <span class="badge <%=
          appointment.status === 'cancelled' ? 'badge-cancelled' :
          appointment.paymentStatus === 'paid' ? 'badge-confirmed' : 'badge-pending'
        %>"><%=
          appointment.status === 'cancelled' ? 'Cancelled' :
          appointment.paymentStatus === 'paid' ? 'Paid' :
          appointment.paymentMethod === 'cash' ? 'Pay at clinic' : 'Pending'
        %></span>
      </div>

      <!-- Cash note -->
      <% if (appointment.paymentMethod === 'cash' && appointment.status !== 'cancelled') { %>
        <div class="cash-note">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Please carry <strong style="margin:0 3px;">₹<%= appointment.consultationFee %></strong> in cash. Payment is due at the time of your visit.
        </div>
      <% } %>

      <!-- Refund info for cancelled -->
      <% if (appointment.status === 'cancelled' && appointment.refundAmount > 0) { %>
        <div class="refund-box">
          <p>Refund: ₹<%= appointment.refundAmount %> (<%= appointment.refundPercentage %>%) credited to your wallet</p>
          <span>Status: <%=
            appointment.refundStatus === 'processed' ? 'Processed — available in your wallet' :
            appointment.refundStatus === 'pending'   ? 'Processing — will be credited shortly' :
            appointment.refundStatus
          %></span>
        </div>
      <% } %>

    </div>

    <!-- Email notice (only for non-cancelled) -->
    <% if (appointment.status !== 'cancelled') { %>
      <div class="email-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <div>
          <p class="email-title">
            <%= appointment.paymentMethod === 'cash' ? 'Booking details sent to your email' : 'Invoice sent to your email' %>
          </p>
          <p class="email-sub">Check your inbox for the full summary.</p>
        </div>
      </div>
    <% } %>

    <!-- Buttons -->
    <div class="btn-row">
      <a href="/patient/appointments" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        My appointments
      </a>
      <a href="/patient/doctors" class="btn btn-outline">Find more doctors</a>
    </div>

  </div>
</div>