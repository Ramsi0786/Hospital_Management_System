<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:#f1f5f9; min-height:100vh; }
    .main-content { margin-left:230px; padding:30px; min-height:100vh; }

    /* Layout */
    .profile-layout { display:grid; grid-template-columns:280px 1fr; gap:24px; align-items:start; }

    /* ── Left: Identity card ── */
    .identity-card {
      background:white; border-radius:20px;
      box-shadow:0 4px 20px rgba(0,0,0,.07);
      overflow:hidden; position:sticky; top:24px;
    }
    .identity-banner {
      height:80px;
      background:linear-gradient(135deg,#203f6a 0%,#1a7f8e 100%);
    }
    .identity-body { padding:0 24px 24px; text-align:center; }
    .identity-avatar-wrap {
      margin-top:-44px; margin-bottom:14px;
      position:relative; display:inline-block;
    }
    .identity-avatar {
      width:88px; height:88px; border-radius:50%;
      border:4px solid white;
      background:linear-gradient(135deg,#667eea,#764ba2);
      color:white; font-size:32px; font-weight:800;
      display:flex; align-items:center; justify-content:center;
      overflow:hidden;
      box-shadow:0 4px 16px rgba(0,0,0,.15);
    }
    .identity-avatar img { width:100%; height:100%; object-fit:cover; }
    .avatar-upload-btn {
      position:absolute; bottom:2px; right:2px;
      width:28px; height:28px; border-radius:50%;
      background:#203f6a; color:white; border:2px solid white;
      display:flex; align-items:center; justify-content:center;
      font-size:11px; cursor:pointer; transition:all .2s;
    }
    .avatar-upload-btn:hover { background:#1a3456; transform:scale(1.1); }

    .identity-name { font-size:18px; font-weight:800; color:#1a202c; margin-bottom:4px; }
    .identity-email { font-size:13px; color:#94a3b8; margin-bottom:16px; word-break:break-all; }

    .identity-stats {
      display:grid; grid-template-columns:1fr 1fr;
      gap:10px; margin-bottom:20px;
    }
    .istat {
      background:#f8fafc; border-radius:12px;
      padding:12px 10px; text-align:center;
    }
    .istat-val { font-size:15px; font-weight:800; color:#1a202c; }
    .istat-label { font-size:11px; color:#94a3b8; font-weight:500; margin-top:2px; }

    .identity-badges { display:flex; flex-direction:column; gap:8px; }
    .ibadge {
      display:flex; align-items:center; gap:10px;
      padding:10px 14px; border-radius:10px;
      background:#f8fafc; font-size:13px; font-weight:600; color:#374151;
    }
    .ibadge i { width:16px; text-align:center; color:#203f6a; }
    .ibadge.verified i { color:#059669; }
    .ibadge.google i { color:#e53e3e; }

    .btn-remove-photo {
      width:100%; margin-top:14px; padding:9px;
      background:white; color:#dc2626;
      border:1.5px solid #fecaca; border-radius:10px;
      font-size:13px; font-weight:700; font-family:inherit;
      cursor:pointer; transition:all .2s;
      display:flex; align-items:center; justify-content:center; gap:6px;
    }
    .btn-remove-photo:hover { background:#fef2f2; border-color:#dc2626; }

    /* ── Right: Form sections ── */
    .form-section {
      background:white; border-radius:16px; padding:28px;
      box-shadow:0 2px 12px rgba(0,0,0,.06); margin-bottom:20px;
    }
    .section-header {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:24px; padding-bottom:16px;
      border-bottom:1.5px solid #f0f2f5;
    }
    .section-title {
      font-size:15px; font-weight:800; color:#1a202c;
      display:flex; align-items:center; gap:10px;
    }
    .section-title i { color:#203f6a; }
    .section-subtitle { font-size:12px; color:#94a3b8; font-weight:500; margin-top:2px; }

    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .form-grid.full { grid-template-columns:1fr; }
    .form-grid.three { grid-template-columns:1fr 1fr 1fr; }

    .fgroup { display:flex; flex-direction:column; gap:6px; }
    .fgroup.span2 { grid-column:span 2; }
    .flabel {
      font-size:12px; font-weight:700; color:#374151;
      text-transform:uppercase; letter-spacing:.4px;
    }
    .finput, .fselect, .ftextarea {
      width:100%; padding:11px 14px;
      border:1.5px solid #e2e8f0; border-radius:10px;
      font-size:14px; font-family:inherit; color:#374151;
      outline:none; transition:border-color .2s; background:white;
    }
    .finput:focus, .fselect:focus, .ftextarea:focus { border-color:#203f6a; }
    .finput:disabled, .fselect:disabled {
      background:#f8fafc; color:#94a3b8; cursor:not-allowed;
    }
    .ftextarea { resize:vertical; min-height:90px; }
    .finput.has-error, .fselect.has-error { border-color:#dc2626; }
    .ferror { font-size:12px; color:#dc2626; font-weight:600; display:none; }
    .ferror.show { display:block; }

    /* Save button */
    .section-footer { display:flex; align-items:center; justify-content:flex-end; gap:12px; margin-top:24px; padding-top:20px; border-top:1.5px solid #f0f2f5; }
    .btn-save {
      padding:11px 28px; background:#203f6a; color:white;
      border:none; border-radius:10px; font-size:14px; font-weight:700;
      font-family:inherit; cursor:pointer; transition:all .2s;
      display:inline-flex; align-items:center; gap:8px;
    }
    .btn-save:hover { background:#1a3456; transform:translateY(-1px); }
    .btn-save:disabled { background:#94a3b8; cursor:not-allowed; transform:none; }
    .save-status {
      font-size:13px; font-weight:600;
      display:none; align-items:center; gap:6px;
    }
    .save-status.success { color:#059669; display:flex; }
    .save-status.error   { color:#dc2626; display:flex; }

    /* Crop modal */
    .crop-modal {
      display:none; position:fixed; inset:0;
      background:rgba(0,0,0,.75); z-index:9999;
      align-items:center; justify-content:center; padding:20px;
    }
    .crop-modal.show { display:flex; }
    .crop-box {
      background:white; border-radius:16px; padding:24px;
      width:100%; max-width:560px; max-height:90vh; overflow:auto;
    }
    .crop-header {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:16px;
    }
    .crop-header h3 { font-size:16px; font-weight:800; color:#1a202c; }
    .crop-close {
      background:none; border:none; font-size:20px;
      color:#94a3b8; cursor:pointer;
    }
    #imagePreview { max-width:100%; max-height:400px; display:none; }
    .crop-actions {
      display:flex; gap:8px; margin-top:16px; flex-wrap:wrap;
    }
    .btn-crop {
      padding:8px 14px; border:none; border-radius:8px;
      font-size:13px; font-weight:700; font-family:inherit;
      cursor:pointer; transition:all .2s;
      display:inline-flex; align-items:center; gap:6px;
    }
    .btn-crop.rotate  { background:#f1f5f9; color:#374151; }
    .btn-crop.rotate:hover  { background:#e2e8f0; }
    .btn-crop.confirm { background:#059669; color:white; margin-left:auto; }
    .btn-crop.confirm:hover { background:#047857; }
    .btn-crop.cancel  { background:#f1f5f9; color:#64748b; }

    @media (max-width:1024px) { .profile-layout { grid-template-columns:1fr; } .identity-card { position:static; } }
    @media (max-width:768px)  { .main-content { margin-left:70px; padding:20px; } .form-grid { grid-template-columns:1fr; } .fgroup.span2 { grid-column:span 1; } }
    @media (max-width:600px)  { .form-grid.three { grid-template-columns:1fr 1fr; } }
  </style>
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'profile', user: patient }) %>
<%- include('../partials/loading') %>

<input type="file" id="imageInput" accept="image/*" style="display:none">

<!-- Crop Modal -->
<div class="crop-modal" id="cropModal">
  <div class="crop-box">
    <div class="crop-header">
      <h3><i class="fas fa-crop-alt" style="color:#203f6a;margin-right:8px;"></i> Crop Your Photo</h3>
      <button class="crop-close" onclick="closeCropModal()"><i class="fas fa-times"></i></button>
    </div>
    <img id="imagePreview" alt="Preview">
    <div class="crop-actions">
      <button class="btn-crop rotate" onclick="cropper.rotate(-90)"><i class="fas fa-undo"></i> Left</button>
      <button class="btn-crop rotate" onclick="cropper.rotate(90)"><i class="fas fa-redo"></i> Right</button>
      <button class="btn-crop rotate" onclick="cropper.zoom(0.1)"><i class="fas fa-search-plus"></i></button>
      <button class="btn-crop rotate" onclick="cropper.zoom(-0.1)"><i class="fas fa-search-minus"></i></button>
      <button class="btn-crop cancel" onclick="closeCropModal()">Cancel</button>
      <button class="btn-crop confirm" onclick="uploadCroppedImage()">
        <i class="fas fa-check"></i> Crop & Upload
      </button>
    </div>
  </div>
</div>

<div class="main-content">

  <%- include('../partials/patient-topbar', {
    pageTitle:    'My Profile',
    pageSubtitle: 'Manage your personal information',
    backUrl:      null,
    backLabel:    null
  }) %>

  <div class="profile-layout">

    <!-- ── LEFT: Identity card ───────────────────────── -->
    <div class="identity-card">
      <div class="identity-banner"></div>
      <div class="identity-body">

        <div class="identity-avatar-wrap">
          <div class="identity-avatar" id="avatarDisplay">
            <% if (patient.profileImage) { %>
              <img src="<%= patient.profileImage %>" alt="<%= patient.name %>">
            <% } else { %>
              <%= patient.name.charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <label for="imageInput" class="avatar-upload-btn" title="Change photo">
            <i class="fas fa-camera"></i>
          </label>
        </div>

        <div class="identity-name"><%= patient.name %></div>
        <div class="identity-email"><%= patient.email %></div>

        <div class="identity-stats">
          <div class="istat">
            <div class="istat-val">
              <%= patient.age || '—' %>
            </div>
            <div class="istat-label">Age</div>
          </div>
          <div class="istat">
            <div class="istat-val">
              <%= patient.bloodGroup || '—' %>
            </div>
            <div class="istat-label">Blood Group</div>
          </div>
          <div class="istat">
            <div class="istat-val">
              <%= patient.gender ? patient.gender.charAt(0) : '—' %>
            </div>
            <div class="istat-label">Gender</div>
          </div>
          <div class="istat">
            <div class="istat-val">
              <%= new Date(patient.createdAt).toLocaleDateString('en-US',{month:'short',year:'numeric'}) %>
            </div>
            <div class="istat-label">Joined</div>
          </div>
        </div>

        <div class="identity-badges">
          <% if (patient.isVerified) { %>
            <div class="ibadge verified">
              <i class="fas fa-check-circle"></i> Email Verified
            </div>
          <% } %>
          <% if (patient.googleId) { %>
            <div class="ibadge google">
              <i class="fab fa-google"></i> Google Account
            </div>
          <% } else { %>
            <div class="ibadge">
              <i class="fas fa-envelope"></i> Email & Password
            </div>
          <% } %>
          <% if (patient.phone) { %>
            <div class="ibadge">
              <i class="fas fa-phone"></i> <%= patient.phone %>
            </div>
          <% } %>
        </div>

        <% if (patient.profileImage) { %>
          <button class="btn-remove-photo" onclick="removePhoto()">
            <i class="fas fa-trash"></i> Remove Photo
          </button>
        <% } %>

      </div>
    </div>

    <!-- ── RIGHT: Form sections ──────────────────────── -->
    <div>

      <!-- Personal Info -->
      <div class="form-section">
        <div class="section-header">
          <div>
            <div class="section-title"><i class="fas fa-user"></i> Personal Information</div>
            <div class="section-subtitle">Your basic personal details</div>
          </div>
        </div>

        <div class="form-grid">
          <div class="fgroup">
            <label class="flabel">Full Name *</label>
            <input type="text" id="f-name" class="finput"
              value="<%= patient.name %>" maxlength="100">
            <span class="ferror" id="err-name"></span>
          </div>
          <div class="fgroup">
            <label class="flabel">Email Address</label>
            <input type="email" id="f-email" class="finput"
              value="<%= patient.email %>" disabled>
          </div>
          <div class="fgroup">
            <label class="flabel">Phone Number</label>
            <input type="tel" id="f-phone" class="finput"
              value="<%= patient.phone || '' %>"
              placeholder="10-digit number" maxlength="10">
            <span class="ferror" id="err-phone"></span>
          </div>
          <div class="fgroup">
            <label class="flabel">Date of Birth</label>
            <input type="date" id="f-dob" class="finput"
              value="<%= patient.dateOfBirth ? new Date(patient.dateOfBirth).toISOString().split('T')[0] : '' %>"
              max="<%= new Date().toISOString().split('T')[0] %>">
            <span class="ferror" id="err-dob"></span>
          </div>
          <div class="fgroup">
            <label class="flabel">Gender</label>
            <select id="f-gender" class="fselect">
              <option value="">Select Gender</option>
              <option value="Male"   <%= patient.gender === 'Male'   ? 'selected' : '' %>>Male</option>
              <option value="Female" <%= patient.gender === 'Female' ? 'selected' : '' %>>Female</option>
              <option value="Other"  <%= patient.gender === 'Other'  ? 'selected' : '' %>>Other</option>
            </select>
          </div>
          <div class="fgroup">
            <label class="flabel">Blood Group</label>
            <select id="f-bloodGroup" class="fselect">
              <option value="">Select Blood Group</option>
              <% ['A+','A-','B+','B-','O+','O-','AB+','AB-'].forEach(bg => { %>
                <option value="<%= bg %>" <%= patient.bloodGroup === bg ? 'selected' : '' %>><%= bg %></option>
              <% }) %>
            </select>
          </div>
          <div class="fgroup span2">
            <label class="flabel">Address</label>
            <textarea id="f-address" class="ftextarea"
              placeholder="Your complete address"><%= patient.address || '' %></textarea>
          </div>
        </div>

        <div class="section-footer">
          <div class="save-status" id="personal-status"></div>
          <button class="btn-save" id="save-personal" onclick="savePersonalInfo()">
            <i class="fas fa-save"></i> Save Changes
          </button>
        </div>
      </div>

      <!-- Emergency Contact -->
      <div class="form-section">
        <div class="section-header">
          <div>
            <div class="section-title"><i class="fas fa-phone-alt"></i> Emergency Contact</div>
            <div class="section-subtitle">Person to contact in case of emergency</div>
          </div>
        </div>

        <div class="form-grid">
          <div class="fgroup">
            <label class="flabel">Contact Name</label>
            <input type="text" id="f-ecName" class="finput"
              value="<%= patient.emergencyContactName || '' %>"
              placeholder="Full name of contact person">
            <span class="ferror" id="err-ecName"></span>
          </div>
          <div class="fgroup">
            <label class="flabel">Contact Phone</label>
            <input type="tel" id="f-ecPhone" class="finput"
              value="<%= patient.emergencyContactPhone || '' %>"
              placeholder="10-digit number" maxlength="10">
            <span class="ferror" id="err-ecPhone"></span>
          </div>
        </div>

        <div class="fgroup">
  <label class="flabel">Relation</label>
  <select id="f-ecRelation" class="fselect">
    <option value="">Select Relation</option>
    <% ['Spouse','Parent','Sibling','Child','Friend','Guardian','Other'].forEach(r => { %>
      <option value="<%= r %>"
        <%= patient.emergencyContactRelation === r ? 'selected' : '' %>>
        <%= r %>
      </option>
    <% }) %>
  </select>
</div>

        <div class="section-footer">
          <div class="save-status" id="emergency-status"></div>
          <button class="btn-save" id="save-emergency" onclick="saveEmergencyContact()">
            <i class="fas fa-save"></i> Save Contact
          </button>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script src="/js/alerts.js"></script>
<script src="/js/loader.js"></script>
<script src="/js/image-cropper.js"></script>
<script src="/js/formValidation.js"></script>

<script>
  /* ── Image cropper setup ──────────────────────── */
  const cropper = new ImageCropper({
    inputId:   'imageInput',
    previewId: 'imagePreview',
    aspectRatio: 1,
    minWidth:  200,
    minHeight: 200
  });

  document.getElementById('imageInput').addEventListener('change', () => {
    setTimeout(() => document.getElementById('cropModal').classList.add('show'), 100);
  });

  function closeCropModal() {
    document.getElementById('cropModal').classList.remove('show');
    cropper.reset();
  }

  async function uploadCroppedImage() {
    cropper.getCroppedImage(async (base64) => {
      Loader.show('Uploading photo...');
      closeCropModal();
      try {
        const res  = await fetch('/patient/upload-profile-image', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ croppedImage: base64 })
        });
        const data = await res.json();
        Loader.hide();
        if (data.success) {
          // Update avatar in identity card
          document.getElementById('avatarDisplay').innerHTML =
            `<img src="${data.imageUrl}" alt="Profile">`;
          Alert.success('Profile photo updated!');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          Alert.error(data.error || 'Upload failed');
        }
      } catch {
        Loader.hide();
        Alert.error('Network error. Please try again.');
      }
    });
  }

  async function removePhoto() {
    const result = await Swal.fire({
      title:             'Remove photo?',
      text:              'Your profile photo will be deleted.',
      icon:              'warning',
      showCancelButton:  true,
      confirmButtonColor:'#dc2626',
      cancelButtonColor: '#64748b',
      confirmButtonText: 'Yes, remove it'
    });
    if (!result.isConfirmed) return;

    Loader.show('Removing...');
    try {
      const res  = await fetch('/patient/delete-profile-image', { method: 'DELETE' });
      const data = await res.json();
      Loader.hide();
      if (data.success) {
        Alert.success('Photo removed.');
        setTimeout(() => window.location.reload(), 1200);
      } else {
        Alert.error(data.error || 'Failed to remove photo');
      }
    } catch {
      Loader.hide();
      Alert.error('Network error.');
    }
  }

  /* ── Field helpers ────────────────────────────── */
  function setError(fieldId, errId, msg) {
    const f = document.getElementById(fieldId);
    const e = document.getElementById(errId);
    if (f) f.classList.add('has-error');
    if (e) { e.textContent = msg; e.classList.add('show'); }
  }

  function clearErrors(fields) {
    fields.forEach(({ f, e }) => {
      const fi = document.getElementById(f);
      const ei = document.getElementById(e);
      if (fi) fi.classList.remove('has-error');
      if (ei) { ei.textContent = ''; ei.classList.remove('show'); }
    });
  }

  function showStatus(id, type, msg) {
    const el = document.getElementById(id);
    el.className = `save-status ${type}`;
    el.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${msg}`;
    if (type === 'success') setTimeout(() => { el.className = 'save-status'; el.innerHTML = ''; }, 3500);
  }

  /* ── Save personal info ───────────────────────── */
  async function savePersonalInfo() {
    clearErrors([
      { f:'f-name',  e:'err-name'  },
      { f:'f-phone', e:'err-phone' },
      { f:'f-dob',   e:'err-dob'   }
    ]);

    const name       = document.getElementById('f-name').value.trim();
    const phone      = document.getElementById('f-phone').value.trim();
    const dob        = document.getElementById('f-dob').value;
    const gender     = document.getElementById('f-gender').value;
    const bloodGroup = document.getElementById('f-bloodGroup').value;
    const address    = document.getElementById('f-address').value.trim();

    let hasError = false;

    const nameErr = FormValidator.validateName(name, 3);
    if (nameErr) { setError('f-name', 'err-name', nameErr); hasError = true; }

    if (phone) {
      const phoneErr = FormValidator.validatePhone(phone);
      if (phoneErr) { setError('f-phone', 'err-phone', phoneErr); hasError = true; }
    }

    if (dob) {
      const dobDate = new Date(dob);
      if (dobDate > new Date()) {
        setError('f-dob', 'err-dob', 'Date cannot be in the future'); hasError = true;
      }
    }

    if (hasError) return;

    const btn = document.getElementById('save-personal');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

    try {
      const res  = await fetch('/patient/update-profile', {
        method:  'PUT',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          name, phone: phone || null,
          dateOfBirth: dob || null,
          gender: gender || null,
          bloodGroup: bloodGroup || null,
          address: address || null
        })
      });
      const data = await res.json();
      if (data.success) {
        showStatus('personal-status', 'success', 'Changes saved successfully');
        // Update identity card name
        document.querySelector('.identity-name').textContent = name;
      } else {
        showStatus('personal-status', 'error', data.error || 'Failed to save');
      }
    } catch {
      showStatus('personal-status', 'error', 'Something went wrong');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i> Save Changes';
    }
  }

  /* ── Save emergency contact ───────────────────── */
  async function saveEmergencyContact() {
    clearErrors([
      { f:'f-ecName',  e:'err-ecName'  },
      { f:'f-ecPhone', e:'err-ecPhone' }
    ]);

    const ecName  = document.getElementById('f-ecName').value.trim();
    const ecPhone = document.getElementById('f-ecPhone').value.trim();
    const ecRelation = document.getElementById('f-ecRelation').value;

    let hasError = false;

    if (ecName && ecName.length < 3) {
      setError('f-ecName', 'err-ecName', 'Name must be at least 3 characters'); hasError = true;
    }
    if (ecPhone) {
      const phoneErr = FormValidator.validatePhone(ecPhone);
      if (phoneErr) { setError('f-ecPhone', 'err-ecPhone', phoneErr); hasError = true; }
    }
    if (ecName && !ecPhone) {
      setError('f-ecPhone', 'err-ecPhone', 'Phone required when name is provided'); hasError = true;
    }
    if (ecPhone && !ecName) {
      setError('f-ecName', 'err-ecName', 'Name required when phone is provided'); hasError = true;
    }

    if (hasError) return;

    const btn = document.getElementById('save-emergency');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

    try {
      const res  = await fetch('/patient/update-profile', {
        method:  'PUT',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          name:                 document.getElementById('f-name').value.trim(),
          emergencyContactName:  ecName  || null,
          emergencyContactPhone: ecPhone || null,
          emergencyContactRelation: ecRelation || null
        })
      });
      const data = await res.json();
      if (data.success) {
        showStatus('emergency-status', 'success', 'Emergency contact saved');
      } else {
        showStatus('emergency-status', 'error', data.error || 'Failed to save');
      }
    } catch {
      showStatus('emergency-status', 'error', 'Something went wrong');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i> Save Contact';
    }
  }
</script>
</body>
</html>