<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/patient/doctor-profile.css">
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'doctors' }) %>

<div class="main-content">
  <!-- Hero Header -->
  <div class="hero-header">
    <div class="hero-overlay">
      <div class="hero-content">

        <!-- Back button — smaller, top left -->
        <a href="/patient/doctors" class="back-btn">
          <i class="fas fa-arrow-left"></i> Back
        </a>

        <div class="hero-profile">

          <div class="hero-avatar-wrap">
            <div class="hero-avatar">
              <% if (doctor.profileImage) { %>
                <img src="<%= doctor.profileImage %>" alt="<%= doctor.name %>">
              <% } else { %>
                <div class="hero-initials">
                  <i class="fas fa-user-doctor"></i>
                </div>
              <% } %>
              <% if (doctor.isFeatured) { %>
                <span class="featured-badge"><i class="fas fa-star"></i></span>
              <% } %>
            </div>
            <!-- Share button under avatar -->
            <button class="btn-share" onclick="shareProfile()">
              <i class="fas fa-share-alt"></i> Share
            </button>
          </div>

          <div class="hero-info">
            <h1 class="hero-name">Dr. <%= doctor.name %></h1>
            <p class="hero-spec"><%= doctor.specialization %></p>
            <p class="hero-dept">
              <i class="fas fa-building"></i> <%= doctor.department %> Department
            </p>

            <div class="hero-stats">
              <div class="stat-item">
                <i class="fas fa-star"></i>
                <span><strong><%= doctor.rating || 4.5 %></strong> Rating</span>
              </div>
              <div class="stat-item">
                <i class="fas fa-briefcase-medical"></i>
                <span><strong><%= doctor.experience || 0 %>+</strong> Years</span>
              </div>
              <div class="stat-item">
                <i class="fas fa-users"></i>
                <span><strong>500+</strong> Patients</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="content-grid">

    <!-- Left Column: Info -->
    <div class="info-column">

      <div class="info-card">
        <h3 class="card-title"><i class="fas fa-user-md"></i> About</h3>
        <p class="bio-text">
          <%= doctor.bio || `Dr. ${doctor.name} is a highly qualified ${doctor.specialization} with ${doctor.experience || 0} years of experience. Dedicated to providing exceptional healthcare services with compassion and expertise.` %>
        </p>
      </div>

      <div class="info-card">
        <h3 class="card-title"><i class="fas fa-graduation-cap"></i> Education & Qualifications</h3>
        <div class="qual-item">
          <i class="fas fa-check-circle"></i>
          <span><%= doctor.qualification || 'MBBS, MD - ' + doctor.specialization %></span>
        </div>
      </div>

      <div class="info-card">
        <h3 class="card-title"><i class="fas fa-stethoscope"></i> Specializations</h3>
        <div class="tags">
          <span class="tag"><%= doctor.specialization %></span>
          <span class="tag"><%= doctor.department %></span>
          <% if (doctor.isFeatured) { %>
            <span class="tag tag-featured">Top Rated</span>
          <% } %>
        </div>
      </div>

      <div class="info-card">
        <h3 class="card-title"><i class="fas fa-hospital"></i> Hospital Information</h3>
        <div class="contact-item">
          <i class="fas fa-map-marker-alt"></i>
          <span>Healora Hospital, <%= doctor.department %> Wing</span>
        </div>
        <div class="contact-item">
          <i class="fas fa-phone"></i>
          <span>+91 1234567890</span>
        </div>
      </div>

    </div>

    <!-- Right Column: Booking -->
    <div class="booking-column">
      <div class="booking-card">
        <div class="booking-header">
          <h3 class="booking-title">
            <i class="fas fa-calendar-check"></i> Book Appointment
          </h3>
          <p class="booking-subtitle">Choose your preferred date and time</p>
        </div>

        <% if (slotCalendar.length === 0) { %>
          <div class="no-slots-state">
            <i class="fas fa-calendar-times"></i>
            <h4>No Available Slots</h4>
            <p>Please check back later or contact us directly</p>
          </div>
        <% } else { %>

          <div class="date-section">
            <label class="section-label">Select Date</label>
            <div class="date-carousel">
              <% slotCalendar.forEach((day, i) => { %>
                <button class="date-card <%= i === 0 ? 'active' : '' %> <%= day.slots.length === 0 ? 'disabled' : '' %>"
                  data-date="<%= day.date %>"
                  data-slots='<%- JSON.stringify(day.slots) %>'
                  data-reason="<%= day.noSlotsReason || '' %>"
                  onclick="selectDate(this)"
                  <%= day.slots.length === 0 ? 'disabled' : '' %>>
                  <span class="date-day"><%= day.dayName.substring(0, 3) %></span>
                  <span class="date-num"><%= day.dayNum %></span>
                  <span class="date-month"><%= day.month.substring(0, 3) %></span>
                  <% if (day.slots.length === 0) { %>
                    <span class="date-unavailable"></span>
                  <% } %>
                </button>
              <% }) %>
            </div>
          </div>

          <div class="time-section" id="timeSection">
            <label class="section-label">Select Time</label>
            <div class="time-grid" id="timeGrid">
              <% const firstDay = slotCalendar[0]; %>
              <% if (firstDay.slots.length > 0) { %>
                <% firstDay.slots.forEach(slot => { %>
                  <%
                  const [fh, fm] = slot.split(':').map(Number);
                  const fampm = fh >= 12 ? 'PM' : 'AM';
                  const fmtSlot = `${fh % 12 || 12}:${String(fm).padStart(2,'0')} ${fampm}`;
                  %>
                  <button class="time-slot" data-slot="<%= slot %>" onclick="selectSlot(this)">
                    <i class="fas fa-clock"></i> <%= fmtSlot %>
                  </button>
                  <% }) %>
              <% } %>
            </div>
            <div class="no-slots-message" id="noSlotsMessage" style="display: none;">
              <i class="fas fa-info-circle"></i>
              <span id="noSlotsText">No slots available for this date</span>
            </div>
          </div>

          <div class="selection-card" id="selectionCard" style="display: none;">
            <div class="selection-icon"><i class="fas fa-check-circle"></i></div>
            <div class="selection-details">
              <span class="selection-label">Your Appointment</span>
              <span class="selection-info" id="selectionInfo"></span>
            </div>
            <div class="selection-fee">₹<%= doctor.consultationFee || 500 %></div>
          </div>

          <!-- Fee row -->
          <div class="fee-row">
            <span class="fee-row-label">Consultation Fee</span>
            <span class="fee-row-amount">₹<%= doctor.consultationFee || 500 %></span>
          </div>

          <button class="btn-book" id="bookBtn" disabled onclick="proceedToBook()">
            <i class="fas fa-calendar-plus"></i> Confirm Booking
          </button>

        <% } %>
      </div>
    </div>

  </div>
  <!-- Booking Confirmation Modal -->
<div id="confirmModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:20px;padding:32px;max-width:460px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
    
    <!-- Header -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
      <div style="width:44px;height:44px;background:#eff6ff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
        <i class="fas fa-calendar-check" style="color:#203f6a;font-size:20px;"></i>
      </div>
      <div>
        <h3 style="margin:0;font-size:18px;font-weight:800;color:#1e293b;">Confirm Appointment</h3>
        <p style="margin:0;font-size:13px;color:#94a3b8;">Please review before confirming</p>
      </div>
      <button onclick="closeConfirmModal()" style="margin-left:auto;background:none;border:none;font-size:20px;color:#94a3b8;cursor:pointer;">×</button>
    </div>

    <!-- Appointment Summary -->
    <div style="background:#f8fafc;border-radius:12px;padding:16px;margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:13px;">
        <span style="color:#64748b;">Doctor</span>
        <span style="font-weight:700;color:#1e293b;" id="modal-doctor"></span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:13px;border-top:1px solid #e2e8f0;">
        <span style="color:#64748b;">Date</span>
        <span style="font-weight:700;color:#1e293b;" id="modal-date"></span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:13px;border-top:1px solid #e2e8f0;">
        <span style="color:#64748b;">Time</span>
        <span style="font-weight:700;color:#1e293b;" id="modal-time"></span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:13px;border-top:1px solid #e2e8f0;">
        <span style="color:#64748b;">Consultation Fee</span>
        <span style="font-weight:800;color:#203f6a;font-size:15px;" id="modal-fee"></span>
      </div>
    </div>

    <!-- Refund Policy -->
    <div style="background:#fefce8;border:1px solid #fde68a;border-radius:12px;padding:14px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
        <i class="fas fa-shield-alt" style="color:#d97706;"></i>
        <span style="font-size:13px;font-weight:700;color:#92400e;">Cancellation & Refund Policy</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
        <i class="fas fa-check-circle" style="color:#059669;font-size:12px;"></i>
        <span style="font-size:12px;color:#78350f;">Cancel <strong>12+ hours</strong> before appointment → <strong>90% refund</strong></span>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <i class="fas fa-times-circle" style="color:#dc2626;font-size:12px;"></i>
        <span style="font-size:12px;color:#78350f;">Cancel <strong>less than 12 hours</strong> before → <strong>No refund</strong></span>
      </div>
    </div>

    <!-- Action Buttons -->
    <div style="display:flex;gap:10px;">
      <button onclick="closeConfirmModal()" 
              style="flex:1;padding:13px;border:2px solid #e2e8f0;border-radius:10px;background:white;color:#64748b;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;">
        Go Back
      </button>
      <button onclick="confirmAndBook()" 
              style="flex:2;padding:13px;border:none;border-radius:10px;background:linear-gradient(135deg,#203f6a,#1a7f8e);color:white;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;">
        <i class="fas fa-calendar-plus"></i> Confirm & Proceed
      </button>
    </div>

  </div>
</div>
</div>

<script type="application/json" id="page-data">
  <%- JSON.stringify({
    doctorId: doctor._id,
    doctorName: doctor.name,
    fee: doctor.consultationFee || 500,
    department: doctor.department
  }) %>
</script>

<script>
  const PAGE = JSON.parse(document.getElementById('page-data').textContent);
  let selectedDate = null;
  let selectedSlot = null;

  // ── Time formatter ──────────────────────────────────────
  function formatSlot(slot) {
    const [h, m] = slot.split(':').map(Number);
    const ampm = h >= 12 ? 'PM' : 'AM';
    return `${h % 12 || 12}:${String(m).padStart(2, '0')} ${ampm}`;
  }

  function selectDate(btn) {
  if (btn.disabled) return;
  document.querySelectorAll('.date-card').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  selectedDate = btn.dataset.date;
  selectedSlot = null;
  updateSummary();
  fetchSlots(selectedDate);
}

async function fetchSlots(date) {
  const timeGrid = document.getElementById('timeGrid');
  const noSlotsMsg = document.getElementById('noSlotsMessage');
  timeGrid.style.display = 'grid';
  timeGrid.innerHTML = '<div style="padding:20px;color:#94a3b8;font-size:13px;">Loading slots...</div>';
  noSlotsMsg.style.display = 'none';
  try {
    const res = await fetch(`/patient/doctors/${PAGE.doctorId}/slots?date=${date}`);
    const data = await res.json();
    if (data.success && data.slots.length > 0) {
      renderTimeSlots(data.slots);
    } else {
      timeGrid.style.display = 'none';
      noSlotsMsg.style.display = 'flex';
      document.getElementById('noSlotsText').textContent = 'No available slots for this date';
    }
  } catch (err) {
    timeGrid.style.display = 'none';
    noSlotsMsg.style.display = 'flex';
    document.getElementById('noSlotsText').textContent = 'Failed to load slots';
  }
}

  function renderTimeSlots(slots) {
    const timeGrid = document.getElementById('timeGrid');
    const noSlotsMsg = document.getElementById('noSlotsMessage');
    if (slots.length === 0) {
      timeGrid.style.display = 'none';
      noSlotsMsg.style.display = 'flex';
      return;
    }
    noSlotsMsg.style.display = 'none';
    timeGrid.style.display = 'grid';
    timeGrid.innerHTML = slots.map(slot => `
  <button class="time-slot" data-slot="${slot}" onclick="selectSlot(this)">
    <i class="fas fa-clock"></i> ${formatSlot(slot)}
  </button>
`).join('');
  }

  function selectSlot(btn) {
    document.querySelectorAll('.time-slot').forEach(s => s.classList.remove('active'));
    btn.classList.add('active');
    selectedSlot = btn.dataset.slot;
    updateSummary();
  }

  function updateSummary() {
    const card = document.getElementById('selectionCard');
    const info = document.getElementById('selectionInfo');
    const bookBtn = document.getElementById('bookBtn');
    if (selectedDate && selectedSlot) {
      const dateStr = new Date(selectedDate + 'T00:00:00').toLocaleDateString('en-US', {
        weekday: 'long', month: 'long', day: 'numeric'
      });
      info.textContent = `${dateStr} at ${formatSlot(selectedSlot)}`;
      card.style.display = 'flex';
      bookBtn.disabled = false;
    } else {
      card.style.display = 'none';
      bookBtn.disabled = true;
    }
  }

  function proceedToBook() {
  if (!selectedDate || !selectedSlot) return;

  // Populate modal
  const dateLabel = new Date(selectedDate + 'T00:00:00').toLocaleDateString('en-US', {
    weekday: 'long', month: 'long', day: 'numeric'
  });
  document.getElementById('modal-doctor').textContent = 'Dr. ' + PAGE.doctorName;
  document.getElementById('modal-date').textContent   = dateLabel;
  document.getElementById('modal-time').textContent = formatSlot(selectedSlot);
  document.getElementById('modal-fee').textContent    = '₹' + PAGE.fee;

  // Show modal
  const modal = document.getElementById('confirmModal');
  modal.style.display = 'flex';
}

function closeConfirmModal() {
  document.getElementById('confirmModal').style.display = 'none';
}

function confirmAndBook() {
  const params = new URLSearchParams({
    doctor: PAGE.doctorId,
    date:   selectedDate,
    slot:   selectedSlot
  });
  window.location.href = `/patient/appointments/book?${params}`;
}

document.getElementById('confirmModal').addEventListener('click', function(e) {
  if (e.target === this) closeConfirmModal();
});

document.addEventListener('DOMContentLoaded', () => {
  const firstDateBtn = document.querySelector('.date-card:not(.disabled)');
  if (firstDateBtn) {
    fetchSlots(firstDateBtn.dataset.date);
  }
});
</script>

</body>
</html>
