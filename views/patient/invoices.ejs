<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:#f1f5f9; }

    .main-content { margin-left:230px; padding:30px; min-height:100vh; }

    .top-bar {
      display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;
    }
    .page-title { font-size:26px; font-weight:800; color:#1a202c; }

    .user-profile-btn {
      display:flex; align-items:center; gap:10px; background:white;
      padding:8px 16px; border-radius:50px; border:none;
      box-shadow:0 2px 8px rgba(0,0,0,.08); cursor:pointer;
    }
    .user-avatar-small {
      width:35px; height:35px; border-radius:50%; background:#203f6a;
      color:white; display:flex; align-items:center; justify-content:center;
      font-weight:700; font-size:14px;
    }

    /* Stats */
    .stats-row {
      display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;
    }
    .stat-card {
      background:white; border-radius:14px; padding:20px;
      border:1.5px solid #e2e8f0;
      display:flex; align-items:center; gap:16px;
    }
    .stat-icon {
      width:48px; height:48px; border-radius:12px;
      display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;
    }
    .stat-icon.total   { background:#eff6ff; color:#3b82f6; }
    .stat-icon.booking { background:#f0fdf4; color:#059669; }
    .stat-icon.refund  { background:#fef3c7; color:#d97706; }
    .stat-info strong  { font-size:22px; font-weight:800; color:#1a202c; display:block; }
    .stat-info span    { font-size:12px; color:#94a3b8; font-weight:600; }

    /* Filter tabs */
    .filter-tabs {
      display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap;
    }
    .filter-tab {
      padding:8px 18px; border-radius:20px; font-size:13px; font-weight:600;
      text-decoration:none; color:#64748b; background:white;
      border:1.5px solid #e2e8f0; transition:all .2s;
    }
    .filter-tab:hover { border-color:#203f6a; color:#203f6a; text-decoration:none; }
    .filter-tab.active { background:#203f6a; color:white; border-color:#203f6a; }

    /* Invoice table card */
    .invoice-card {
      background:white; border-radius:14px; border:1.5px solid #e2e8f0; overflow:hidden;
    }
    .invoice-card-header {
      padding:18px 24px; border-bottom:1.5px solid #f1f5f9;
      display:flex; align-items:center; justify-content:space-between;
    }
    .invoice-card-title {
      font-size:15px; font-weight:800; color:#1a202c;
      display:flex; align-items:center; gap:8px;
    }
    .invoice-count {
      font-size:12px; color:#94a3b8; font-weight:600;
      background:#f1f5f9; padding:3px 10px; border-radius:20px;
    }

    /* Invoice row */
    .invoice-row {
      display:grid;
      grid-template-columns: 160px 1fr 120px 100px 110px;
      align-items:center;
      padding:16px 24px;
      border-bottom:1px solid #f8fafc;
      gap:16px;
      transition:background .15s;
    }
    .invoice-row:last-child { border-bottom:none; }
    .invoice-row:hover { background:#fafbfc; }

    .invoice-row-header {
      display:grid;
      grid-template-columns: 160px 1fr 120px 100px 110px;
      padding:10px 24px;
      gap:16px;
      background:#f8fafc;
      border-bottom:1.5px solid #f1f5f9;
    }
    .col-header {
      font-size:11px; font-weight:700; color:#94a3b8;
      text-transform:uppercase; letter-spacing:0.5px;
    }

    .inv-number {
      font-size:13px; font-weight:700; color:#203f6a; font-family:monospace;
    }
    .inv-date { font-size:11px; color:#94a3b8; margin-top:2px; }

    .inv-doctor { font-size:13px; font-weight:700; color:#1a202c; }
    .inv-spec   { font-size:11px; color:#94a3b8; margin-top:2px; }

    .inv-amount { font-size:15px; font-weight:800; color:#1a202c; }

    .type-badge {
      display:inline-flex; align-items:center; gap:5px;
      padding:4px 10px; border-radius:20px; font-size:11px; font-weight:700;
    }
    .type-badge.booking { background:#f0fdf4; color:#059669; }
    .type-badge.refund  { background:#fef3c7; color:#d97706; }

    .btn-download {
      display:inline-flex; align-items:center; gap:6px;
      padding:7px 14px; border-radius:8px; font-size:12px; font-weight:700;
      background:#f1f5f9; color:#374151; text-decoration:none;
      border:1.5px solid #e2e8f0; transition:all .15s; white-space:nowrap;
    }
    .btn-download:hover {
      background:#203f6a; color:white; border-color:#203f6a; text-decoration:none;
    }

    /* Empty state */
    .empty-state {
      text-align:center; padding:60px 20px;
    }
    .empty-state i { font-size:48px; color:#cbd5e1; display:block; margin-bottom:14px; }
    .empty-state h4 { font-size:17px; font-weight:800; color:#1a202c; margin-bottom:6px; }
    .empty-state p  { font-size:13px; color:#94a3b8; }

    .pagination-wrap { padding:16px 24px; border-top:1.5px solid #f1f5f9; }
  </style>
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'invoices' }) %>

<div class="main-content">
  <div class="top-bar">
    <h1 class="page-title">My Invoices</h1>
    <button class="user-profile-btn">
      <div class="user-avatar-small"><%= user.name.charAt(0).toUpperCase() %></div>
      <span class="user-name-text" style="font-size:14px;font-weight:600;color:#2d3748;">
        Hello <%= user.name.split(' ')[0] %>
      </span>
    </button>
  </div>

  <%
    const allInvoices   = invoices;
    const bookingCount  = allInvoices.filter(i => i.type === 'booking').length;
    const refundCount   = allInvoices.filter(i => i.type === 'refund').length;
  %>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon total"><i class="fas fa-file-invoice"></i></div>
      <div class="stat-info"><strong><%= total %></strong><span>Total Invoices</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon booking"><i class="fas fa-calendar-check"></i></div>
      <div class="stat-info"><strong><%= bookingCount %></strong><span>Booking Invoices</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon refund"><i class="fas fa-undo"></i></div>
      <div class="stat-info"><strong><%= refundCount %></strong><span>Refund Invoices</span></div>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="filter-tabs">
    <a href="/patient/invoices"               class="filter-tab <%= selectedType==='all'     ? 'active':'' %>">All</a>
    <a href="/patient/invoices?type=booking"  class="filter-tab <%= selectedType==='booking' ? 'active':'' %>">Bookings</a>
    <a href="/patient/invoices?type=refund"   class="filter-tab <%= selectedType==='refund'  ? 'active':'' %>">Refunds</a>
  </div>

  <!-- Invoice list -->
  <div class="invoice-card">
    <div class="invoice-card-header">
      <div class="invoice-card-title">
        <i class="fas fa-file-invoice" style="color:#203f6a;"></i>
        Invoice History
      </div>
      <span class="invoice-count"><%= total %> invoice<%= total !== 1 ? 's' : '' %></span>
    </div>

    <% if (invoices.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-file-invoice"></i>
        <h4>No invoices found</h4>
        <p><%= selectedType === 'all' ? "You don't have any invoices yet." : `No ${selectedType} invoices found.` %></p>
      </div>
    <% } else { %>

      <!-- Table header -->
      <div class="invoice-row-header">
        <span class="col-header">Invoice No.</span>
        <span class="col-header">Appointment</span>
        <span class="col-header">Date</span>
        <span class="col-header">Amount</span>
        <span class="col-header">Download</span>
      </div>

      <% invoices.forEach(inv => { %>
        <%
          const appt    = inv.appointment;
          const doctor  = appt && appt.doctor ? appt.doctor : null;
          const invDate = new Date(inv.createdAt).toLocaleDateString('en-IN', {
            day:'2-digit', month:'short', year:'numeric'
          });
          const apptDate = appt ? new Date(appt.date + 'T00:00:00').toLocaleDateString('en-IN', {
            day:'2-digit', month:'short', year:'numeric'
          }) : '—';
        %>
        <div class="invoice-row">

          <!-- Invoice number + date -->
          <div>
            <div class="inv-number"><%= inv.invoiceNumber %></div>
            <div class="inv-date"><%= invDate %></div>
          </div>

          <!-- Doctor info -->
          <div>
            <% if (doctor) { %>
              <div class="inv-doctor">Dr. <%= doctor.name %></div>
              <div class="inv-spec"><%= doctor.specialization %> · <%= apptDate %> <%= appt.timeSlot %></div>
            <% } else { %>
              <div class="inv-doctor" style="color:#94a3b8;">Appointment removed</div>
            <% } %>
          </div>

          <!-- Type badge -->
          <div>
            <span class="type-badge <%= inv.type %>">
              <i class="fas fa-<%= inv.type === 'booking' ? 'calendar-check' : 'undo' %>"></i>
              <%= inv.type.charAt(0).toUpperCase() + inv.type.slice(1) %>
            </span>
          </div>

          <!-- Amount -->
          <div class="inv-amount">₹<%= inv.amount.toLocaleString('en-IN') %></div>

          <!-- Download -->
          <div>
            <a href="/patient/appointments/<%= appt ? appt._id : '' %>/invoice/download"
               class="btn-download">
              <i class="fas fa-download"></i> PDF
            </a>
          </div>

        </div>
      <% }) %>

      <% if (totalPages > 1) { %>
        <div class="pagination-wrap">
          <%- include('../partials/pagination', {
            currentPage, totalPages,
            searchQuery: '', selectedDepartment: '', sortBy: '',
            selectedStatus: selectedType !== 'all' ? `type=${selectedType}` : ''
          }) %>
        </div>
      <% } %>

    <% } %>
  </div>

</div>

</body>
</html>