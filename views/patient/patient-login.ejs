<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patient Login - Healora</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/patient/login.css">
</head>
<body>
  <%- include('../partials/loading') %>

  <div class="auth-wrapper">

    <!-- Left Panel -->
    <div class="left-panel">
      <div class="left-content">
        <a href="/" class="brand">
  <img src="/images/logo-1.jpg" alt="Healora" class="brand-logo">
</a>
        <div class="left-hero">
          <h1 class="left-title">Your health,<br>our priority.</h1>
          <p class="left-sub">Access your appointments, medical records, and health history — all in one place.</p>
        </div>
        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-calendar-check"></i></div>
            <div>
              <div class="feature-title">Book appointments</div>
              <div class="feature-desc">Find and book doctors instantly</div>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-file-medical"></i></div>
            <div>
              <div class="feature-title">Medical records</div>
              <div class="feature-desc">Access your health history anytime</div>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-wallet"></i></div>
            <div>
              <div class="feature-title">Healora wallet</div>
              <div class="feature-desc">Easy and secure payments</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel -->
    <div class="right-panel">
      <div class="form-wrap">

        <div class="form-header">
          <h2 class="form-title">Welcome back</h2>
          <p class="form-subtitle">Sign in to your patient account</p>
        </div>

        <div id="serverError" class="server-error"></div>
        <div id="successMessage" class="success-message"></div>

        <form id="patientLoginForm" novalidate>

          <div class="field-group">
            <label class="field-label" for="email">Email address</label>
            <div class="input-wrap">
              <i class="fas fa-envelope input-icon"></i>
              <input
                type="email"
                name="email"
                id="email"
                class="field-input"
                placeholder="you@example.com"
                autocomplete="username"
                required
              >
            </div>
            <div id="errorEmail" class="field-error"></div>
          </div>

          <div class="field-group">
            <div class="label-row">
              <label class="field-label" for="password">Password</label>
              <a href="/patient/forgot-password" class="forgot-link">Forgot password?</a>
            </div>
            <div class="input-wrap">
              <i class="fas fa-lock input-icon"></i>
              <input
                type="password"
                name="password"
                id="password"
                class="field-input"
                placeholder="Enter your password"
                autocomplete="current-password"
                required
              >
              <i class="fa-solid fa-eye toggle-password" id="togglePassword"></i>
            </div>
            <div id="errorPassword" class="field-error"></div>
          </div>

          <button type="submit" class="btn-submit">
            Sign in to Healora
          </button>

          <div class="divider">
            <span>or continue with</span>
          </div>

          <a href="/patient/auth/google?prompt=select_account" class="btn-google">
            <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google" width="18">
            Continue with Google
          </a>

          <p class="signup-text">
            Don't have an account? <a href="/patient/signup" class="signup-link">Sign up free</a>
          </p>

        </form>
      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/formValidation.js"></script>
  <script>
    FormValidator.handleFormSubmit(
      'patientLoginForm',
      '/patient/login',
      'login',
      {
        onSuccess: (result) => {
          document.getElementById('successMessage').style.display = 'block';
          document.getElementById('successMessage').textContent = 'Login successful! Redirecting...';
          setTimeout(() => {
            window.location.href = result.redirect;
          }, 1000);
        }
      }
    );
    FormValidator.setupPasswordToggle('password', 'togglePassword');
  </script>
</body>
</html>