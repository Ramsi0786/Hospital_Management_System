<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:#f1f5f9; min-height:100vh; }
    .main-content { margin-left:260px; padding:30px; min-height:100vh; }

    /* Top bar */
    .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; }
    .back-btn { display:inline-flex; align-items:center; gap:8px; color:white; text-decoration:none; font-size:14px; font-weight:600; padding:8px 16px; background:#4b72b6; border-radius:8px; transition:all .3s; }
    .back-btn:hover { background:#1e4382; color:white; }
    .page-title { font-size:26px; font-weight:800; color:#1a202c; margin:10px 0 0; }
    .user-profile-btn { display:flex; align-items:center; gap:10px; background:white; padding:8px 16px; border-radius:50px; border:none; box-shadow:0 2px 8px rgba(0,0,0,.08); }
    .user-avatar-small { width:35px; height:35px; border-radius:50%; background:#203f6a; color:white; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; }
    .user-name { font-size:14px; font-weight:600; color:#2d3748; }

    /* Layout */
    .booking-layout { display:grid; grid-template-columns:1fr 380px; gap:24px; align-items:start; }

    /* Cards */
    .card { background:white; border-radius:16px; padding:24px; box-shadow:0 4px 20px rgba(0,0,0,.06); margin-bottom:20px; }
    .card-title { font-size:16px; font-weight:800; color:#1a202c; margin-bottom:20px; display:flex; align-items:center; gap:10px; }
    .card-title i { color:#203f6a; }

    /* Doctor summary */
    .doctor-summary { display:flex; align-items:center; gap:16px; }
    .doc-avatar { width:70px; height:70px; border-radius:50%; object-fit:cover; border:3px solid #e2e8f0; }
    .doc-avatar-initials { width:70px; height:70px; border-radius:50%; background:linear-gradient(135deg,#203f6a,#1a7f8e); color:white; font-size:22px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .doc-info h3 { font-size:18px; font-weight:800; color:#1a202c; margin-bottom:2px; }
    .doc-info p  { font-size:13px; color:#64748b; margin:0; }
    .doc-info .dept { color:#203f6a; font-weight:600; font-size:13px; }

    /* Appointment summary strip */
    .appt-strip { display:flex; gap:12px; margin-top:16px; flex-wrap:wrap; }
    .appt-chip { display:flex; align-items:center; gap:8px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px 14px; font-size:13px; font-weight:600; color:#374151; }
    .appt-chip i { color:#203f6a; }

    /* Form */
    .form-label { font-size:13px; font-weight:700; color:#374151; margin-bottom:6px; display:block; text-transform:uppercase; letter-spacing:.4px; }
    .form-control { width:100%; padding:11px 14px; border:1.5px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:inherit; color:#374151; outline:none; transition:border-color .2s; background:white; }
    .form-control:focus { border-color:#203f6a; }
    textarea.form-control { resize:vertical; min-height:90px; }
    .form-group { margin-bottom:18px; }

    /* Payment methods */
    .payment-options { display:flex; flex-direction:column; gap:10px; }
    .payment-option { display:flex; align-items:center; gap:14px; padding:14px 16px; border:2px solid #e2e8f0; border-radius:12px; cursor:pointer; transition:all .2s; }
    .payment-option:hover { border-color:#93c5fd; }
    .payment-option.selected { border-color:#203f6a; background:#eff6ff; }
    .payment-option input[type=radio] { display:none; }
    .pay-icon { width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
    .pay-icon.cash    { background:#ecfdf5; color:#059669; }
    .pay-icon.wallet  { background:#eff6ff; color:#2563eb; }
    .pay-icon.razorpay{ background:#fff0f0; color:#e53e3e; }
    .pay-info { flex:1; }
    .pay-name  { font-size:14px; font-weight:700; color:#1a202c; }
    .pay-desc  { font-size:12px; color:#94a3b8; margin-top:2px; }
    .pay-check { width:20px; height:20px; border-radius:50%; border:2px solid #e2e8f0; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all .2s; }
    .payment-option.selected .pay-check { background:#203f6a; border-color:#203f6a; color:white; }
    .wallet-low { font-size:12px; color:#ef4444; font-weight:600; margin-top:2px; }

    /* Order summary */
    .summary-card { background:white; border-radius:16px; padding:24px; box-shadow:0 4px 20px rgba(0,0,0,.06); position:sticky; top:24px; }
    .summary-title { font-size:16px; font-weight:800; color:#1a202c; margin-bottom:20px; }
    .summary-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid #f0f2f5; font-size:14px; color:#64748b; }
    .summary-row:last-of-type { border-bottom:none; }
    .summary-row strong { color:#1a202c; font-weight:700; }
    .summary-total { display:flex; justify-content:space-between; align-items:center; padding:14px 0 0; margin-top:4px; font-size:17px; font-weight:800; color:#1a202c; }
    .summary-total span:last-child { color:#203f6a; }

    .btn-book { width:100%; padding:15px; background:#203f6a; color:white; border:none; border-radius:12px; font-size:16px; font-weight:800; cursor:pointer; font-family:inherit; transition:all .2s; display:flex; align-items:center; justify-content:center; gap:10px; margin-top:20px; }
    .btn-book:hover { background:#1a3456; transform:translateY(-2px); box-shadow:0 8px 24px rgba(32,63,106,.3); }
    .btn-book:disabled { background:#94a3b8; cursor:not-allowed; transform:none; box-shadow:none; }

    .secure-note { display:flex; align-items:center; gap:6px; justify-content:center; font-size:12px; color:#94a3b8; margin-top:12px; }

    /* Alert */
    .alert-box { padding:12px 16px; border-radius:10px; font-size:13px; font-weight:600; margin-bottom:16px; display:none; }
    .alert-box.error { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; display:flex; gap:8px; align-items:center; }

    @media (max-width:1000px) { .booking-layout { grid-template-columns:1fr; } .summary-card { position:static; } }
    @media (max-width:768px)  { .main-content { margin-left:70px; } }
  </style>
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'doctors' }) %>

<div class="main-content">
  <div class="top-bar">
    <div>
      <a href="/patient/doctors/<%= doctor._id %>" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Doctor
      </a>
      <h1 class="page-title">Book Appointment</h1>
    </div>
    <button class="user-profile-btn">
      <div class="user-avatar-small"><%= user.name.charAt(0).toUpperCase() %></div>
      <span class="user-name">Hello <%= user.name.split(' ')[0] %></span>
    </button>
  </div>

  <div class="booking-layout">

    <!-- ── LEFT: Booking Form ── -->
    <div>

      <!-- Doctor Summary -->
      <div class="card">
        <div class="card-title"><i class="fas fa-user-md"></i> Appointment Details</div>

        <div class="doctor-summary">
          <% if (doctor.profileImage) { %>
            <img class="doc-avatar" src="<%= doctor.profileImage %>" alt="<%= doctor.name %>">
          <% } else { %>
            <div class="doc-avatar-initials">
              <%= doctor.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
            </div>
          <% } %>
          <div class="doc-info">
            <h3>Dr. <%= doctor.name %></h3>
            <p><%= doctor.specialization %></p>
            <p class="dept"><i class="fas fa-hospital" style="font-size:11px;"></i> <%= doctor.department %> Department</p>
          </div>
        </div>

        <div class="appt-strip">
          <div class="appt-chip">
            <i class="fas fa-calendar"></i>
            <%= new Date(date + 'T00:00:00').toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
          </div>
          <div class="appt-chip">
            <i class="fas fa-clock"></i>
            <%= slot %>
          </div>
          <div class="appt-chip">
            <i class="fas fa-indian-rupee-sign"></i>
            ₹<%= doctor.consultationFee %>
          </div>
        </div>
      </div>

      <!-- Reason -->
      <div class="card">
        <div class="card-title"><i class="fas fa-notes-medical"></i> Reason for Visit</div>
        <div class="form-group">
          <label class="form-label">Describe your symptoms or reason <span style="color:#94a3b8;font-weight:400;text-transform:none;">(optional)</span></label>
          <textarea class="form-control" id="reasonInput" placeholder="e.g. Chest pain, fever, routine checkup..."></textarea>
        </div>
      </div>

      <!-- Payment Method -->
      <div class="card">
        <div class="card-title"><i class="fas fa-credit-card"></i> Payment Method</div>

        <div id="alertBox" class="alert-box"></div>

        <div class="payment-options">

          <!-- Cash -->
          <label class="payment-option selected" id="opt-cash" onclick="selectPayment('cash')">
            <input type="radio" name="payment" value="cash" checked>
            <div class="pay-icon cash"><i class="fas fa-money-bill-wave"></i></div>
            <div class="pay-info">
              <div class="pay-name">Pay at Clinic</div>
              <div class="pay-desc">Pay cash when you visit the doctor</div>
            </div>
            <div class="pay-check"><i class="fas fa-check" style="font-size:10px;"></i></div>
          </label>

          <!-- Wallet -->
          <label class="payment-option" id="opt-wallet" onclick="selectPayment('wallet')">
            <input type="radio" name="payment" value="wallet">
            <div class="pay-icon wallet"><i class="fas fa-wallet"></i></div>
            <div class="pay-info">
              <div class="pay-name">Healora Wallet</div>
              <div class="pay-desc">
                Balance: <strong>₹<%= walletBalance %></strong>
                <% if (walletBalance < doctor.consultationFee) { %>
                  <div class="wallet-low"><i class="fas fa-exclamation-circle"></i> Insufficient balance</div>
                <% } %>
              </div>
            </div>
            <div class="pay-check"><i class="fas fa-check" style="font-size:10px;"></i></div>
          </label>

          <!-- Razorpay -->
          <label class="payment-option" id="opt-razorpay" onclick="selectPayment('razorpay')">
            <input type="radio" name="payment" value="razorpay">
            <div class="pay-icon razorpay"><i class="fas fa-credit-card"></i></div>
            <div class="pay-info">
              <div class="pay-name">Pay Online</div>
              <div class="pay-desc">UPI, Cards, Net Banking via Razorpay</div>
            </div>
            <div class="pay-check"><i class="fas fa-check" style="font-size:10px;"></i></div>
          </label>

        </div>
      </div>

    </div>

    <!-- ── RIGHT: Order Summary ── -->
    <div class="summary-card">
      <div class="summary-title">Order Summary</div>

      <div class="summary-row">
        <span>Consultation Fee</span>
        <strong>₹<%= doctor.consultationFee %></strong>
      </div>
      <div class="summary-row">
        <span>Platform Fee</span>
        <strong>₹0</strong>
      </div>
      <div class="summary-row">
        <span>Doctor</span>
        <strong>Dr. <%= doctor.name %></strong>
      </div>
      <div class="summary-row">
        <span>Date</span>
        <strong><%= new Date(date + 'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></strong>
      </div>
      <div class="summary-row">
        <span>Time Slot</span>
        <strong><%= slot %></strong>
      </div>

      <div class="summary-total">
        <span>Total</span>
        <span>₹<%= doctor.consultationFee %></span>
      </div>

      <button class="btn-book" id="bookBtn" onclick="handleBooking()">
        <i class="fas fa-calendar-check"></i>
        <span id="bookBtnText">Confirm Booking</span>
      </button>

      <div class="secure-note">
        <i class="fas fa-lock"></i> Secure & encrypted payment
      </div>
    </div>

  </div>
</div>

<!-- Logout Modal -->
<div class="modal-overlay" id="logoutModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:20px;padding:40px;max-width:420px;width:90%;text-align:center;">
    <h3 style="font-size:22px;font-weight:800;margin-bottom:10px;">Confirm Logout</h3>
    <p style="color:#718096;margin-bottom:28px;">Are you sure you want to logout?</p>
    <div style="display:flex;gap:12px;">
      <button onclick="document.getElementById('logoutModal').style.display='none'" style="flex:1;padding:12px;border-radius:10px;border:none;background:#e2e8f0;font-weight:700;cursor:pointer;font-family:inherit;">Cancel</button>
      <button onclick="fetch('/patient/logout',{method:'POST'}).then(()=>window.location.href='/patient/login')" style="flex:1;padding:12px;border-radius:10px;border:none;background:#203f6a;color:white;font-weight:700;cursor:pointer;font-family:inherit;">Logout</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<% if (razorpayKeyId) { %>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<% } %>

<script type="application/json" id="page-data">
  <%- JSON.stringify({
    doctorId:      doctor._id,
    doctorName:    doctor.name,
    date:          date,
    slot:          slot,
    fee:           doctor.consultationFee,
    walletBalance: walletBalance,
    razorpayKeyId: razorpayKeyId,
    patientName:   user.name,
    patientEmail:  user.email,
    patientPhone:  user.phone || ''
  }) %>
</script>

<script>
  const PD = JSON.parse(document.getElementById('page-data').textContent);
  let selectedPayment = 'cash';

  function selectPayment(method) {
    selectedPayment = method;
    ['cash','wallet','razorpay'].forEach(m => {
      document.getElementById(`opt-${m}`).classList.toggle('selected', m === method);
    });
    hideAlert();
  }

  function showAlert(msg) {
    const box = document.getElementById('alertBox');
    box.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${msg}`;
    box.className = 'alert-box error';
  }

  function hideAlert() {
    document.getElementById('alertBox').style.display = 'none';
    document.getElementById('alertBox').className = 'alert-box';
  }

  function setLoading(on) {
    const btn  = document.getElementById('bookBtn');
    const text = document.getElementById('bookBtnText');
    btn.disabled = on;
    text.textContent = on ? 'Processing...' : 'Confirm Booking';
  }

  // ── Main booking handler ────────────────────────────────
  async function handleBooking() {
    hideAlert();

    if (selectedPayment === 'wallet' && PD.walletBalance < PD.fee) {
      showAlert(`Insufficient wallet balance. You need ₹${PD.fee}, you have ₹${PD.walletBalance}.`);
      return;
    }

    if (selectedPayment === 'razorpay') {
      await handleRazorpay();
      return;
    }

    // Cash or Wallet
    setLoading(true);
    try {
      const res  = await fetch('/patient/appointments/book', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          doctorId:      PD.doctorId,
          date:          PD.date,
          timeSlot:      PD.slot,
          reason:        document.getElementById('reasonInput').value.trim(),
          paymentMethod: selectedPayment
        })
      });
      const data = await res.json();
      if (data.success) {
        window.location.href = data.redirectUrl;
      } else {
        showAlert(data.error || 'Booking failed. Please try again.');
        setLoading(false);
      }
    } catch (err) {
      showAlert('Something went wrong. Please try again.');
      setLoading(false);
    }
  }

  // ── Razorpay flow ───────────────────────────────────────
  async function handleRazorpay() {
    setLoading(true);
    try {
      // Step 1: Create order
      const orderRes  = await fetch('/patient/appointments/razorpay/create-order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ doctorId: PD.doctorId, date: PD.date, timeSlot: PD.slot })
      });
      const orderData = await orderRes.json();

      if (!orderData.success) {
        showAlert(orderData.error || 'Could not initiate payment.');
        setLoading(false);
        return;
      }

      setLoading(false);

      // Step 2: Open Razorpay checkout
      const options = {
        key:         PD.razorpayKeyId,
        amount:      orderData.order.amount,
        currency:    'INR',
        name:        'Healora',
        description: `Consultation with Dr. ${PD.doctorName}`,
        order_id:    orderData.order.id,
        prefill: {
          name:    PD.patientName,
          email:   PD.patientEmail,
          contact: PD.patientPhone
        },
        theme: { color: '#203f6a' },
        handler: async function(response) {
          setLoading(true);
          // Step 3: Verify payment
          const verifyRes  = await fetch('/patient/appointments/razorpay/verify', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              razorpay_order_id:   response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature:  response.razorpay_signature,
              doctorId:            PD.doctorId,
              date:                PD.date,
              timeSlot:            PD.slot,
              reason:              document.getElementById('reasonInput').value.trim()
            })
          });
          const verifyData = await verifyRes.json();
          if (verifyData.success) {
            window.location.href = verifyData.redirectUrl;
          } else {
            showAlert(verifyData.error || 'Payment verification failed.');
            setLoading(false);
          }
        },
        modal: {
          ondismiss: function() { setLoading(false); }
        }
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function(resp) {
        showAlert(`Payment failed: ${resp.error.description}`);
        setLoading(false);
      });
      rzp.open();

    } catch (err) {
      showAlert('Payment initiation failed. Please try again.');
      setLoading(false);
    }
  }
</script>
</body>
</html>
