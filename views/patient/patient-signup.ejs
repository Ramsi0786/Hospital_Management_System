<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patient Signup - Healora</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/patient/signup.css">
</head>
<body>
  <%- include('../partials/loading') %>

  <div class="auth-wrapper">

    <!-- Left Panel -->
    <div class="left-panel">
      <div class="left-content">
        <a href="/" class="brand">
  <img src="/images/logo-1.jpg" alt="Healora" class="brand-logo">
</a>
        <div class="left-hero">
          <h1 class="left-title">Join Healora<br>today.</h1>
          <p class="left-sub">Create your free patient account and take control of your health journey in minutes.</p>
        </div>
        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
            <div>
              <div class="feature-title">Secure & private</div>
              <div class="feature-desc">Your data is encrypted and protected</div>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-calendar-check"></i></div>
            <div>
              <div class="feature-title">Easy booking</div>
              <div class="feature-desc">Book doctors in under 2 minutes</div>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i class="fas fa-file-medical"></i></div>
            <div>
              <div class="feature-title">Health records</div>
              <div class="feature-desc">All your records in one place</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel -->
    <div class="right-panel">
      <div class="form-wrap">

        <div class="form-header">
          <h2 class="form-title">Create account</h2>
          <p class="form-subtitle">Fill in your details to get started</p>
        </div>

        <div id="serverError" class="server-error"></div>
        <div id="successMessage" class="success-message"></div>

        <form id="patientSignupForm" novalidate>

          <div class="field-row">
            <div class="field-group">
              <label class="field-label" for="name">Full name</label>
              <div class="input-wrap">
                <i class="fas fa-user input-icon"></i>
                <input type="text" name="name" id="name"
                  class="field-input" placeholder="Your full name" required>
              </div>
              <div id="errorName" class="field-error"></div>
            </div>

            <div class="field-group">
              <label class="field-label" for="phone">Phone number</label>
              <div class="input-wrap">
                <i class="fas fa-phone input-icon"></i>
                <input type="text" name="phone" id="phone"
                  class="field-input" placeholder="10-digit number" required>
              </div>
              <div id="errorPhone" class="field-error"></div>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="email">Email address</label>
            <div class="input-wrap">
              <i class="fas fa-envelope input-icon"></i>
              <input type="email" name="email" id="email"
                class="field-input" placeholder="you@example.com" required>
            </div>
            <div id="errorEmail" class="field-error"></div>
          </div>

          <div class="field-row">
            <div class="field-group">
              <label class="field-label" for="password">Password</label>
              <div class="input-wrap">
                <i class="fas fa-lock input-icon"></i>
                <input type="password" name="password" id="password"
                  class="field-input" placeholder="Min 6 characters" required>
                <i class="fa-solid fa-eye toggle-password" id="togglePassword"></i>
              </div>
              <div id="errorPassword" class="field-error"></div>
            </div>

            <div class="field-group">
              <label class="field-label" for="confirmPassword">Confirm password</label>
              <div class="input-wrap">
                <i class="fas fa-lock input-icon"></i>
                <input type="password" name="confirmPassword" id="confirmPassword"
                  class="field-input" placeholder="Repeat password" required>
                <i class="fa-solid fa-eye toggle-password" id="toggleConfirmPassword"></i>
              </div>
              <div id="errorConfirmPassword" class="field-error"></div>
            </div>
          </div>

          <button type="submit" class="btn-submit">
            Create my account
          </button>

          <div class="divider">
            <span>or continue with</span>
          </div>

          <a href="/patient/auth/google?prompt=select_account" class="btn-google">
            <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google" width="18">
            Continue with Google
          </a>

          <p class="login-text">
            Already have an account? <a href="/patient/login" class="login-link">Sign in</a>
          </p>

        </form>
      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/formValidation.js?v=2"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/alerts.js?v=2"></script>
  <script src="/js/loader.js"></script>
  <script>
    FormValidator.handleFormSubmit(
      'patientSignupForm',
      '/patient/signup',
      'signup',
      {
        onSuccess: (result) => {
          if (result.requiresOtp) {
            window.location.href = '/patient/verify-otp';
          }
        }
      }
    );
    FormValidator.setupPasswordToggle('password', 'togglePassword');
    FormValidator.setupPasswordToggle('confirmPassword', 'toggleConfirmPassword');
  </script>
</body>
</html>