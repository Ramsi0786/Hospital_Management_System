<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/patient/doctors-list.css">
</head>
<body>

  <%- include('../partials/patient-sidebar', { currentPage: 'doctors' }) %>

  <div class="main-content">

    <!-- Top Bar -->
    <div class="top-bar">
      <div>
        <h1 class="page-title">Find Your Doctor</h1>
        <p class="page-subtitle">Connect with experienced healthcare professionals</p>
      </div>
      <button class="user-profile-btn">
        <div class="user-avatar-small">
          <% if (locals.user && user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="<%= user.name %>">
          <% } else { %>
            <%= user.name.charAt(0).toUpperCase() %>
          <% } %>
        </div>
        <span class="user-name">Hello <%= user.name.split(' ')[0] %></span>
      </button>
    </div>

    <!-- Filter Bar (single row) -->
    <form method="GET" action="/patient/doctors" id="filterForm">
      <div class="filter-bar">

        <div class="search-box">
          <i class="fas fa-search search-icon"></i>
          <input
            type="text"
            name="search"
            id="searchInput"
            class="search-input"
            placeholder="Search by name, specialization..."
            value="<%= locals.searchQuery || '' %>"
            autocomplete="off"
          >
          <% if (locals.searchQuery) { %>
            <button type="button" class="search-clear" onclick="clearSearch()">
              <i class="fas fa-times"></i>
            </button>
          <% } %>
        </div>

        <div class="filter-select-wrap">
          <i class="fas fa-building"></i>
          <select name="department" id="departmentFilter" class="filter-select">
            <option value="">All Departments</option>
            <% if (typeof departments !== 'undefined') { %>
              <% departments.forEach(dept => { %>
                <% const deptName = typeof dept === 'object' ? dept.name : dept; %>
                <option value="<%= deptName %>" <%= (locals.selectedDepartment === deptName) ? 'selected' : '' %>>
                  <%= deptName %>
                </option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div class="filter-select-wrap">
          <i class="fas fa-sort-amount-down"></i>
          <select name="sort" id="sortFilter" class="filter-select">
            <option value="">Sort By</option>
            <option value="rating"     <%= (locals.sortBy === 'rating')     ? 'selected' : '' %>>Highest Rated</option>
            <option value="experience" <%= (locals.sortBy === 'experience') ? 'selected' : '' %>>Most Experienced</option>
            <option value="fee-low"    <%= (locals.sortBy === 'fee-low')    ? 'selected' : '' %>>Fee: Low to High</option>
            <option value="fee-high"   <%= (locals.sortBy === 'fee-high')   ? 'selected' : '' %>>Fee: High to Low</option>
          </select>
        </div>

        <% if (locals.searchQuery || locals.selectedDepartment || locals.sortBy) { %>
          <button type="button" class="btn-clear-filter" onclick="clearAllFilters()">
            <i class="fas fa-times"></i> Clear
          </button>
        <% } %>

        <div class="results-info">
          <strong><%= total %></strong> Doctor<%= total !== 1 ? 's' : '' %>
        </div>

        <div class="view-toggle">
          <button type="button" class="toggle-btn active" data-view="grid" onclick="toggleView('grid', event)">
            <i class="fas fa-th-large"></i>
          </button>
          <button type="button" class="toggle-btn" data-view="list" onclick="toggleView('list', event)">
            <i class="fas fa-list"></i>
          </button>
        </div>

      </div>
    </form>

    <!-- Doctors Grid -->
    <div class="doctors-container" id="doctorsContainer">
      <% if (doctors.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-user-doctor"></i>
          <h3>No Doctors Found</h3>
          <p>Try adjusting your search or filters</p>
          <a href="/patient/doctors" class="btn-reset">
            <i class="fas fa-redo"></i> Reset Filters
          </a>
        </div>
      <% } else { %>
        <% doctors.forEach(doctor => { %>
          <div class="doctor-card">

            <% if (doctor.isFeatured) { %>
              <div class="featured-badge"><i class="fas fa-star"></i> Featured</div>
            <% } %>

            <div class="doctor-header">
              <div class="doctor-avatar">
                <% if (doctor.profileImage) { %>
                  <img src="<%= doctor.profileImage %>" alt="Dr. <%= doctor.name %>">
                <% } else { %>
                  <div class="avatar-initials">
                    <%= doctor.name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) %>
                  </div>
                <% } %>
              </div>
              <div class="doctor-info">
                <h3 class="doctor-name">Dr. <%= doctor.name %></h3>
                <p class="doctor-specialty"><%= doctor.specialization %></p>
                <p class="doctor-department"><i class="fas fa-building"></i> <%= doctor.department %></p>
              </div>
            </div>

            <div class="stats-row">
              <div class="stat-item">
                <span class="stat-value">⭐ <%= doctor.rating || '4.5' %></span>
                <span class="stat-label">Rating</span>
              </div>
              <div class="stat-item">
                <span class="stat-value"><%= doctor.experience || '0' %>+ yrs</span>
                <span class="stat-label">Exp.</span>
              </div>
              <div class="stat-item">
                <span class="stat-value">500+</span>
                <span class="stat-label">Patients</span>
              </div>
            </div>

            <div class="card-footer">
              <div class="fee-info">
                
                <span class="fee-amount"><span class="fee-label">Consultation Fee</span> ₹<%= doctor.consultationFee || '500' %></span>
              </div>
              <div class="action-buttons">
                <a href="/patient/doctors/<%= doctor._id %>" class="btn-view">
                  <i class="fas fa-eye"></i> View
                </a>
                <a href="/patient/doctors/<%= doctor._id %>" class="btn-book">
                  <i class="fas fa-calendar-check"></i> Book
                </a>
              </div>
            </div>

          </div>
        <% }) %>
      <% } %>
    </div>

    <% if (totalPages > 1) { %>
      <%- include('../partials/pagination', {
        currentPage,
        totalPages,
        searchQuery: searchQuery || '',
        selectedDepartment: selectedDepartment || '',
        sortBy: sortBy || ''
      }) %>
    <% } %>

  </div>

  <script>
    document.getElementById('departmentFilter').addEventListener('change', () => {
      document.getElementById('filterForm').submit();
    });
    document.getElementById('sortFilter').addEventListener('change', () => {
      document.getElementById('filterForm').submit();
    });

    let searchTimeout;
    document.getElementById('searchInput').addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => document.getElementById('filterForm').submit(), 500);
    });

    function clearSearch() {
      document.getElementById('searchInput').value = '';
      document.getElementById('filterForm').submit();
    }

    function clearAllFilters() {
      window.location.href = '/patient/doctors';
    }

    function toggleView(view, event) {
      const container = document.getElementById('doctorsContainer');
      document.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
      event.currentTarget.classList.add('active');
      container.classList.toggle('list-view', view === 'list');
      localStorage.setItem('doctorsView', view);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const saved = localStorage.getItem('doctorsView');
      if (saved === 'list') {
        document.getElementById('doctorsContainer').classList.add('list-view');
        document.querySelector('[data-view="list"]').classList.add('active');
        document.querySelector('[data-view="grid"]').classList.remove('active');
      }
    });
  </script>

</body>
</html>
