<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/patient/appointment.css" >
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'appointments' }) %>

<div id="healora-modal-root"></div>

<div class="main-content">
  <%- include('../partials/patient-topbar', {
  pageTitle:    'My Appointments',
  pageSubtitle: null,
  backUrl:      null,
  backLabel:    null
}) %>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon total"><i class="fas fa-calendar-alt"></i></div>
      <div class="stat-info"><strong><%= total %></strong><span>Total</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon confirmed"><i class="fas fa-check-circle"></i></div>
      <div class="stat-info"><strong><%= appointments.filter(a => a.status === 'confirmed').length %></strong><span>Confirmed</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon pending"><i class="fas fa-clock"></i></div>
      <div class="stat-info"><strong><%= appointments.filter(a => a.status === 'pending').length %></strong><span>Pending</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon cancelled"><i class="fas fa-times-circle"></i></div>
      <div class="stat-info"><strong><%= appointments.filter(a => a.status === 'cancelled').length %></strong><span>Cancelled</span></div>
    </div>
  </div>

  <div class="filter-tabs">
    <a href="/patient/appointments"                  class="filter-tab <%= selectedStatus==='all'       ? 'active':'' %>">All</a>
    <a href="/patient/appointments?status=pending"   class="filter-tab <%= selectedStatus==='pending'   ? 'active':'' %>">Pending</a>
    <a href="/patient/appointments?status=confirmed" class="filter-tab <%= selectedStatus==='confirmed' ? 'active':'' %>">Confirmed</a>
    <a href="/patient/appointments?status=completed" class="filter-tab <%= selectedStatus==='completed' ? 'active':'' %>">Completed</a>
    <a href="/patient/appointments?status=cancelled" class="filter-tab <%= selectedStatus==='cancelled' ? 'active':'' %>">Cancelled</a>
  </div>

  <% if (appointments.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-calendar-times"></i>
      <h4>No appointments found</h4>
      <p><%= selectedStatus === 'all' ? "You haven't booked any appointments yet." : `No ${selectedStatus} appointments.` %></p>
      <a href="/patient/doctors" class="btn-primary"><i class="fas fa-search"></i> Find a Doctor</a>
    </div>
  <% } else { %>
    <div class="appointments-list">
      <% appointments.forEach(appt => { %>
        <div class="appt-card" id="appt-<%= appt._id %>">
          <% if (appt.doctor && appt.doctor.profileImage) { %>
            <img class="doc-avatar" src="<%= appt.doctor.profileImage %>" alt="">
          <% } else { %>
            <div class="doc-initials"><%= appt.doctor ? appt.doctor.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) : 'DR' %></div>
          <% } %>
          <div class="appt-main">
            <div class="appt-doctor">Dr. <%= appt.doctor ? appt.doctor.name : 'Unknown' %></div>
            <div class="appt-spec"><%= appt.doctor ? appt.doctor.specialization : '' %> · <%= appt.department %></div>
            <div class="appt-meta">
              <span class="meta-chip"><i class="fas fa-calendar"></i> <%= new Date(appt.date+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'}) %></span>
              <span class="meta-chip"><i class="fas fa-clock"></i> <%
                const [h1, m1] = appt.timeSlot.split(':').map(Number);
                const ampm1 = h1 >= 12 ? 'PM' : 'AM';
                const fh1 = h1 % 12 || 12;
                %><%= `${fh1}:${String(m1).padStart(2,'0')} ${ampm1}` %></span>
              <span class="meta-chip">
                <i class="fas fa-<%= appt.paymentMethod==='cash'?'money-bill-wave':appt.paymentMethod==='wallet'?'wallet':'credit-card' %>"></i>
                <%= appt.paymentMethod==='cash'?'Cash':appt.paymentMethod==='wallet'?'Wallet':'Online' %>
              </span>
              <% if (appt.reason) { %><span class="meta-chip"><i class="fas fa-notes-medical"></i> <%= appt.reason.substring(0,30) %><%= appt.reason.length>30?'...':'' %></span><% } %>
            </div>
            <% if (appt.status==='cancelled' && appt.refundAmount>0) { %>
              <div style="margin-top:8px;">
                <span class="refund-info"><i class="fas fa-undo"></i> Refund: ₹<%= appt.refundAmount %> (<%= appt.refundPercentage %>%) — <%= appt.refundStatus %></span>
              </div>
            <% } %>
          </div>
          <div class="appt-right">
            <span class="status-badge <%= appt.status %>"><%= appt.status %></span>
            <div class="appt-fee">₹<%= appt.consultationFee %></div>
            <div class="appt-actions">
              <a href="/patient/appointments/<%= appt._id %>" class="btn-sm btn-view"><i class="fas fa-eye"></i> View</a>
              <%
                const [slotHour, slotMin] = appt.timeSlot.split(':').map(Number);
                const apptDateTime = new Date(appt.date);
                apptDateTime.setHours(slotHour, slotMin, 0, 0);
                const isPast = apptDateTime < new Date();
              %>
              <% if (['pending','confirmed'].includes(appt.status) && !isPast) { %>
                <button class="btn-sm btn-cancel"
                  data-id="<%= appt._id %>"
                  data-doctor="<%= appt.doctor ? appt.doctor.name : 'Unknown' %>"
                  data-date="<%= appt.date %>"
                  data-slot="<%= appt.timeSlot %>"
                  data-fee="<%= appt.consultationFee %>"
                  data-method="<%= appt.paymentMethod %>"
                  data-payment-status="<%= appt.paymentStatus %>"
                  onclick="openCancelModal(this)">Cancel</button>
              <% } else if (['pending','confirmed'].includes(appt.status) && isPast) { %>
                <button class="btn-sm" style="background:#f1f5f9;color:#94a3b8;cursor:not-allowed;" disabled>Expired</button>
              <% } %>

              <% if (appt.status === 'completed' && !appt.hasReview) { %>
  <button class="btn-sm btn-rate"
    data-id="<%= appt._id %>"
    data-doctor="<%= appt.doctor ? appt.doctor.name : 'Unknown' %>"
    data-date="<%= appt.date %>"
    data-slot="<%= appt.timeSlot %>"
    onclick="openRateModal(this)">
    <i class="fas fa-star"></i> Rate
  </button>
<% } else if (appt.status === 'completed' && appt.hasReview) { %>
  <button class="btn-sm btn-rated"
    data-id="<%= appt._id %>"
    data-doctor="<%= appt.doctor ? appt.doctor.name : 'Unknown' %>"
    data-date="<%= appt.date %>"
    data-slot="<%= appt.timeSlot %>"
    onclick="openRateModal(this)">
    <i class="fas fa-star"></i> Edit Rating
  </button>
<% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <% if (totalPages > 1) { %>
      <%- include('../partials/pagination', { 
  currentPage, 
  totalPages, 
  selectedStatus,
  searchQuery: '',
  selectedDepartment: '',
  sortBy: ''
}) %>
    <% } %>
  <% } %>
</div>

<script>
  const modalRoot = document.getElementById('healora-modal-root');
  let cancelTargetId = null;

  // ── Global time formatter ──────────────────────────────────────
  function formatSlot(slot) {
    const [h, m] = slot.split(':').map(Number);
    const ampm = h >= 12 ? 'PM' : 'AM';
    return `${h % 12 || 12}:${String(m).padStart(2, '0')} ${ampm}`;
  }

  function showModal(innerHtml) {
    modalRoot.innerHTML = `
      <div class="hm-backdrop" id="hm-backdrop">
        ${innerHtml}
      </div>`;
    document.getElementById('hm-backdrop').addEventListener('click', function(e) {
      if (e.target === this) hideModal();
    });
    requestAnimationFrame(() => requestAnimationFrame(() => {
      modalRoot.classList.add('active');
    }));
    document.body.style.overflow = 'hidden';
  }

  function hideModal() {
    modalRoot.classList.remove('active');
    document.body.style.overflow = '';
    setTimeout(() => { modalRoot.innerHTML = ''; }, 250);
    cancelTargetId = null;
  }

  /* ── Cancel modal ─────────────────────────────────────────────── */
  function openCancelModal(btn) {
    const id            = btn.dataset.id;
    const doctorName    = btn.dataset.doctor;
    const date          = btn.dataset.date;
    const timeSlot      = btn.dataset.slot;
    const fee           = parseFloat(btn.dataset.fee);
    const paymentMethod = btn.dataset.method;
    const paymentStatus = btn.dataset.paymentStatus;

    cancelTargetId = id;

    const hoursUntil    = (new Date(date + 'T' + timeSlot + ':00') - new Date()) / (1000 * 60 * 60);
    const refundPercent = hoursUntil >= 12 ? 90 : 0;
    const refundNote    = hoursUntil >= 12 ? '90% refund' : 'No refund (< 12 hrs)';
    const refundAmount  = paymentMethod === 'cash' ? 0 : Math.round(fee * refundPercent / 100);
    const payLabel      = paymentMethod === 'wallet' ? `₹${refundAmount} → Healora Wallet` : `₹${refundAmount} → Original payment method`;
    const dateLabel     = new Date(date + 'T00:00:00').toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' });

    const previewHtml = (paymentMethod === 'cash' || paymentStatus !== 'paid') ? `
      <div class="hm-row"><span>Payment</span><strong>Cash at Hospital</strong></div>
      <div class="hm-row" style="font-size:12px;color:#64748b;"><span>No payment collected — appointment will simply be cancelled.</span></div>
    ` : `
      <div class="hm-row"><span>Consultation Fee</span><strong>₹${fee}</strong></div>
      <div class="hm-row"><span>Refund Policy</span><strong>${refundNote}</strong></div>
      <div class="hm-row total">
        <span>Refund Amount</span>
        <strong style="color:${refundAmount > 0 ? '#059669' : '#dc2626'}">₹${refundAmount} (${refundPercent}%)</strong>
      </div>
      <div class="hm-row" style="font-size:12px;color:#64748b;"><span>Refund to</span><span>${payLabel}</span></div>
    `;

    showModal(`
      <div class="hm-box" onclick="event.stopPropagation()">
        <div class="hm-icon red"><i class="fas fa-times-circle"></i></div>
        <div class="hm-title">Cancel Appointment</div>
        <div class="hm-sub">Dr. ${doctorName} &middot; ${dateLabel} at ${formatSlot(timeSlot)}</div>
        <div class="hm-preview">${previewHtml}</div>
        <textarea id="cancelReason" class="hm-textarea" placeholder="Reason for cancellation (optional)"></textarea>
        <div class="hm-btns">
          <button class="hm-btn gray" onclick="hideModal()">Keep Appointment</button>
          <button class="hm-btn red" id="confirmCancelBtn" onclick="confirmCancel()">Cancel Appointment</button>
        </div>
      </div>
    `);
  }

  async function confirmCancel() {
    if (!cancelTargetId) return;
    const btn    = document.getElementById('confirmCancelBtn');
    const reason = document.getElementById('cancelReason').value.trim();
    btn.disabled    = true;
    btn.textContent = 'Cancelling...';
    try {
      const res  = await fetch(`/patient/appointments/${cancelTargetId}/cancel`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      });
      const data = await res.json();
      if (data.success) { hideModal(); window.location.reload(); }
      else {
        alert(data.error || 'Failed to cancel');
        btn.disabled = false; btn.textContent = 'Cancel Appointment';
      }
    } catch {
      alert('Something went wrong. Please try again.');
      btn.disabled = false; btn.textContent = 'Cancel Appointment';
    }
  }

  /* ── Rate modal ───────────────────────────────────────────────── */
  let rateTargetId = null;

  function openRateModal(btn) {
    rateTargetId     = btn.dataset.id;
    const doctorName = btn.dataset.doctor;
    const date       = btn.dataset.date;
    const slot       = btn.dataset.slot;
    const dateLabel  = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
      weekday:'long', month:'long', day:'numeric'
    });

    showModal(`
      <div class="hm-box" onclick="event.stopPropagation()">
        <div class="hm-icon" style="background:#fef9c3;color:#d97706;">
          <i class="fas fa-star"></i>
        </div>
        <div class="hm-title">Rate Your Experience</div>
        <div class="hm-sub">Dr. ${doctorName} &middot; ${dateLabel} at ${formatSlot(slot)}</div>

        <div style="display:flex;justify-content:center;gap:10px;margin:20px 0 8px;">
          ${[1,2,3,4,5].map(n => `
            <button type="button"
              id="star-${n}"
              onclick="selectStar(${n})"
              style="background:none;border:none;font-size:32px;cursor:pointer;color:#e2e8f0;transition:color .15s;padding:0;">
              &#9733;
            </button>
          `).join('')}
        </div>
        <div id="ratingLabel" style="text-align:center;font-size:13px;color:#94a3b8;margin-bottom:16px;">
          Tap a star to rate
        </div>

        <div id="reviewHint" style="display:none;font-size:12px;color:#d97706;font-weight:600;margin-bottom:6px;text-align:left;"></div>
        <textarea id="reviewText" class="hm-textarea"
          placeholder="Share your experience (optional)"
          style="margin-bottom:4px;"
          oninput="document.getElementById('reviewText').style.border='';document.getElementById('reviewValidation').style.display='none'"></textarea>
        <div id="reviewValidation" style="display:none;font-size:12px;color:#dc2626;font-weight:600;margin-bottom:12px;">
          <i class="fas fa-exclamation-circle"></i> Please describe your experience for low ratings.
        </div>

        <div class="hm-btns">
          <button class="hm-btn gray" onclick="hideModal()">Cancel</button>
          <button class="hm-btn navy" id="submitRateBtn" onclick="submitRating()" disabled>
            Submit Review
          </button>
        </div>
      </div>
    `);

    selectedRating = 0;
  }

  const ratingLabels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
  let selectedRating = 0;

  function selectStar(n) {
    selectedRating = n;
    for (let i = 1; i <= 5; i++) {
      document.getElementById(`star-${i}`).style.color = i <= n ? '#f59e0b' : '#e2e8f0';
    }
    document.getElementById('ratingLabel').textContent = ratingLabels[n];
    document.getElementById('ratingLabel').style.color = '#d97706';
    document.getElementById('submitRateBtn').disabled = false;

    const hint       = document.getElementById('reviewHint');
    const validation = document.getElementById('reviewValidation');
    if (n <= 2) {
      hint.style.display   = 'block';
      hint.textContent     = '⚠️ Please describe what went wrong (required)';
    } else {
      hint.style.display   = 'none';
    }
    validation.style.display                          = 'none';
    document.getElementById('reviewText').style.border = '';
  }

  async function submitRating() {
    if (!rateTargetId || !selectedRating) return;

    if (selectedRating <= 2) {
      const reviewText = document.getElementById('reviewText').value.trim();
      if (!reviewText) {
        document.getElementById('reviewText').style.border       = '2px solid #dc2626';
        document.getElementById('reviewText').placeholder        = 'Please describe your experience (required for low ratings)';
        document.getElementById('reviewValidation').style.display = 'block';
        return;
      }
    }

    document.getElementById('reviewText').style.border       = '';
    document.getElementById('reviewValidation').style.display = 'none';

    const btn = document.getElementById('submitRateBtn');
    btn.disabled    = true;
    btn.textContent = 'Submitting...';

    try {
      const res  = await fetch(`/patient/appointments/${rateTargetId}/review`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          rating: selectedRating,
          review: document.getElementById('reviewText').value.trim()
        })
      });
      const data = await res.json();
      if (data.success) {
        hideModal();
        window.location.reload();
      } else {
        alert(data.error || 'Failed to submit review');
        btn.disabled    = false;
        btn.textContent = 'Submit Review';
      }
    } catch {
      alert('Something went wrong. Please try again.');
      btn.disabled    = false;
      btn.textContent = 'Submit Review';
    }
  }

  /* ── Logout modal ─────────────────────────────────────────────── */
  function showLogoutModal() {
    showModal(`
      <div class="hm-box" onclick="event.stopPropagation()">
        <div class="hm-icon blue"><i class="fas fa-sign-out-alt"></i></div>
        <div class="hm-title">Confirm Logout</div>
        <div class="hm-sub">Are you sure you want to logout from Healora?</div>
        <div class="hm-btns">
          <button class="hm-btn gray" onclick="hideModal()">Cancel</button>
          <button class="hm-btn navy" onclick="confirmLogout()">Logout</button>
        </div>
      </div>
    `);
  }

  function confirmLogout() {
    fetch('/patient/logout', { method: 'POST' })
      .then(() => window.location.href = '/patient/login')
      .catch(() => window.location.href = '/patient/login');
  }
</script>
</body>
</html>
