<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:#f1f5f9; min-height:100vh; }
    .main-content { margin-left:260px; padding:30px; min-height:100vh; }

    /* Top bar */
    .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; }
    .page-title { font-size:26px; font-weight:800; color:#1a202c; }
    .user-profile-btn { display:flex; align-items:center; gap:10px; background:white; padding:8px 16px; border-radius:50px; border:none; box-shadow:0 2px 8px rgba(0,0,0,.08); }
    .user-avatar-small { width:35px; height:35px; border-radius:50%; background:#203f6a; color:white; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; }
    .user-name { font-size:14px; font-weight:600; color:#2d3748; }

    /* Filter tabs */
    .filter-tabs { display:flex; gap:8px; margin-bottom:24px; flex-wrap:wrap; }
    .filter-tab { padding:8px 18px; border-radius:20px; border:2px solid #e2e8f0; background:white; font-size:13px; font-weight:700; color:#64748b; cursor:pointer; text-decoration:none; transition:all .2s; font-family:inherit; }
    .filter-tab:hover { border-color:#93c5fd; color:#1d4ed8; }
    .filter-tab.active { background:#203f6a; border-color:#203f6a; color:white; }

    /* Stats row */
    .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }
    .stat-card { background:white; border-radius:14px; padding:18px 20px; box-shadow:0 2px 12px rgba(0,0,0,.06); display:flex; align-items:center; gap:14px; }
    .stat-icon { width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
    .stat-icon.total     { background:#eff6ff; color:#2563eb; }
    .stat-icon.confirmed { background:#ecfdf5; color:#059669; }
    .stat-icon.pending   { background:#fffbeb; color:#d97706; }
    .stat-icon.cancelled { background:#fef2f2; color:#dc2626; }
    .stat-info strong { font-size:22px; font-weight:800; color:#1a202c; display:block; }
    .stat-info span   { font-size:12px; color:#94a3b8; font-weight:600; }

    /* Appointment cards */
    .appointments-list { display:flex; flex-direction:column; gap:14px; }

    .appt-card { background:white; border-radius:16px; padding:20px 24px; box-shadow:0 2px 12px rgba(0,0,0,.06); display:grid; grid-template-columns:60px 1fr auto; gap:18px; align-items:center; transition:box-shadow .2s; }
    .appt-card:hover { box-shadow:0 4px 20px rgba(0,0,0,.1); }

    .doc-avatar { width:60px; height:60px; border-radius:50%; object-fit:cover; border:3px solid #e2e8f0; }
    .doc-initials { width:60px; height:60px; border-radius:50%; background:linear-gradient(135deg,#203f6a,#1a7f8e); color:white; font-size:18px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

    .appt-main { min-width:0; }
    .appt-doctor { font-size:16px; font-weight:800; color:#1a202c; margin-bottom:2px; }
    .appt-spec   { font-size:13px; color:#64748b; margin-bottom:8px; }
    .appt-meta   { display:flex; flex-wrap:wrap; gap:10px; }
    .meta-chip   { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:600; color:#374151; background:#f8fafc; padding:4px 10px; border-radius:6px; }
    .meta-chip i { color:#203f6a; font-size:11px; }

    .appt-right { display:flex; flex-direction:column; align-items:flex-end; gap:10px; flex-shrink:0; }

    /* Status badges */
    .status-badge { padding:5px 12px; border-radius:20px; font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.5px; }
    .status-badge.pending   { background:#fffbeb; color:#d97706; }
    .status-badge.confirmed { background:#ecfdf5; color:#059669; }
    .status-badge.completed { background:#eff6ff; color:#2563eb; }
    .status-badge.cancelled { background:#fef2f2; color:#dc2626; }
    .status-badge.rejected  { background:#fdf2f8; color:#9333ea; }

    .appt-fee { font-size:16px; font-weight:800; color:#203f6a; }

    /* Action buttons */
    .appt-actions { display:flex; gap:8px; }
    .btn-sm { padding:7px 14px; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; font-family:inherit; transition:all .2s; border:none; }
    .btn-cancel   { background:#fef2f2; color:#dc2626; }
    .btn-cancel:hover { background:#dc2626; color:white; }
    .btn-view     { background:#eff6ff; color:#2563eb; text-decoration:none; display:inline-flex; align-items:center; gap:5px; }
    .btn-view:hover { background:#2563eb; color:white; }

    /* Refund info */
    .refund-info { font-size:11px; color:#059669; font-weight:600; background:#ecfdf5; padding:4px 10px; border-radius:6px; }

    /* Empty state */
    .empty-state { text-align:center; padding:60px 20px; background:white; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.06); }
    .empty-state i { font-size:56px; color:#cbd5e1; margin-bottom:16px; display:block; }
    .empty-state h4 { font-size:20px; font-weight:800; color:#1a202c; margin-bottom:8px; }
    .empty-state p { color:#94a3b8; margin-bottom:24px; }
    .btn-primary { padding:12px 24px; background:#203f6a; color:white; border:none; border-radius:10px; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all .2s; }
    .btn-primary:hover { background:#1a3456; color:white; }

    /* Cancel modal */
    .modal-backdrop { 
  display: none;
  position: fixed; 
  inset: 0; 
  background: rgba(0, 0, 0, 0.65);
  z-index: 9998;
  backdrop-filter: blur(4px);
}
.modal-backdrop.show { 
  display: flex;
  align-items: center; 
  justify-content: center; 
}
    .modal-box { background:white; border-radius:20px; padding:32px; max-width:460px; width:90%; box-shadow:0 20px 60px rgba(0,0,0,.2); }
    .modal-icon-wrap { width:64px; height:64px; border-radius:50%; background:#fef2f2; color:#dc2626; display:flex; align-items:center; justify-content:center; font-size:28px; margin:0 auto 18px; }
    .modal-title { font-size:20px; font-weight:800; color:#1a202c; text-align:center; margin-bottom:6px; }
    .modal-sub   { font-size:14px; color:#64748b; text-align:center; margin-bottom:20px; }
    .refund-preview { background:#f8fafc; border-radius:10px; padding:14px 16px; margin-bottom:20px; }
    .refund-row { display:flex; justify-content:space-between; font-size:13px; color:#374151; padding:4px 0; }
    .refund-row strong { color:#1a202c; }
    .refund-row.total { border-top:1px solid #e2e8f0; margin-top:6px; padding-top:10px; font-weight:800; font-size:14px; }
    textarea.form-control { width:100%; padding:10px 14px; border:1.5px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:inherit; resize:vertical; min-height:80px; outline:none; margin-bottom:16px; }
    textarea.form-control:focus { border-color:#203f6a; }
    .modal-btns { display:flex; gap:12px; }
    .btn-modal-cancel  { flex:1; padding:12px; border-radius:10px; border:none; background:#e2e8f0; color:#4a5568; font-weight:700; cursor:pointer; font-family:inherit; }
    .btn-modal-confirm { flex:1; padding:12px; border-radius:10px; border:none; background:#dc2626; color:white; font-weight:700; cursor:pointer; font-family:inherit; transition:background .2s; }
    .btn-modal-confirm:hover { background:#b91c1c; }
    .btn-modal-confirm:disabled { background:#94a3b8; cursor:not-allowed; }

    @media (max-width:900px)  { .stats-row { grid-template-columns:repeat(2,1fr); } .appt-card { grid-template-columns:50px 1fr; } .appt-right { display:none; } }
    @media (max-width:768px)  { .main-content { margin-left:70px; } }
  </style>
</head>
<body>

<%- include('../partials/patient-sidebar', { currentPage: 'appointments' }) %>

<div class="main-content">
  <div class="top-bar">
    <h1 class="page-title">My Appointments</h1>
    <button class="user-profile-btn">
      <div class="user-avatar-small"><%= user.name.charAt(0).toUpperCase() %></div>
      <span class="user-name">Hello <%= user.name.split(' ')[0] %></span>
    </button>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon total"><i class="fas fa-calendar-alt"></i></div>
      <div class="stat-info">
        <strong><%= total %></strong>
        <span>Total</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon confirmed"><i class="fas fa-check-circle"></i></div>
      <div class="stat-info">
        <strong><%= appointments.filter(a => a.status === 'confirmed').length %></strong>
        <span>Confirmed</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon pending"><i class="fas fa-clock"></i></div>
      <div class="stat-info">
        <strong><%= appointments.filter(a => a.status === 'pending').length %></strong>
        <span>Pending</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon cancelled"><i class="fas fa-times-circle"></i></div>
      <div class="stat-info">
        <strong><%= appointments.filter(a => a.status === 'cancelled').length %></strong>
        <span>Cancelled</span>
      </div>
    </div>
  </div>

  <!-- Filter Tabs -->
  <div class="filter-tabs">
    <a href="/patient/appointments" class="filter-tab <%= selectedStatus === 'all' ? 'active' : '' %>">All</a>
    <a href="/patient/appointments?status=pending"   class="filter-tab <%= selectedStatus === 'pending'   ? 'active' : '' %>">Pending</a>
    <a href="/patient/appointments?status=confirmed" class="filter-tab <%= selectedStatus === 'confirmed' ? 'active' : '' %>">Confirmed</a>
    <a href="/patient/appointments?status=completed" class="filter-tab <%= selectedStatus === 'completed' ? 'active' : '' %>">Completed</a>
    <a href="/patient/appointments?status=cancelled" class="filter-tab <%= selectedStatus === 'cancelled' ? 'active' : '' %>">Cancelled</a>
  </div>

  <!-- Appointments List -->
  <% if (appointments.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-calendar-times"></i>
      <h4>No appointments found</h4>
      <p><%= selectedStatus === 'all' ? "You haven't booked any appointments yet." : `No ${selectedStatus} appointments.` %></p>
      <a href="/patient/doctors" class="btn-primary">
        <i class="fas fa-search"></i> Find a Doctor
      </a>
    </div>
  <% } else { %>
    <div class="appointments-list">
      <% appointments.forEach(appt => { %>
        <div class="appt-card" id="appt-<%= appt._id %>">

          <!-- Avatar -->
          <% if (appt.doctor && appt.doctor.profileImage) { %>
            <img class="doc-avatar" src="<%= appt.doctor.profileImage %>" alt="">
          <% } else { %>
            <div class="doc-initials">
              <%= appt.doctor ? appt.doctor.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) : 'DR' %>
            </div>
          <% } %>

          <!-- Main info -->
          <div class="appt-main">
            <div class="appt-doctor">Dr. <%= appt.doctor ? appt.doctor.name : 'Unknown' %></div>
            <div class="appt-spec"><%= appt.doctor ? appt.doctor.specialization : '' %> · <%= appt.department %></div>
            <div class="appt-meta">
              <span class="meta-chip"><i class="fas fa-calendar"></i>
                <%= new Date(appt.date + 'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'}) %>
              </span>
              <span class="meta-chip"><i class="fas fa-clock"></i> <%= appt.timeSlot %></span>
              <span class="meta-chip">
                <i class="fas fa-<%= appt.paymentMethod === 'cash' ? 'money-bill-wave' : appt.paymentMethod === 'wallet' ? 'wallet' : 'credit-card' %>"></i>
                <%= appt.paymentMethod === 'cash' ? 'Cash' : appt.paymentMethod === 'wallet' ? 'Wallet' : 'Online' %>
              </span>
              <% if (appt.reason) { %>
                <span class="meta-chip"><i class="fas fa-notes-medical"></i> <%= appt.reason.substring(0,30) %><%= appt.reason.length > 30 ? '...' : '' %></span>
              <% } %>
            </div>
            <% if (appt.status === 'cancelled' && appt.refundAmount > 0) { %>
              <div style="margin-top:8px;">
                <span class="refund-info">
                  <i class="fas fa-undo"></i>
                  Refund: ₹<%= appt.refundAmount %> (<%= appt.refundPercentage %>%) — <%= appt.refundStatus %>
                </span>
              </div>
            <% } %>
          </div>

          <!-- Right side -->
          <div class="appt-right">
            <span class="status-badge <%= appt.status %>"><%= appt.status %></span>
            <div class="appt-fee">₹<%= appt.consultationFee %></div>
            <div class="appt-actions">
              <a href="/patient/appointments/<%= appt._id %>/success" class="btn-sm btn-view">
                <i class="fas fa-eye"></i> View
              </a>
              <%
  const [slotHour, slotMin] = appt.timeSlot.split(':').map(Number);
  const apptDateTime = new Date(appt.date);
  apptDateTime.setHours(slotHour, slotMin, 0, 0);
  const isPast = apptDateTime < new Date();
%>
<% if (['pending','confirmed'].includes(appt.status) && !isPast) { %>
  <button class="btn-sm btn-cancel"
          data-id="<%= appt._id %>"
          data-doctor="<%= appt.doctor ? appt.doctor.name : 'Unknown' %>"
          data-date="<%= appt.date %>"
          data-slot="<%= appt.timeSlot %>"
          data-fee="<%= appt.consultationFee %>"
          data-method="<%= appt.paymentMethod %>"
          onclick="openCancelModal(this)">
    Cancel
  </button>
<% } else if (['pending','confirmed'].includes(appt.status) && isPast) { %>
  <button class="btn-sm" style="background:#f1f5f9;color:#94a3b8;cursor:not-allowed;" disabled>
    Expired
  </button>
<% } %>
            </div>
          </div>

        </div>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <%- include('../partials/pagination', { currentPage, totalPages, selectedStatus }) %>
    <% } %>
  <% } %>
</div>

<!-- Cancel Modal -->
<div class="modal-backdrop" id="cancelModal">
  <div class="modal-box">
    <div class="modal-icon-wrap"><i class="fas fa-times-circle"></i></div>
    <div class="modal-title">Cancel Appointment</div>
    <div class="modal-sub" id="cancelModalSub">Are you sure you want to cancel this appointment?</div>

    <div class="refund-preview" id="refundPreview"></div>

    <textarea class="form-control" id="cancelReason" placeholder="Reason for cancellation (optional)"></textarea>

    <div class="modal-btns">
      <button class="btn-modal-cancel" onclick="closeCancelModal()">Keep Appointment</button>
      <button class="btn-modal-confirm" id="confirmCancelBtn" onclick="confirmCancel()">Cancel Appointment</button>
    </div>
  </div>
</div>

<!-- Logout Modal -->
<div class="modal-backdrop" id="logoutModal">
  <div class="modal-box" style="max-width:420px;">
    <div class="modal-icon-wrap"><i class="fas fa-sign-out-alt"></i></div>
    <div class="modal-title">Confirm Logout</div>
    <div class="modal-sub">Are you sure you want to logout?</div>
    <div class="modal-btns">
      <button class="btn-modal-cancel" onclick="closeLogoutModal()">Cancel</button>
      <button onclick="confirmLogout()" style="flex:1;padding:12px;border-radius:10px;border:none;background:#203f6a;color:white;font-weight:700;cursor:pointer;font-family:inherit;">Logout</button>
    </div>
  </div>
</div>

<script>
  let cancelTargetId = null;

  function openCancelModal(btn) {
  const id            = btn.dataset.id;
  const doctorName    = btn.dataset.doctor;
  const date          = btn.dataset.date;
  const timeSlot      = btn.dataset.slot;
  const fee           = parseFloat(btn.dataset.fee);
  const paymentMethod = btn.dataset.method;
  const apptDateTimeStr = date + 'T' + timeSlot + ':00';

  cancelTargetId = id;

  // Calculate refund
  const hoursUntil = (new Date(apptDateTimeStr) - new Date()) / (1000 * 60 * 60);

  let refundPercent, refundNote;
  if (hoursUntil >= 12) {
    refundPercent = 90;
    refundNote    = '90% refund';
  } else {
    refundPercent = 0;
    refundNote    = 'No refund — less than 12 hours before appointment';
  }

  const refundAmount = paymentMethod === 'cash' ? 0 : Math.round(fee * refundPercent / 100);

  const payLabel = paymentMethod === 'cash'
    ? 'No refund (cash payment)'
    : paymentMethod === 'wallet'
      ? `₹${refundAmount} → Healora Wallet`
      : `₹${refundAmount} → Original payment method`;

  const dateLabel = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
    weekday: 'long', month: 'long', day: 'numeric'
  });

  document.getElementById('cancelModalSub').textContent =
    `Dr. ${doctorName} · ${dateLabel} at ${timeSlot}`;

  document.getElementById('refundPreview').innerHTML = `
    <div class="refund-row"><span>Consultation Fee</span><strong>₹${fee}</strong></div>
    <div class="refund-row"><span>Refund Policy</span><strong>${refundNote}</strong></div>
    <div class="refund-row total">
      <span>Refund Amount</span>
      <strong>${paymentMethod === 'cash' ? '₹0 (0%)' : `₹${refundAmount} (${refundPercent}%)`}</strong>
    </div>
    <div class="refund-row" style="font-size:12px;color:#64748b;">
      <span>Refund to</span><span>${payLabel}</span>
    </div>
  `;

  document.getElementById('cancelReason').value = '';
  document.getElementById('cancelModal').classList.add('show');
}

  function closeCancelModal() {
    document.getElementById('cancelModal').classList.remove('show');
    cancelTargetId = null;
  }

  async function confirmCancel() {
    if (!cancelTargetId) return;

    const btn    = document.getElementById('confirmCancelBtn');
    const reason = document.getElementById('cancelReason').value.trim();

    btn.disabled    = true;
    btn.textContent = 'Cancelling...';

    try {
      const res  = await fetch(`/patient/appointments/${cancelTargetId}/cancel`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ reason })
      });
      const data = await res.json();

      if (data.success) {
        closeCancelModal();
        // Remove card from DOM and reload to refresh stats
        window.location.reload();
      } else {
        alert(data.error || 'Failed to cancel appointment');
        btn.disabled    = false;
        btn.textContent = 'Cancel Appointment';
      }
    } catch (err) {
      alert('Something went wrong. Please try again.');
      btn.disabled    = false;
      btn.textContent = 'Cancel Appointment';
    }
  }

  function showLogoutModal()  { document.getElementById('logoutModal').classList.add('show'); }
  function closeLogoutModal() { document.getElementById('logoutModal').classList.remove('show'); }
  function confirmLogout() {
    fetch('/patient/logout', { method: 'POST' })
      .then(() => window.location.href = '/patient/login')
      .catch(() => window.location.href = '/patient/login');
  }
</script>
</body>
</html>
