<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/Logo-browser.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; }
    .page-hero { background: linear-gradient(135deg, #0D3D8F 0%, #1A6FD4 100%); padding: 56px 0 40px; color: white; text-align: center; }
    .page-hero h1 { font-size: 36px; font-weight: 800; margin-bottom: 10px; }
    .page-hero p  { font-size: 15px; color: rgba(255,255,255,.75); }
    .breadcrumb-hero { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,.6); margin-top: 12px; }
    .breadcrumb-hero a { color: rgba(255,255,255,.75); text-decoration: none; }

    .depts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px; padding: 40px 0;
    }
    .dept-card {
      background: white; border-radius: 16px;
      border: 1.5px solid #e4eaf3;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
      overflow: hidden;
      transition: transform .2s, box-shadow .2s;
    }
    .dept-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(20,89,200,.12); }

    .dept-card-head {
      background: linear-gradient(135deg, #0D3D8F, #1A6FD4);
      padding: 20px; color: white;
      display: flex; align-items: center; gap: 14px;
    }
    .dept-icon {
      width: 46px; height: 46px; border-radius: 12px;
      background: rgba(255,255,255,.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .dept-name  { font-size: 16px; font-weight: 800; }
    .dept-count { font-size: 12px; color: rgba(255,255,255,.7); margin-top: 2px; }

    .dept-card-body { padding: 16px; }
    .dept-doctors { display: flex; flex-direction: column; gap: 10px; }

    .dept-doctor-row {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: 10px;
      background: #f8fafc; transition: background .15s;
    }
    .dept-doctor-row:hover { background: #E8F0FD; }

    .dept-doc-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: linear-gradient(135deg, #1459C8, #0D3D8F);
      color: white; font-size: 12px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; flex-shrink: 0;
    }
    .dept-doc-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
    .dept-doc-name { font-size: 12px; font-weight: 700; color: #0B1120; }
    .dept-doc-spec { font-size: 11px; color: #94a3b8; }

    .dept-more {
      font-size: 12px; font-weight: 600; color: #1459C8;
      padding: 6px 10px; text-align: center; margin-top: 4px;
    }

    .dept-card-footer {
      padding: 12px 16px;
      border-top: 1px solid #f1f5f9;
    }
    .btn-view-dept {
      display: block; width: 100%; padding: 9px;
      background: #E8F0FD; color: #1459C8;
      border: none; border-radius: 8px;
      font-size: 12px; font-weight: 700;
      text-align: center; text-decoration: none;
      font-family: inherit; cursor: pointer;
      transition: background .15s;
    }
    .btn-view-dept:hover { background: #1459C8; color: white; }

    .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
    .empty-state i { font-size: 40px; color: #e2e8f0; display: block; margin-bottom: 12px; }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-hero">
  <h1>Our Departments</h1>
  <p>Specialized care across every medical discipline</p>
  <div class="breadcrumb-hero">
    <a href="/">Home</a>
    <i class="fas fa-chevron-right" style="font-size:10px;"></i>
    <span>Departments</span>
  </div>
</div>

<div class="container">
  <% if (departments.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-building"></i>
      <p>No departments available yet.</p>
    </div>
  <% } else { %>
    <div class="depts-grid">
      <% departments.forEach(dept => { %>
        <div class="dept-card">
          <div class="dept-card-head">
            <div class="dept-icon"><i class="fas fa-stethoscope"></i></div>
            <div>
              <div class="dept-name"><%= dept._id %></div>
              <div class="dept-count"><%= dept.count %> Doctor<%= dept.count !== 1 ? 's' : '' %></div>
            </div>
          </div>
          <div class="dept-card-body">
            <div class="dept-doctors">
              <% dept.doctors.slice(0, 3).forEach(doc => { %>
                <div class="dept-doctor-row">
                  <div class="dept-doc-avatar">
                    <% if (doc.profileImage) { %>
                      <img src="<%= doc.profileImage %>" alt="">
                    <% } else { %>
                      <%= doc.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
                    <% } %>
                  </div>
                  <div>
                    <div class="dept-doc-name">Dr. <%= doc.name %></div>
                    <div class="dept-doc-spec"><%= doc.specialization %></div>
                  </div>
                </div>
              <% }) %>
              <% if (dept.count > 3) { %>
                <div class="dept-more">+<%= dept.count - 3 %> more doctor<%= dept.count - 3 !== 1 ? 's' : '' %></div>
              <% } %>
            </div>
          </div>
          <div class="dept-card-footer">
            <a href="/doctors?department=<%= encodeURIComponent(dept._id) %>" class="btn-view-dept">
              View All Doctors <i class="fas fa-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
