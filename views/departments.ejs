<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/logo.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --blue:     #1250b0;
      --blue-mid: #1a6fd4;
      --sky:      #0ea5d4;
      --navy:     #071730;
      --ink:      #0f1f3d;
      --slate:    #475569;
      --muted:    #94a3b8;
      --border:   #e2e8f0;
      --surface:  #f8fafd;
      --white:    #ffffff;
      --accent:   #05c8a4;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Sora', sans-serif;
      background: var(--surface);
      color: var(--ink);
      overflow-x: hidden;
    }

    /* ── HERO ── */
    .page-hero {
      position: relative;
      background: var(--navy);
      padding: 110px 0 72px;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 56px 56px;
    }

    .page-hero::after {
      content: '';
      position: absolute;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(26,111,212,.3) 0%, transparent 70%);
      top: -180px; right: -120px;
      pointer-events: none;
    }

    .hero-inner {
      position: relative; z-index: 2;
      display: flex; flex-direction: column; align-items: flex-start;
    }

    .hero-pill {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.13);
      color: var(--accent);
      padding: 6px 16px; border-radius: 40px;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 1.2px;
      margin-bottom: 22px;
    }

    .hero-title {
      font-family: 'Lora', serif;
      font-size: clamp(2.1rem, 4.5vw, 3.4rem);
      font-weight: 500; color: var(--white);
      line-height: 1.15; margin-bottom: 14px;
    }

    .hero-title em { font-style: italic; color: var(--sky); }

    .hero-sub {
      font-size: 14.5px; color: rgba(255,255,255,.55);
      line-height: 1.8; font-weight: 300;
      max-width: 460px; margin-bottom: 28px;
    }

    .hero-breadcrumb {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px; color: rgba(255,255,255,.38);
    }
    .hero-breadcrumb a { color: rgba(255,255,255,.55); text-decoration: none; transition: color .2s; }
    .hero-breadcrumb a:hover { color: var(--white); }
    .hero-breadcrumb i { font-size: 8px; opacity: .7; }

    /* ── STATS BAR ── */
    .stats-wrap {
      margin-top: -36px;
      position: relative; z-index: 10;
    }

    .stats-bar {
      background: var(--white);
      border-radius: 16px;
      box-shadow: 0 16px 48px rgba(7,23,48,.11), 0 1px 0 var(--border);
      overflow: hidden;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }

    .stat-cell {
      padding: 26px 20px;
      text-align: center;
      border-right: 1px solid var(--border);
    }

    .stat-cell:last-child { border-right: none; }

    .stat-num {
      font-family: 'Lora', serif;
      font-size: 2rem; font-weight: 500;
      color: var(--blue); line-height: 1;
      margin-bottom: 5px;
    }

    .stat-lbl {
      font-size: 11px; font-weight: 600;
      color: var(--muted); text-transform: uppercase;
      letter-spacing: .7px;
    }

    /* ── SEARCH + FILTER BAR ── */
    .filter-bar {
      padding: 36px 0 8px;
      display: flex; align-items: center;
      justify-content: space-between;
      gap: 14px; flex-wrap: wrap;
    }

    .search-box {
      position: relative; flex: 1; min-width: 220px; max-width: 360px;
    }

    .search-box i {
      position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%);
      color: var(--muted); font-size: 13px;
      pointer-events: none;
    }

    .search-input {
      width: 100%; padding: 11px 14px 11px 40px;
      border: 1.5px solid var(--border); border-radius: 10px;
      font-size: 13px; font-family: 'Sora', sans-serif;
      color: var(--ink); background: var(--white); outline: none;
      transition: border-color .2s, box-shadow .2s;
    }

    .search-input::placeholder { color: var(--muted); font-weight: 300; }
    .search-input:focus {
      border-color: var(--blue-mid);
      box-shadow: 0 0 0 3px rgba(26,111,212,.09);
    }

    .filter-count {
      font-size: 13px; color: var(--muted); font-weight: 400;
      white-space: nowrap;
    }

    .filter-count strong { color: var(--ink); font-weight: 700; }

    /* ── DEPARTMENTS GRID ── */
    .depts-section { padding: 20px 0 80px; }

    .depts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    /* ── DEPARTMENT CARD ── */
    .dept-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      display: flex; flex-direction: column;
      transition: border-color .22s, box-shadow .22s, transform .22s;
    }

    .dept-card:hover {
      border-color: var(--blue-mid);
      box-shadow: 0 12px 36px rgba(18,80,176,.1);
      transform: translateY(-4px);
    }

    /* Card header */
    .dept-head {
      padding: 22px 20px 18px;
      display: flex; align-items: flex-start; gap: 14px;
      border-bottom: 1px solid var(--border);
    }

    .dept-icon-wrap {
      width: 48px; height: 48px; border-radius: 12px;
      background: #e8f1fb; color: var(--blue-mid);
      display: flex; align-items: center; justify-content: center;
      font-size: 19px; flex-shrink: 0;
    }

    .dept-name {
      font-size: 15px; font-weight: 700;
      color: var(--ink); line-height: 1.25;
      margin-bottom: 4px;
    }

    .dept-badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 600;
      color: var(--blue-mid);
      background: #e8f1fb;
      padding: 3px 10px; border-radius: 20px;
    }

    /* Doctors list */
    .dept-body { padding: 14px 16px; flex: 1; }

    .doc-row {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: 9px;
      transition: background .15s; cursor: default;
    }

    .doc-row:hover { background: var(--surface); }

    .doc-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: linear-gradient(135deg, var(--blue), var(--sky));
      color: var(--white); font-size: 11px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; flex-shrink: 0;
    }

    .doc-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .doc-name { font-size: 12.5px; font-weight: 600; color: var(--ink); }
    .doc-spec { font-size: 11px; color: var(--muted); margin-top: 1px; }

    .doc-more {
      padding: 6px 10px; text-align: center;
      font-size: 12px; font-weight: 600; color: var(--blue-mid);
    }

    /* Card footer */
    .dept-footer {
      padding: 12px 16px 16px;
      border-top: 1px solid var(--border);
    }

    .btn-view {
      display: flex; align-items: center; justify-content: center; gap: 7px;
      width: 100%; padding: 10px;
      background: var(--surface); color: var(--blue);
      border: 1.5px solid var(--border); border-radius: 9px;
      font-size: 12.5px; font-weight: 700;
      font-family: 'Sora', sans-serif;
      text-decoration: none; cursor: pointer;
      transition: background .18s, border-color .18s, color .18s;
    }

    .btn-view:hover {
      background: var(--blue);
      border-color: var(--blue);
      color: var(--white);
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      grid-column: 1 / -1;
      text-align: center; padding: 80px 20px;
    }

    .empty-icon {
      width: 72px; height: 72px; border-radius: 50%;
      background: #e8f1fb; color: var(--blue-mid);
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; margin: 0 auto 20px;
    }

    .empty-title {
      font-family: 'Lora', serif;
      font-size: 1.3rem; font-weight: 500; color: var(--ink);
      margin-bottom: 8px;
    }

    .empty-sub { font-size: 13.5px; color: var(--muted); font-weight: 300; }

    /* ── NO SEARCH RESULTS ── */
    #noResults {
      display: none;
      grid-column: 1 / -1;
      text-align: center; padding: 60px 20px;
    }

    /* ── RESPONSIVE ── */

    /* Tablet: 2 columns */
    @media (max-width: 1024px) {
      .depts-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* Large mobile */
    @media (max-width: 767px) {
      .page-hero { padding: 90px 0 56px; }
      .hero-title { font-size: 1.9rem; }
      .stats-grid { grid-template-columns: repeat(3, 1fr); }
      .stat-cell { padding: 20px 12px; }
      .stat-num { font-size: 1.5rem; }
      .depts-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
      .filter-bar { flex-direction: column; align-items: stretch; }
      .search-box { max-width: 100%; }
    }

    /* Small mobile: 1 column */
    @media (max-width: 480px) {
      .depts-grid { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: repeat(3, 1fr); }
      .stat-num { font-size: 1.3rem; }
      .stat-lbl { font-size: 9.5px; }
      .dept-head { padding: 18px 16px 14px; }
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<!-- ── Hero ── -->
<section class="page-hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-pill">
        <i class="fas fa-building-columns"></i> Medical Departments
      </div>
      <h1 class="hero-title">
        Specialized care across<br><em>every discipline</em>
      </h1>
      <p class="hero-sub">
        Our departments bring together world-class specialists, advanced equipment,
        and compassionate teams — all under one roof.
      </p>
      <div class="hero-breadcrumb">
        <a href="/"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <span>Departments</span>
      </div>
    </div>
  </div>
</section>

<!-- ── Stats ── -->
<div class="container stats-wrap">
  <div class="stats-bar">
    <div class="stats-grid">
      <div class="stat-cell">
        <div class="stat-num"><%= departments.length %></div>
        <div class="stat-lbl">Departments</div>
      </div>
      <div class="stat-cell">
        <div class="stat-num"><%= departments.reduce((s,d) => s + d.count, 0) %>+</div>
        <div class="stat-lbl">Specialists</div>
      </div>
      <div class="stat-cell">
        <div class="stat-num">24/7</div>
        <div class="stat-lbl">Emergency</div>
      </div>
    </div>
  </div>
</div>

<!-- ── Departments ── -->
<div class="container depts-section">

  <% if (departments.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon"><i class="fas fa-building"></i></div>
      <div class="empty-title">No departments yet</div>
      <p class="empty-sub">Departments will appear here once they are added.</p>
    </div>

  <% } else { %>

    <!-- Filter bar -->
    <div class="filter-bar">
      <div class="search-box">
        <i class="fas fa-search"></i>
        <input
          type="text"
          class="search-input"
          id="deptSearch"
          placeholder="Search departments or doctors…"
          oninput="filterDepts()"
        >
      </div>
      <div class="filter-count" id="deptCount">
        Showing <strong><%= departments.length %></strong> department<%= departments.length !== 1 ? 's' : '' %>
      </div>
    </div>

    <div class="depts-grid" id="deptsGrid">

      <% departments.forEach(dept => { %>
        <div class="dept-card" data-name="<%= dept._id.toLowerCase() %>" data-doctors="<%= dept.doctors.map(d=>d.name.toLowerCase()).join(' ') %>">

          <!-- Head -->
          <div class="dept-head">
            <div class="dept-icon-wrap">
              <i class="fas fa-stethoscope"></i>
            </div>
            <div>
              <div class="dept-name"><%= dept._id %></div>
              <span class="dept-badge">
                <i class="fas fa-user-md"></i>
                <%= dept.count %> Doctor<%= dept.count !== 1 ? 's' : '' %>
              </span>
            </div>
          </div>

          <!-- Doctors list -->
          <div class="dept-body">
            <% dept.doctors.slice(0, 3).forEach(doc => { %>
              <div class="doc-row">
                <div class="doc-avatar">
                  <% if (doc.profileImage) { %>
                    <img src="<%= doc.profileImage %>" alt="<%= doc.name %>">
                  <% } else { %>
                    <%= doc.name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) %>
                  <% } %>
                </div>
                <div>
                  <div class="doc-name">Dr. <%= doc.name %></div>
                  <div class="doc-spec"><%= doc.specialization %></div>
                </div>
              </div>
            <% }) %>
            <% if (dept.count > 3) { %>
              <div class="doc-more">+<%= dept.count - 3 %> more doctor<%= dept.count - 3 !== 1 ? 's' : '' %></div>
            <% } %>
          </div>

          <!-- Footer -->
          <div class="dept-footer">
            <a href="/doctors?department=<%= encodeURIComponent(dept._id) %>" class="btn-view">
              View All Doctors <i class="fas fa-arrow-right"></i>
            </a>
          </div>

        </div>
      <% }) %>

      <!-- No search results placeholder -->
      <div id="noResults">
        <div class="empty-icon" style="margin:0 auto 16px;"><i class="fas fa-search"></i></div>
        <div class="empty-title">No departments found</div>
        <p class="empty-sub">Try a different department name or doctor name.</p>
      </div>

    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function filterDepts() {
    const q = document.getElementById('deptSearch').value.trim().toLowerCase();
    const cards = document.querySelectorAll('.dept-card');
    let visible = 0;

    cards.forEach(card => {
      const nameMatch   = card.dataset.name.includes(q);
      const doctorMatch = card.dataset.doctors.includes(q);
      const show = !q || nameMatch || doctorMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // update count label
    const countEl = document.getElementById('deptCount');
    if (countEl) {
      countEl.innerHTML = `Showing <strong>${visible}</strong> department${visible !== 1 ? 's' : ''}`;
    }

    // show/hide no-results
    const noRes = document.getElementById('noResults');
    if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
  }
</script>
</body>
</html>
