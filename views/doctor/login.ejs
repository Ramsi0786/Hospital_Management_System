<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Doctor Login | Healora</title>
  <link href="/images/test.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --navy:  #071730;
      --teal:  #1a7f8e;
      --white: #ffffff;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.023) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.023) 1px, transparent 1px);
      background-size: 52px 52px;
      pointer-events: none;
    }

    .orb-1 {
      position: absolute;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(26,127,142,.18) 0%, transparent 70%);
      top: -180px; right: -120px;
      pointer-events: none;
    }

    .orb-2 {
      position: absolute;
      width: 380px; height: 380px; border-radius: 50%;
      background: radial-gradient(circle, rgba(18,80,176,.15) 0%, transparent 70%);
      bottom: -140px; left: -100px;
      pointer-events: none;
    }

    .login-box {
      position: relative; z-index: 2;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 22px;
      padding: 44px 40px 40px;
      width: 100%; max-width: 460px;
      animation: fadeUp .5s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Logo */
    .brand {
      display: flex;
      justify-content: center;
      margin-bottom: 28px;
      text-decoration: none;
    }

    .brand img {
      height: 60px;
      width: auto;
      filter: brightness(0) invert(1);
    }

    /* Icon circle */
    .icon-circle {
      width: 64px; height: 64px;
      background: rgba(26,127,142,.15);
      border: 1px solid rgba(26,127,142,.3);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
      color: var(--teal);
      font-size: 26px;
    }

    h2 {
      font-size: 24px;
      font-weight: 800;
      color: var(--white);
      text-align: center;
      margin-bottom: 6px;
      letter-spacing: -0.3px;
    }

    .subtitle {
      font-size: 13.5px;
      color: rgba(255,255,255,.42);
      text-align: center;
      font-weight: 300;
      margin-bottom: 32px;
    }

    /* Form */
    .form-group { margin-bottom: 14px; }

    .form-control {
      width: 100%;
      padding: 13px 18px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 12px;
      color: var(--white);
      font-size: 14px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      transition: border-color .2s, background .2s;
      outline: none;
    }

    .form-control::placeholder { color: rgba(255,255,255,.3); }

    .form-control:focus {
      border-color: rgba(26,127,142,.6);
      background: rgba(255,255,255,.09);
    }

    .password-wrapper { position: relative; }

    .password-wrapper .form-control { padding-right: 46px; }

    .toggle-password {
      position: absolute;
      right: 16px; top: 35%;
      transform: translateY(-50%);
      color: rgba(255,255,255,.35);
      cursor: pointer;
      font-size: 15px;
      transition: color .2s;
    }

    .toggle-password:hover { color: var(--teal); }

    /* Error messages */
    .error-msg {
      color: #f87171;
      font-size: 12px;
      margin-top: 5px;
      min-height: 16px;
      display: block;
    }

    /* Forgot password */
    .forgot-link {
      display: block;
      text-align: right;
      font-size: 12.5px;
      color: var(--teal);
      text-decoration: none;
      font-weight: 600;
      margin-bottom: 22px;
      transition: opacity .2s;
    }

    .forgot-link:hover { opacity: .75; }

    /* Submit button */
    .btn-submit {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--teal), #0f6b7a);
      border: none;
      border-radius: 12px;
      color: var(--white);
      font-size: 15px;
      font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      cursor: pointer;
      transition: transform .2s, box-shadow .2s, opacity .2s;
      box-shadow: 0 8px 24px rgba(26,127,142,.3);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(26,127,142,.4);
    }

    .btn-submit:active { transform: translateY(0); }

    .btn-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }

    /* Server messages */
    #serverError {
      background: rgba(248,113,113,.1);
      border: 1px solid rgba(248,113,113,.3);
      border-radius: 10px;
      color: #f87171;
      font-size: 13px;
      padding: 10px 14px;
      margin-bottom: 16px;
      display: none;
    }

    #successMessage {
      background: rgba(26,127,142,.12);
      border: 1px solid rgba(26,127,142,.3);
      border-radius: 10px;
      color: #5eead4;
      font-size: 13px;
      padding: 10px 14px;
      margin-bottom: 16px;
      display: none;
    }

    /* Back link */
    .back-link {
      text-align: center;
      margin-top: 24px;
      font-size: 12.5px;
      color: rgba(255,255,255,.25);
    }

    .back-link a {
      color: rgba(255,255,255,.45);
      text-decoration: none;
      font-weight: 600;
      transition: color .2s;
    }

    .back-link a:hover { color: var(--white); }

    @media (max-width: 480px) {
      .login-box { padding: 36px 24px 32px; }
      h2 { font-size: 21px; }
    }
  </style>
</head>
<body>

  <div class="orb-1"></div>
  <div class="orb-2"></div>

  <div class="login-box">

    <div class="icon-circle">
      <i class="fas fa-user-md"></i>
    </div>

    <h2>Doctor Login</h2>
    <p class="subtitle">Secure access to your doctor dashboard</p>

    <div id="serverError"></div>
    <div id="successMessage"></div>

    <form id="doctorLoginForm" novalidate>

      <div class="form-group">
        <input type="email" id="email" name="email"
               class="form-control" placeholder="Email Address"
               required autocomplete="username" autofocus>
        <span class="error-msg" id="errorEmail"></span>
      </div>

      <div class="form-group password-wrapper">
        <input type="password" id="password" name="password"
               class="form-control" placeholder="Password"
               required autocomplete="current-password">
        <i class="fas fa-eye toggle-password" id="togglePassword"></i>
        <span class="error-msg" id="errorPassword"></span>
      </div>

      <a href="/doctor/forgot-password" class="forgot-link">Forgot Password?</a>

      <button type="submit" class="btn-submit">
        <i class="fas fa-sign-in-alt"></i> Sign In
      </button>

    </form>

    <p class="back-link">
      <a href="/login">← Back to role selection</a>
    </p>

  </div>

  <script src="/js/formValidation.js"></script>
  <script>
    FormValidator.handleFormSubmit(
      'doctorLoginForm',
      '/doctor/login',
      'login',
      {
        onSuccess: (result) => {
          const s = document.getElementById('successMessage');
          s.style.display = 'block';
          s.textContent = 'Login successful! Redirecting...';
          setTimeout(() => { window.location.href = result.redirect; }, 1000);
        }
      }
    );
    FormValidator.setupPasswordToggle('password', 'togglePassword');
  </script>
</body>
</html>