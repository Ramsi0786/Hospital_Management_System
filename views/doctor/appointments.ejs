<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:#f1f5f9; min-height:100vh; }
    .main-content { margin-left:230px; padding:30px; min-height:100vh; }

    .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; }
    .page-title { font-size:26px; font-weight:800; color:#1a202c; }
    .user-profile { display:flex; align-items:center; gap:10px; background:white; padding:8px 16px; border-radius:50px; box-shadow:0 2px 8px rgba(0,0,0,.08); }
    .user-avatar { width:35px; height:35px; border-radius:50%; background:#203f6a; color:white; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; overflow:hidden; }
    .user-avatar img { width:100%; height:100%; object-fit:cover; }
    .user-avatar-name { font-size:14px; font-weight:600; color:#2d3748; }

    /* Stats */
    .stats-row { display:grid; grid-template-columns:repeat(5,1fr); gap:16px; margin-bottom:28px; }
    .stat-card { background:white; border-radius:14px; padding:16px 18px; box-shadow:0 2px 12px rgba(0,0,0,.06); display:flex; align-items:center; gap:12px; }
    .stat-icon { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
    .stat-icon.total     { background:#eff6ff; color:#2563eb; }
    .stat-icon.pending   { background:#fffbeb; color:#d97706; }
    .stat-icon.confirmed { background:#ecfdf5; color:#059669; }
    .stat-icon.completed { background:#f0f9ff; color:#0369a1; }
    .stat-icon.cancelled { background:#fef2f2; color:#dc2626; }
    .stat-info strong { font-size:20px; font-weight:800; color:#1a202c; display:block; }
    .stat-info span   { font-size:12px; color:#94a3b8; font-weight:600; }

    /* Filter tabs */
    .filter-tabs { display:flex; gap:8px; margin-bottom:24px; flex-wrap:wrap; }
    .filter-tab { padding:8px 18px; border-radius:20px; border:2px solid #e2e8f0; background:white; font-size:13px; font-weight:700; color:#64748b; text-decoration:none; transition:all .2s; }
    .filter-tab:hover  { border-color:#93c5fd; color:#1d4ed8; }
    .filter-tab.active { background:#203f6a; border-color:#203f6a; color:white; }

    /* Empty state */
    .empty-state { text-align:center; padding:60px 20px; background:white; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.06); }
    .empty-state i  { font-size:52px; color:#cbd5e1; margin-bottom:16px; display:block; }
    .empty-state h4 { font-size:20px; font-weight:800; color:#1a202c; margin-bottom:8px; }
    .empty-state p  { color:#94a3b8; }

    /* Appointment cards */
    .appointments-list { display:flex; flex-direction:column; gap:14px; }
    .appt-card { background:white; border-radius:16px; padding:20px 24px; box-shadow:0 2px 12px rgba(0,0,0,.06); display:grid; grid-template-columns:56px 1fr auto; gap:18px; align-items:center; transition:box-shadow .2s; }
    .appt-card:hover { box-shadow:0 4px 20px rgba(0,0,0,.1); }

    .patient-avatar { width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,#203f6a,#1a7f8e); color:white; font-size:18px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; overflow:hidden; border:3px solid #e2e8f0; }
    .patient-avatar img { width:100%; height:100%; object-fit:cover; }

    .appt-main { min-width:0; }
    .appt-name { font-size:16px; font-weight:800; color:#1a202c; margin-bottom:2px; }
    .appt-sub  { font-size:13px; color:#64748b; margin-bottom:8px; }
    .appt-meta { display:flex; flex-wrap:wrap; gap:8px; }
    .meta-chip { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:600; color:#374151; background:#f8fafc; padding:4px 10px; border-radius:6px; }
    .meta-chip i { color:#203f6a; font-size:11px; }

    .appt-right { display:flex; flex-direction:column; align-items:flex-end; gap:10px; flex-shrink:0; }
    .appt-fee   { font-size:16px; font-weight:800; color:#203f6a; }
    .appt-actions { display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end; }

    /* Status badges */
    .status-badge { padding:5px 12px; border-radius:20px; font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.5px; }
    .status-badge.pending   { background:#fffbeb; color:#d97706; }
    .status-badge.confirmed { background:#ecfdf5; color:#059669; }
    .status-badge.completed { background:#eff6ff; color:#2563eb; }
    .status-badge.cancelled { background:#fef2f2; color:#dc2626; }

    /* Buttons */
    .btn-sm { padding:7px 14px; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; font-family:inherit; transition:all .2s; border:none; display:inline-flex; align-items:center; gap:5px; }
    .btn-view     { background:#eff6ff; color:#2563eb; }
    .btn-view:hover     { background:#2563eb; color:white; }
    .btn-confirm  { background:#ecfdf5; color:#059669; }
    .btn-confirm:hover  { background:#059669; color:white; }
    .btn-complete { background:#f0f9ff; color:#0369a1; }
    .btn-complete:hover { background:#0369a1; color:white; }
    .btn-cancel   { background:#fef2f2; color:#dc2626; }
    .btn-cancel:hover   { background:#dc2626; color:white; }

    /* Pagination */
    .pagination-row { display:flex; gap:8px; justify-content:center; margin-top:28px; }
    .page-btn { width:36px; height:36px; border-radius:8px; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; text-decoration:none; color:#64748b; background:white; border:1px solid #e2e8f0; transition:all .2s; }
    .page-btn:hover  { border-color:#203f6a; color:#203f6a; }
    .page-btn.active { background:#203f6a; color:white; border-color:#203f6a; }

    /* Modal */
    #healora-modal-root { position:fixed; inset:0; z-index:2147483647; pointer-events:none; font-family:'Plus Jakarta Sans',sans-serif; }
    #healora-modal-root.active { pointer-events:all; }
    .hm-backdrop { position:absolute; inset:0; background:rgba(8,18,38,.82); display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity .2s; }
    #healora-modal-root.active .hm-backdrop { opacity:1; }
    .hm-box { background:white; border-radius:20px; padding:32px; width:90%; max-width:460px; box-shadow:0 28px 72px rgba(8,18,38,.4); transform:translateY(16px) scale(.97); opacity:0; transition:transform .22s, opacity .22s; }
    #healora-modal-root.active .hm-box { transform:none; opacity:1; }
    .hm-icon { width:64px; height:64px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:26px; margin:0 auto 18px; }
    .hm-icon.blue  { background:#eff6ff; color:#203f6a; }
    .hm-icon.red   { background:#fef2f2; color:#dc2626; }
    .hm-icon.green { background:#ecfdf5; color:#059669; }
    .hm-title { font-size:20px; font-weight:800; color:#1a202c; text-align:center; margin-bottom:6px; }
    .hm-sub   { font-size:14px; color:#64748b; text-align:center; margin-bottom:20px; line-height:1.5; }
    .hm-detail-row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid #f8fafc; font-size:14px; }
    .hm-detail-row:last-of-type { border-bottom:none; }
    .hm-detail-row span:first-child { color:#64748b; }
    .hm-detail-row span:last-child  { color:#1a202c; font-weight:700; }
    .hm-btns { display:flex; gap:12px; margin-top:22px; }
    .hm-btn { flex:1; padding:12px; border-radius:10px; border:none; font-size:14px; font-weight:700; cursor:pointer; font-family:'Plus Jakarta Sans',sans-serif; transition:all .2s; }
    .hm-btn.gray  { background:#e2e8f0; color:#4a5568; }
    .hm-btn.gray:hover  { background:#cbd5e1; }
    .hm-btn.red   { background:#dc2626; color:white; }
    .hm-btn.red:hover   { background:#b91c1c; }
    .hm-btn.blue  { background:#203f6a; color:white; }
    .hm-btn.blue:hover  { background:#1a3456; }
    .hm-btn.green { background:#059669; color:white; }
    .hm-btn.green:hover { background:#047857; }
    .hm-btn:disabled { background:#94a3b8; cursor:not-allowed; }

    @media (max-width:1024px) { .stats-row { grid-template-columns:repeat(3,1fr); } }
    @media (max-width:768px)  { .main-content { margin-left:80px; } .appt-card { grid-template-columns:46px 1fr; } .appt-right { display:none; } }
  </style>
</head>
<body>

<%- include('../partials/doctor-sidebar', { currentPage: 'appointments' }) %>
<div id="healora-modal-root"></div>

<div class="main-content">

  <div class="top-bar">
    <h1 class="page-title">My Appointments</h1>
    <div class="user-profile">
      <div class="user-avatar">
        <% if (user.profileImage) { %><img src="<%= user.profileImage %>" alt=""><% } else { %><%= user.name.charAt(0).toUpperCase() %><% } %>
      </div>
      <span class="user-avatar-name">Dr. <%= user.name.split(' ')[0] %></span>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon total"><i class="fas fa-calendar-alt"></i></div>
      <div class="stat-info"><strong><%= stats.total %></strong><span>Total</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon pending"><i class="fas fa-clock"></i></div>
      <div class="stat-info"><strong><%= stats.pending %></strong><span>Pending</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon confirmed"><i class="fas fa-check-circle"></i></div>
      <div class="stat-info"><strong><%= stats.confirmed %></strong><span>Confirmed</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon completed"><i class="fas fa-check-double"></i></div>
      <div class="stat-info"><strong><%= stats.completed %></strong><span>Completed</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon cancelled"><i class="fas fa-times-circle"></i></div>
      <div class="stat-info"><strong><%= stats.cancelled %></strong><span>Cancelled</span></div>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="filter-tabs">
    <a href="/doctor/appointments"                  class="filter-tab <%= selectedStatus==='all'       ? 'active':'' %>">All</a>
    <a href="/doctor/appointments?status=pending"   class="filter-tab <%= selectedStatus==='pending'   ? 'active':'' %>">Pending</a>
    <a href="/doctor/appointments?status=confirmed" class="filter-tab <%= selectedStatus==='confirmed' ? 'active':'' %>">Confirmed</a>
    <a href="/doctor/appointments?status=completed" class="filter-tab <%= selectedStatus==='completed' ? 'active':'' %>">Completed</a>
    <a href="/doctor/appointments?status=cancelled" class="filter-tab <%= selectedStatus==='cancelled' ? 'active':'' %>">Cancelled</a>
  </div>

  <!-- List -->
  <% if (appointments.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-calendar-times"></i>
      <h4>No appointments found</h4>
      <p><%= selectedStatus === 'all' ? 'No appointments yet.' : `No ${selectedStatus} appointments.` %></p>
    </div>
  <% } else { %>
    <div class="appointments-list">
      <% appointments.forEach(appt => { %>
        <div class="appt-card" id="appt-<%= appt._id %>">

          <div class="patient-avatar">
            <% if (appt.patient?.profileImage) { %>
              <img src="<%= appt.patient.profileImage %>" alt="">
            <% } else { %>
              <%= appt.patient ? appt.patient.name.charAt(0).toUpperCase() : 'P' %>
            <% } %>
          </div>

          <div class="appt-main">
            <div class="appt-name"><%= appt.patient?.name || 'Unknown Patient' %></div>
            <div class="appt-sub"><%= appt.department || 'General' %> · <%= appt.patient?.phone || 'No phone' %></div>
            <div class="appt-meta">
              <span class="meta-chip"><i class="fas fa-calendar"></i> <%= new Date(appt.date+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'}) %></span>
              <span class="meta-chip"><i class="fas fa-clock"></i> <%= appt.timeSlot %></span>
              <span class="meta-chip"><i class="fas fa-<%= appt.paymentMethod==='cash'?'money-bill-wave':appt.paymentMethod==='wallet'?'wallet':'credit-card' %>"></i> <%= appt.paymentMethod==='cash'?'Cash':appt.paymentMethod==='wallet'?'Wallet':'Online' %></span>
              <% if (appt.reason) { %>
                <span class="meta-chip"><i class="fas fa-notes-medical"></i> <%= appt.reason.substring(0,35) %><%= appt.reason.length>35?'...':'' %></span>
              <% } %>
            </div>
          </div>

          <div class="appt-right">
            <span class="status-badge <%= appt.status %>"><%= appt.status %></span>
            <div class="appt-fee">₹<%= appt.consultationFee %></div>
            <div class="appt-actions">
              <button class="btn-sm btn-view" onclick="openDetailModal('<%= appt._id %>')"><i class="fas fa-eye"></i> View</button>
              <% if (appt.status === 'pending') { %>
                <button class="btn-sm btn-confirm"  onclick="updateStatus('<%= appt._id %>','confirmed')"><i class="fas fa-check"></i> Confirm</button>
              <% } %>
              <% if (appt.status === 'confirmed') { %>
                <button class="btn-sm btn-complete" onclick="updateStatus('<%= appt._id %>','completed')"><i class="fas fa-check-double"></i> Complete</button>
              <% } %>
              <% if (['pending','confirmed'].includes(appt.status)) { %>
                <button class="btn-sm btn-cancel"   onclick="updateStatus('<%= appt._id %>','cancelled')"><i class="fas fa-times"></i> Cancel</button>
              <% } %>
            </div>
          </div>

        </div>
      <% }) %>
    </div>

    <% if (pagination.totalPages > 1) { %>
      <div class="pagination-row">
        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
          <a href="/doctor/appointments?status=<%= selectedStatus %>&page=<%= i %>"
             class="page-btn <%= pagination.page === i ? 'active' : '' %>"><%= i %></a>
        <% } %>
      </div>
    <% } %>
  <% } %>

</div>

<script>
  const modalRoot = document.getElementById('healora-modal-root');

  function showModal(html) {
    modalRoot.innerHTML = `<div class="hm-backdrop" id="hm-backdrop">${html}</div>`;
    document.getElementById('hm-backdrop').addEventListener('click', e => {
      if (e.target === document.getElementById('hm-backdrop')) hideModal();
    });
    requestAnimationFrame(() => requestAnimationFrame(() => modalRoot.classList.add('active')));
    document.body.style.overflow = 'hidden';
  }

  function hideModal() {
    modalRoot.classList.remove('active');
    document.body.style.overflow = '';
    setTimeout(() => { modalRoot.innerHTML = ''; }, 250);
  }

  function openDetailModal(id) {
    const card   = document.getElementById('appt-' + id);
    const name   = card.querySelector('.appt-name').textContent.trim();
    const sub    = card.querySelector('.appt-sub').textContent.trim();
    const chips  = card.querySelectorAll('.meta-chip');
    const date   = chips[0]?.textContent.trim() || '';
    const time   = chips[1]?.textContent.trim() || '';
    const payment= chips[2]?.textContent.trim() || '';
    const reason = chips[3]?.textContent.trim() || 'Not specified';
    const fee    = card.querySelector('.appt-fee').textContent.trim();
    const badge  = card.querySelector('.status-badge');
    const status = badge.textContent.trim();
    const statusClass = [...badge.classList].find(c => c !== 'status-badge') || '';

    showModal(`
      <div class="hm-box" onclick="event.stopPropagation()">
        <div class="hm-icon blue"><i class="fas fa-user"></i></div>
        <div class="hm-title">${name}</div>
        <div class="hm-sub">${sub}</div>
        <div class="hm-detail-row"><span>Date</span><span>${date}</span></div>
        <div class="hm-detail-row"><span>Time</span><span>${time}</span></div>
        <div class="hm-detail-row"><span>Payment</span><span>${payment}</span></div>
        <div class="hm-detail-row"><span>Reason</span><span>${reason}</span></div>
        <div class="hm-detail-row"><span>Fee</span><span>${fee}</span></div>
        <div class="hm-detail-row"><span>Status</span><span class="status-badge ${statusClass}">${status}</span></div>
        <div class="hm-btns">
          <button class="hm-btn gray" onclick="hideModal()">Close</button>
        </div>
      </div>
    `);
  }

  function updateStatus(id, status) {
  if (status === 'cancelled') {
    showModal(`
      <div class="hm-box" onclick="event.stopPropagation()">
        <div class="hm-icon red"><i class="fas fa-times-circle"></i></div>
        <div class="hm-title">Cancel Appointment</div>
        <div class="hm-sub">Please provide a reason. The patient will be notified via email with available slots.</div>
        <textarea id="cancelReasonInput" class="hm-textarea" placeholder="Reason for cancellation (required)" style="width:100%;padding:10px 14px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:14px;font-family:inherit;resize:vertical;min-height:90px;outline:none;margin-bottom:16px;background:#fff;color:#1a202c;"></textarea>
        <div class="hm-btns">
          <button class="hm-btn gray" onclick="hideModal()">Go Back</button>
          <button class="hm-btn red" id="confirmBtn" onclick="confirmStatusUpdate('${id}','cancelled')">Cancel Appointment</button>
        </div>
      </div>
    `);
    return;
  }

  const labels = { confirmed:'Confirm', completed:'Complete' };
  const colors = { confirmed:'green',  completed:'blue' };
  const icons  = { confirmed:'fa-check', completed:'fa-check-double' };
  const msgs   = { confirmed:'This will confirm the appointment.', completed:'This will mark the appointment as completed.' };

  showModal(`
    <div class="hm-box" onclick="event.stopPropagation()">
      <div class="hm-icon ${colors[status]}"><i class="fas ${icons[status]}"></i></div>
      <div class="hm-title">${labels[status]} Appointment?</div>
      <div class="hm-sub">${msgs[status]}</div>
      <div class="hm-btns">
        <button class="hm-btn gray" onclick="hideModal()">Go Back</button>
        <button class="hm-btn ${colors[status]}" id="confirmBtn" onclick="confirmStatusUpdate('${id}','${status}')">${labels[status]}</button>
      </div>
    </div>
  `);
}

async function confirmStatusUpdate(id, status) {
  const btn = document.getElementById('confirmBtn');
  let reason = '';

  if (status === 'cancelled') {
    reason = document.getElementById('cancelReasonInput')?.value.trim() || '';
    if (!reason) {
      document.getElementById('cancelReasonInput').style.borderColor = '#dc2626';
      document.getElementById('cancelReasonInput').placeholder = 'Reason is required';
      return;
    }
  }

  btn.disabled = true;
  btn.textContent = 'Updating...';
  try {
    const res  = await fetch(`/doctor/appointments/${id}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status, reason })
    });
    const data = await res.json();
    if (data.success) { hideModal(); window.location.reload(); }
    else { alert(data.error || 'Failed to update'); btn.disabled = false; btn.textContent = 'Retry'; }
  } catch {
    alert('Something went wrong.');
    btn.disabled = false; btn.textContent = 'Retry';
  }
}
</script>

</body>
</html>