<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/cache-control') %>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    :root {
      --blue:       #1459C8;
      --blue-dark:  #0D3D8F;
      --blue-mid:   #1A6FD4;
      --blue-light: #E8F0FD;
      --ink:        #0B1120;
      --ink-2:      #1E2D45;
      --muted:      #6B7E99;
      --border:     #E4EAF3;
      --surface:    #F4F7FC;
      --white:      #FFFFFF;
      --green:      #0DBF7E;
      --amber:      #F5A623;
      --red:        #E8354A;
      --r-lg:       16px;
      --r-md:       12px;
      --r-sm:       8px;
      --sh-sm:      0 1px 6px rgba(20,89,200,.07);
      --sh-md:      0 4px 20px rgba(20,89,200,.10);
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--surface);
      color: var(--ink);
      min-height: 100vh;
      font-size: 14px;
    }

    .main-content {
      margin-left: 230px;
      padding: 30px 28px 40px;
      min-height: 100vh;
    }

    /* ── Page header ── */
    .page-header {
      margin-bottom: 24px;
    }
    .page-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--ink);
      line-height: 1.2;
    }
    .page-sub {
      font-size: 12px;
      color: var(--muted);
      font-weight: 500;
      margin-top: 3px;
    }

    /* ── Layout ── */
    .settings-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 20px;
      align-items: start;
    }

    /* ── Profile summary card ── */
    .profile-card {
      background: var(--white);
      border-radius: var(--r-lg);
      border: 1.5px solid var(--border);
      box-shadow: var(--sh-sm);
      overflow: hidden;
      position: sticky;
      top: 24px;
    }

    .profile-hero {
      background: linear-gradient(135deg, #0D3D8F 0%, #1A6FD4 100%);
      padding: 24px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .profile-hero::before {
      content: '';
      position: absolute;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: rgba(255,255,255,.06);
      top: -40px; right: -20px;
    }
    .profile-hero::after {
      content: '';
      position: absolute;
      width: 80px; height: 80px;
      border-radius: 50%;
      background: rgba(255,255,255,.04);
      bottom: -20px; left: -10px;
    }

    .profile-avatar {
      width: 64px; height: 64px;
      border-radius: 50%;
      border: 3px solid rgba(255,255,255,.3);
      background: rgba(255,255,255,.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; font-weight: 800; color: white;
      overflow: hidden;
      margin-bottom: 12px;
      position: relative; z-index: 1;
    }
    .profile-avatar img {
      width: 100%; height: 100%; object-fit: cover; border-radius: 50%;
    }

    .profile-name {
      font-size: 14px; font-weight: 800;
      color: white; margin-bottom: 3px;
      position: relative; z-index: 1;
    }
    .profile-spec {
      font-size: 11px;
      color: rgba(255,255,255,.65);
      position: relative; z-index: 1;
    }

    .profile-rows { padding: 4px 0; }
    .profile-row {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 10px 18px;
      border-bottom: 1px solid var(--border);
      font-size: 12px;
    }
    .profile-row:last-child { border-bottom: none; }
    .pr-lbl { color: var(--muted); font-weight: 600; }
    .pr-val { font-weight: 700; color: var(--ink); text-align: right; max-width: 60%; word-break: break-word; }

    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 2px 9px; border-radius: 20px;
      font-size: 11px; font-weight: 700;
    }
    .status-active {
      background: rgba(13,191,126,.12);
      color: var(--green);
    }
    .status-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

    .profile-edit-btn {
      display: block; margin: 12px 18px 16px;
      padding: 9px 16px; border-radius: var(--r-sm);
      background: var(--blue-light);
      color: var(--blue);
      font-size: 12px; font-weight: 700;
      text-align: center; text-decoration: none;
      border: 1.5px solid transparent;
      transition: all .15s;
    }
    .profile-edit-btn:hover {
      background: var(--blue);
      color: white;
    }

    /* ── Right column cards ── */
    .settings-right { display: flex; flex-direction: column; gap: 16px; }

    .s-card {
      background: var(--white);
      border-radius: var(--r-lg);
      border: 1.5px solid var(--border);
      box-shadow: var(--sh-sm);
      overflow: hidden;
    }

    .s-card-head {
      display: flex; align-items: center; gap: 10px;
      padding: 16px 20px;
      border-bottom: 1.5px solid var(--border);
    }
    .s-card-icon {
      width: 34px; height: 34px; border-radius: var(--r-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px;
      background: var(--blue-light); color: var(--blue);
      flex-shrink: 0;
    }
    .s-card-title {
      font-size: 13px; font-weight: 800; color: var(--ink);
    }
    .s-card-sub {
      font-size: 11px; color: var(--muted); font-weight: 500;
      margin-top: 1px;
    }
    .s-card-body { padding: 20px; }

    /* ── Form elements ── */
    .fg { margin-bottom: 16px; }
    .fg:last-child { margin-bottom: 0; }

    .fg label {
      display: block;
      font-size: 11px; font-weight: 700;
      color: var(--ink-2);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 6px;
    }

    .fi-wrap { position: relative; }

    .fi {
      width: 100%;
      padding: 11px 42px 11px 14px;
      border: 1.5px solid var(--border);
      border-radius: var(--r-sm);
      font-size: 13px; font-weight: 500;
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--ink);
      background: var(--white);
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .fi:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(20,89,200,.08);
    }
    .fi.error { border-color: var(--red); }
    .fi.success-field { border-color: var(--green); }

    .pw-toggle {
      position: absolute; right: 13px; top: 50%;
      transform: translateY(-50%);
      background: none; border: none;
      color: var(--muted); cursor: pointer;
      font-size: 13px; padding: 0;
      transition: color .2s; line-height: 1;
    }
    .pw-toggle:hover { color: var(--blue); }

    /* Strength bar */
    .strength-wrap { margin-top: 8px; }
    .strength-bar-bg {
      height: 4px; border-radius: 2px;
      background: var(--border);
      overflow: hidden; margin-bottom: 5px;
    }
    .strength-bar-fill {
      height: 100%; border-radius: 2px;
      transition: width .3s, background .3s;
      width: 0%;
    }
    .strength-label {
      font-size: 11px; font-weight: 600;
      color: var(--muted);
    }

    /* Rules checklist */
    .pw-rules {
      background: var(--surface);
      border: 1.5px solid var(--border);
      border-radius: var(--r-sm);
      padding: 12px 14px;
      margin-top: 8px;
      display: none;
    }
    .pw-rules.visible { display: block; }
    .pw-rule {
      display: flex; align-items: center; gap: 7px;
      font-size: 11px; font-weight: 600;
      color: var(--muted);
      padding: 2px 0;
      transition: color .2s;
    }
    .pw-rule i { font-size: 10px; transition: color .2s; }
    .pw-rule.valid   { color: var(--green); }
    .pw-rule.invalid { color: var(--muted); }

    /* Alert banners */
    .s-alert {
      display: none;
      align-items: center; gap: 10px;
      padding: 12px 14px;
      border-radius: var(--r-sm);
      font-size: 13px; font-weight: 600;
      margin-bottom: 16px;
      animation: alertFadeIn .25s ease;
    }
    @keyframes alertFadeIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .s-alert.show { display: flex; }
    .s-alert.success {
      background: rgba(13,191,126,.08);
      border: 1.5px solid rgba(13,191,126,.25);
      color: #0a9962;
    }
    .s-alert.error {
      background: rgba(232,53,74,.06);
      border: 1.5px solid rgba(232,53,74,.2);
      color: var(--red);
    }
    .s-alert i { font-size: 15px; flex-shrink: 0; }

    /* Submit button */
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 8px;
      width: 100%; padding: 12px 24px;
      background: var(--blue);
      color: white;
      border: none; border-radius: var(--r-sm);
      font-size: 13px; font-weight: 700;
      font-family: 'Plus Jakarta Sans', sans-serif;
      cursor: pointer;
      transition: all .2s;
      margin-top: 4px;
    }
    .btn-primary:hover:not(:disabled) {
      background: var(--blue-dark);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(20,89,200,.25);
    }
    .btn-primary:disabled {
      opacity: .6; cursor: not-allowed; transform: none;
    }

    /* ── Account info section ── */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .info-cell {
      padding: 12px 14px;
      background: var(--surface);
      border-radius: var(--r-sm);
      border: 1.5px solid var(--border);
    }
    .info-cell-lbl {
      font-size: 10px; font-weight: 700;
      color: var(--muted); text-transform: uppercase;
      letter-spacing: .5px; margin-bottom: 4px;
    }
    .info-cell-val {
      font-size: 13px; font-weight: 700;
      color: var(--ink);
    }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp .4s ease both; }
    .d1 { animation-delay: .05s; }
    .d2 { animation-delay: .10s; }
    .d3 { animation-delay: .15s; }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .settings-layout { grid-template-columns: 1fr; }
      .profile-card { position: static; }
    }
    @media (max-width: 768px) {
      .main-content { margin-left: 0; padding: 16px; padding-top: 76px; }
      .info-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<%- include('../partials/doctor-sidebar', { currentPage: 'settings' }) %>

<div class="main-content">
  <%- include('../partials/doctor-topbar', {
    pageTitle:    'Settings',
    pageSubtitle: 'Manage your account',
    backUrl:      null,
    backLabel:    null
  }) %>

  

  <div class="settings-layout">

    <!-- Left: Profile Summary -->
    <div class="profile-card fade-up d1">
      <div class="profile-hero">
        <div class="profile-avatar">
          <% if (user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="">
          <% } else { %>
            <%= user.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
          <% } %>
        </div>
        <div class="profile-name">Dr. <%= user.name %></div>
        <div class="profile-spec"><%= user.specialization %> &middot; <%= user.department %></div>
      </div>

      <div class="profile-rows">
        <div class="profile-row">
          <span class="pr-lbl">Status</span>
          <span class="pr-val">
            <span class="status-pill status-active">
              <span class="status-dot"></span> Active
            </span>
          </span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Email</span>
          <span class="pr-val"><%= user.email %></span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Phone</span>
          <span class="pr-val"><%= user.phone || '—' %></span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Fee</span>
          <span class="pr-val">
            <% if (user.consultationFee > 0) { %>₹<%= user.consultationFee %><% } else { %>Not set<% } %>
          </span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Experience</span>
          <span class="pr-val"><%= user.experience || 0 %>+ yrs</span>
        </div>
        <div class="profile-row">
          <span class="pr-lbl">Member Since</span>
          <span class="pr-val">
            <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %>
          </span>
        </div>
      </div>

      <a href="/doctor/profile" class="profile-edit-btn">
        <i class="fas fa-user-edit"></i> Edit Profile
      </a>
    </div>

    <!-- Right: Settings sections -->
    <div class="settings-right">

      <!-- Account Info -->
      <div class="s-card fade-up d1">
        <div class="s-card-head">
          <div class="s-card-icon"><i class="fas fa-id-card"></i></div>
          <div>
            <div class="s-card-title">Account Information</div>
            <div class="s-card-sub">Your profile details at a glance</div>
          </div>
        </div>
        <div class="s-card-body">
          <div class="info-grid">
            <div class="info-cell">
              <div class="info-cell-lbl">Full Name</div>
              <div class="info-cell-val">Dr. <%= user.name %></div>
            </div>
            <div class="info-cell">
              <div class="info-cell-lbl">Specialization</div>
              <div class="info-cell-val"><%= user.specialization || '—' %></div>
            </div>
            <div class="info-cell">
              <div class="info-cell-lbl">Department</div>
              <div class="info-cell-val"><%= user.department || '—' %></div>
            </div>
            <div class="info-cell">
              <div class="info-cell-lbl">Qualification</div>
              <div class="info-cell-val"><%= user.qualification || '—' %></div>
            </div>
            <div class="info-cell">
              <div class="info-cell-lbl">Rating</div>
              <div class="info-cell-val">
                <% if (user.rating && user.rating > 0) { %>
                  <i class="fas fa-star" style="color:#F5A623;font-size:11px;"></i>
                  <%= Number(user.rating).toFixed(1) %>
                  <span style="color:var(--muted);font-size:11px;font-weight:500;">(<%= user.ratingCount || 0 %>)</span>
                <% } else { %>
                  <span style="color:var(--muted);font-weight:500;">New</span>
                <% } %>
              </div>
            </div>
            <div class="info-cell">
              <div class="info-cell-lbl">Role</div>
              <div class="info-cell-val" style="text-transform:capitalize;"><%= user.role || 'Doctor' %></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Change Password -->
      <div class="s-card fade-up d2">
        <div class="s-card-head">
          <div class="s-card-icon" style="background:rgba(124,92,252,.12);color:#7C5CFC;">
            <i class="fas fa-lock"></i>
          </div>
          <div>
            <div class="s-card-title">Change Password</div>
            <div class="s-card-sub">Keep your account secure with a strong password</div>
          </div>
        </div>
        <div class="s-card-body">

          <!-- Alert banners -->
          <div class="s-alert success" id="pw-success">
            <i class="fas fa-check-circle"></i>
            <span id="pw-success-msg">Password changed successfully.</span>
          </div>
          <div class="s-alert error" id="pw-error">
            <i class="fas fa-exclamation-circle"></i>
            <span id="pw-error-msg">Something went wrong.</span>
          </div>

          <!-- Current Password -->
          <div class="fg">
            <label>Current Password</label>
            <div class="fi-wrap">
              <input type="password" class="fi" id="currentPassword"
                placeholder="Enter your current password"
                autocomplete="current-password">
              <button class="pw-toggle" type="button"
                onclick="togglePw('currentPassword', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>

          <!-- New Password -->
          <div class="fg">
            <label>New Password</label>
            <div class="fi-wrap">
              <input type="password" class="fi" id="newPassword"
                placeholder="Enter a new password"
                autocomplete="new-password"
                oninput="onNewPwInput()">
              <button class="pw-toggle" type="button"
                onclick="togglePw('newPassword', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
            <!-- Strength bar -->
            <div class="strength-wrap" id="strengthWrap" style="display:none;">
              <div class="strength-bar-bg">
                <div class="strength-bar-fill" id="strengthFill"></div>
              </div>
              <div class="strength-label" id="strengthLabel"></div>
            </div>
            <!-- Rules -->
            <div class="pw-rules" id="pwRules">
              <div class="pw-rule" id="rule-len">
                <i class="fas fa-circle"></i> At least 6 characters
              </div>
              <div class="pw-rule" id="rule-upper">
                <i class="fas fa-circle"></i> At least one uppercase letter
              </div>
              <div class="pw-rule" id="rule-num">
                <i class="fas fa-circle"></i> At least one number
              </div>
              <div class="pw-rule" id="rule-diff">
                <i class="fas fa-circle"></i> Different from current password
              </div>
            </div>
          </div>

          <!-- Confirm Password -->
          <div class="fg">
            <label>Confirm New Password</label>
            <div class="fi-wrap">
              <input type="password" class="fi" id="confirmPassword"
                placeholder="Re-enter your new password"
                autocomplete="new-password"
                oninput="onConfirmInput()">
              <button class="pw-toggle" type="button"
                onclick="togglePw('confirmPassword', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>

          <button class="btn-primary" id="pw-btn" onclick="changePassword()">
            <i class="fas fa-shield-halved"></i> Update Password
          </button>

        </div>
      </div>

    </div><!-- /settings-right -->
  </div><!-- /settings-layout -->
</div><!-- /main-content -->

<script>
  /* ── Toggle password visibility ── */
  function togglePw(id, btn) {
    const input = document.getElementById(id);
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    btn.querySelector('i').className = isText ? 'fas fa-eye' : 'fas fa-eye-slash';
  }

  /* ── Password strength ── */
  function getStrength(pw) {
    let score = 0;
    if (pw.length >= 6)               score++;
    if (pw.length >= 10)              score++;
    if (/[A-Z]/.test(pw))             score++;
    if (/[0-9]/.test(pw))             score++;
    if (/[^A-Za-z0-9]/.test(pw))      score++;
    return score;
  }

  const STRENGTH_MAP = [
    { label: '',          color: '',              w: '0%'   },
    { label: 'Weak',      color: 'var(--red)',    w: '25%'  },
    { label: 'Fair',      color: 'var(--amber)',  w: '50%'  },
    { label: 'Good',      color: 'var(--amber)',  w: '65%'  },
    { label: 'Strong',    color: 'var(--green)',  w: '85%'  },
    { label: 'Very strong', color: 'var(--green)', w: '100%' },
  ];

  function setRule(id, valid) {
    const el = document.getElementById(id);
    el.className = 'pw-rule ' + (valid ? 'valid' : 'invalid');
    el.querySelector('i').className = valid ? 'fas fa-check-circle' : 'fas fa-circle';
  }

  function onNewPwInput() {
    const pw   = document.getElementById('newPassword').value;
    const curr = document.getElementById('currentPassword').value;
    const rules = document.getElementById('pwRules');
    const strengthWrap = document.getElementById('strengthWrap');

    if (pw.length > 0) {
      rules.classList.add('visible');
      strengthWrap.style.display = 'block';
    } else {
      rules.classList.remove('visible');
      strengthWrap.style.display = 'none';
    }

    setRule('rule-len',   pw.length >= 6);
    setRule('rule-upper', /[A-Z]/.test(pw));
    setRule('rule-num',   /[0-9]/.test(pw));
    setRule('rule-diff',  pw !== curr || curr === '');

    const s = STRENGTH_MAP[Math.min(getStrength(pw), 5)];
    document.getElementById('strengthFill').style.width      = s.w;
    document.getElementById('strengthFill').style.background = s.color;
    document.getElementById('strengthLabel').textContent     = s.label;
    document.getElementById('strengthLabel').style.color     = s.color;

    // Also recheck confirm match
    onConfirmInput();
  }

  function onConfirmInput() {
    const pw      = document.getElementById('newPassword').value;
    const confirm = document.getElementById('confirmPassword').value;
    const el      = document.getElementById('confirmPassword');
    if (confirm.length === 0) {
      el.classList.remove('error', 'success-field');
      return;
    }
    if (pw === confirm) {
      el.classList.remove('error');
      el.classList.add('success-field');
    } else {
      el.classList.remove('success-field');
      el.classList.add('error');
    }
  }

  /* ── Alert helpers ── */
  function showAlert(type, msg) {
    ['success', 'error'].forEach(t => {
      document.getElementById('pw-' + t).classList.remove('show');
    });
    document.getElementById('pw-' + type + '-msg').textContent = msg;
    document.getElementById('pw-' + type).classList.add('show');

    // Auto-hide success after 4s
    if (type === 'success') {
      setTimeout(() => {
        document.getElementById('pw-success').classList.remove('show');
      }, 4000);
    }
  }

  /* ── Submit ── */
  async function changePassword() {
    const currentPassword = document.getElementById('currentPassword').value.trim();
    const newPassword     = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    // Client-side validation
    if (!currentPassword || !newPassword || !confirmPassword) {
      showAlert('error', 'All fields are required.'); return;
    }
    if (newPassword.length < 6) {
      showAlert('error', 'New password must be at least 6 characters.'); return;
    }
    if (newPassword !== confirmPassword) {
      showAlert('error', 'New passwords do not match.'); return;
    }
    if (currentPassword === newPassword) {
      showAlert('error', 'New password must be different from current password.'); return;
    }

    const btn = document.getElementById('pw-btn');
    btn.disabled  = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';

    try {
      const res  = await fetch('/doctor/settings/change-password', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ currentPassword, newPassword, confirmPassword })
      });
      const data = await res.json();

      if (data.success) {
        showAlert('success', 'Password updated successfully. Stay secure!');
        document.getElementById('currentPassword').value = '';
        document.getElementById('newPassword').value     = '';
        document.getElementById('confirmPassword').value = '';
        document.getElementById('pwRules').classList.remove('visible');
        document.getElementById('strengthWrap').style.display = 'none';
        document.getElementById('confirmPassword').classList.remove('success-field', 'error');
      } else {
        showAlert('error', data.error || 'Failed to update password.');
      }
    } catch {
      showAlert('error', 'Something went wrong. Please try again.');
    } finally {
      btn.disabled  = false;
      btn.innerHTML = '<i class="fas fa-shield-halved"></i> Update Password';
    }
  }
</script>
</body>
</html>
