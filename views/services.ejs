<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/Logo-browser.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; }
    .page-hero { background: linear-gradient(135deg, #0D3D8F 0%, #1A6FD4 100%); padding: 60px 0; color: white; text-align: center; }
    .page-hero h1 { font-size: 38px; font-weight: 800; margin-bottom: 12px; }
    .page-hero p  { font-size: 15px; color: rgba(255,255,255,.75); max-width: 560px; margin: 0 auto; }
    .breadcrumb-hero { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,.6); margin-top: 14px; }
    .breadcrumb-hero a { color: rgba(255,255,255,.75); text-decoration: none; }

    .services-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 24px; padding: 50px 0;
    }
    .service-card {
      background: white; border-radius: 16px;
      border: 1.5px solid #e4eaf3;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
      overflow: hidden;
      transition: transform .2s, box-shadow .2s;
    }
    .service-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(20,89,200,.13); }
    .service-card img { width: 100%; height: 180px; object-fit: cover; }
    .service-card-body { padding: 20px; }
    .service-icon {
      width: 46px; height: 46px; border-radius: 12px;
      background: #E8F0FD; color: #1459C8;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; margin-bottom: 12px;
    }
    .service-title { font-size: 16px; font-weight: 800; color: #0B1120; margin-bottom: 8px; }
    .service-desc  { font-size: 13px; color: #64748b; line-height: 1.7; margin: 0; }

    .cta-section {
      background: linear-gradient(135deg, #0D3D8F, #1A6FD4);
      padding: 60px 0; text-align: center; color: white;
    }
    .cta-section h2 { font-size: 30px; font-weight: 800; margin-bottom: 12px; }
    .cta-section p  { font-size: 15px; color: rgba(255,255,255,.75); margin-bottom: 28px; }
  </style>
</head>
<body>
<%- include('partials/navbar') %>

<div class="page-hero">
  <h1>Our Services</h1>
  <p>Comprehensive healthcare services with advanced technology and trusted expertise</p>
  <div class="breadcrumb-hero">
    <a href="/">Home</a>
    <i class="fas fa-chevron-right" style="font-size:10px;"></i>
    <span>Services</span>
  </div>
</div>

<div class="container">
  <div class="services-grid">
    <div class="service-card">
      <img src="/images/service1.jpg" alt="General Consultation">
      <div class="service-card-body">
        <div class="service-icon"><i class="fas fa-stethoscope"></i></div>
        <div class="service-title">General Consultation</div>
        <p class="service-desc">Experienced doctors providing accurate diagnosis and personalized treatment for every patient with care and precision.</p>
      </div>
    </div>
    <div class="service-card">
      <img src="/images/service2.jpg" alt="Diagnostics">
      <div class="service-card-body">
        <div class="service-icon"><i class="fas fa-microscope"></i></div>
        <div class="service-title">Diagnostics & Scans</div>
        <p class="service-desc">Advanced imaging and testing facilities ensuring quick and reliable results with utmost precision and accuracy.</p>
      </div>
    </div>
    <div class="service-card">
      <img src="/images/service3.jpg" alt="Emergency Care">
      <div class="service-card-body">
        <div class="service-icon" style="background:rgba(232,53,74,.1);color:#E8354A;"><i class="fas fa-ambulance"></i></div>
        <div class="service-title">Emergency Care</div>
        <p class="service-desc">Round-the-clock emergency unit equipped with modern facilities and expert medical staff ready 24/7.</p>
      </div>
    </div>
    <div class="service-card">
      <img src="/images/service4.jpg" alt="Pharmacy">
      <div class="service-card-body">
        <div class="service-icon" style="background:rgba(13,191,126,.1);color:#0a9962;"><i class="fas fa-pills"></i></div>
        <div class="service-title">Pharmacy & Medicine</div>
        <p class="service-desc">On-site pharmacy offering genuine and prescribed medicines with professional guidance and quick dispensing.</p>
      </div>
    </div>
    <div class="service-card">
      <img src="/images/service5.jpg" alt="Surgery">
      <div class="service-card-body">
        <div class="service-icon" style="background:rgba(124,92,252,.1);color:#6d28d9;"><i class="fas fa-scalpel"></i></div>
        <div class="service-title">Surgery & Operation</div>
        <p class="service-desc">State-of-the-art operation theatres ensuring patient safety and top surgical standards at every procedure.</p>
      </div>
    </div>
    <div class="service-card">
      <img src="/images/service6.jpg" alt="Physiotherapy">
      <div class="service-card-body">
        <div class="service-icon" style="background:rgba(245,166,35,.1);color:#b45309;"><i class="fas fa-person-walking"></i></div>
        <div class="service-title">Physiotherapy & Rehab</div>
        <p class="service-desc">Expert-led therapy sessions helping patients recover faster and regain strength efficiently and comfortably.</p>
      </div>
    </div>
  </div>
</div>

<div class="cta-section">
  <div class="container">
    <h2>Ready to Get Started?</h2>
    <p>Book an appointment with one of our expert doctors today</p>
    <a href="/doctors" class="btn btn-light px-5 py-2 rounded-pill" style="font-weight:700;color:#1459C8;">
      <i class="fas fa-calendar-plus me-2"></i> Book Appointment
    </a>
  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
