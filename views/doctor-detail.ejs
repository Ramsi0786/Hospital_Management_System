<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/cache-control') %>
  <title><%= title %> | Healora</title>
  <link href="/images/Logo-browser.jpg" rel="icon">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; }

    .page-hero {
      background: linear-gradient(135deg, #0D3D8F 0%, #1A6FD4 100%);
      padding: 40px 0 60px; color: white;
    }
    .breadcrumb-hero {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 20px;
    }
    .breadcrumb-hero a { color: rgba(255,255,255,.75); text-decoration: none; }
    .breadcrumb-hero a:hover { color: white; }

    /* ── Profile card overlapping hero ── */
    .profile-section { margin-top: -40px; margin-bottom: 32px; }

    .profile-card {
      background: white; border-radius: 20px;
      box-shadow: 0 8px 32px rgba(20,89,200,.12);
      padding: 32px;
      display: flex; align-items: flex-start; gap: 28px;
      flex-wrap: wrap;
    }

    .profile-avatar {
      width: 110px; height: 110px; border-radius: 50%;
      border: 4px solid white;
      box-shadow: 0 4px 16px rgba(20,89,200,.2);
      background: linear-gradient(135deg, #1459C8, #0D3D8F);
      color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 34px; font-weight: 800;
      overflow: hidden; flex-shrink: 0;
    }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

    .profile-main { flex: 1; min-width: 200px; }
    .profile-name { font-size: 24px; font-weight: 800; color: #0B1120; margin-bottom: 4px; }
    .profile-spec { font-size: 14px; font-weight: 600; color: #1459C8; margin-bottom: 4px; }
    .profile-dept { font-size: 13px; color: #64748b; margin-bottom: 12px; }

    .profile-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .profile-tag {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 12px; border-radius: 20px;
      font-size: 12px; font-weight: 700;
    }
    .tag-blue   { background: #E8F0FD; color: #1459C8; }
    .tag-green  { background: rgba(13,191,126,.1); color: #0a9962; }
    .tag-amber  { background: rgba(245,166,35,.1); color: #b45309; }
    .tag-purple { background: rgba(124,92,252,.1); color: #6d28d9; }

    .profile-actions { display: flex; flex-direction: column; gap: 10px; min-width: 180px; }

    .btn-book-lg {
      padding: 13px 24px;
      background: #1459C8; color: white;
      border: none; border-radius: 12px;
      font-size: 14px; font-weight: 700;
      font-family: inherit; cursor: pointer;
      text-align: center; text-decoration: none;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: background .2s, transform .15s;
    }
    .btn-book-lg:hover { background: #0D3D8F; transform: translateY(-1px); color: white; }

    .btn-back-lg {
      padding: 12px 24px;
      background: #f1f5f9; color: #374151;
      border: 1.5px solid #e2e8f0; border-radius: 12px;
      font-size: 14px; font-weight: 700;
      text-align: center; text-decoration: none;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: background .2s;
    }
    .btn-back-lg:hover { background: #e2e8f0; color: #374151; }

    /* ── Info sections ── */
    .info-grid {
      display: grid; grid-template-columns: 1fr 320px;
      gap: 20px; align-items: start;
    }
    .info-left { display: flex; flex-direction: column; gap: 20px; }

    .info-card {
      background: white; border-radius: 16px;
      border: 1.5px solid #e4eaf3;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
      overflow: hidden;
    }
    .info-card-head {
      display: flex; align-items: center; gap: 8px;
      padding: 14px 20px;
      border-bottom: 1.5px solid #e4eaf3;
      font-size: 13px; font-weight: 800; color: #0B1120;
    }
    .info-card-head i { color: #1459C8; font-size: 13px; }
    .info-card-body { padding: 18px 20px; }

    .bio-text { font-size: 14px; color: #374151; line-height: 1.8; }
    .no-info   { font-size: 13px; color: #94a3b8; font-style: italic; }

    /* Stats row inside card */
    .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .stat-cell {
      text-align: center; padding: 14px 10px;
      background: #f8fafc; border-radius: 10px;
    }
    .stat-cell-val { font-size: 20px; font-weight: 800; color: #0B1120; line-height: 1; }
    .stat-cell-lbl { font-size: 11px; font-weight: 600; color: #94a3b8; margin-top: 3px; }

    /* Availability */
    .avail-grid { display: flex; flex-direction: column; gap: 8px; }
    .avail-row  { display: flex; align-items: center; gap: 12px; }
    .avail-day  {
      width: 90px; font-size: 12px; font-weight: 700;
      color: #374151; flex-shrink: 0;
    }
    .avail-slots { display: flex; flex-wrap: wrap; gap: 6px; }
    .avail-slot {
      padding: 3px 10px; border-radius: 20px;
      background: #E8F0FD; color: #1459C8;
      font-size: 11px; font-weight: 700;
    }
    .avail-none { font-size: 12px; color: #94a3b8; font-style: italic; }

    /* Sidebar sticky card */
    .sidebar-card {
      background: white; border-radius: 16px;
      border: 1.5px solid #e4eaf3;
      box-shadow: 0 1px 6px rgba(20,89,200,.07);
      position: sticky; top: 16px; overflow: hidden;
    }
    .sidebar-book-hero {
      background: linear-gradient(135deg, #0D3D8F, #1A6FD4);
      padding: 20px; text-align: center; color: white;
    }
    .fee-display { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
    .fee-label   { font-size: 12px; color: rgba(255,255,255,.7); }
    .sidebar-body { padding: 16px; }

    .detail-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 10px 0; border-bottom: 1px solid #f1f5f9;
      font-size: 13px;
    }
    .detail-row:last-of-type { border-bottom: none; }
    .detail-lbl { color: #64748b; font-weight: 600; }
    .detail-val { font-weight: 700; color: #0B1120; }

    /* Login prompt */
    .lp-backdrop {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.5); backdrop-filter: blur(4px);
      z-index: 9999; display: flex; align-items: center; justify-content: center;
      padding: 20px; opacity: 0; pointer-events: none; transition: opacity .25s;
    }
    .lp-backdrop.show { opacity: 1; pointer-events: all; }
    .lp-box {
      background: white; border-radius: 20px; padding: 32px;
      max-width: 420px; width: 100%;
      box-shadow: 0 20px 60px rgba(0,0,0,.2);
      transform: translateY(20px); transition: transform .25s; text-align: center;
    }
    .lp-backdrop.show .lp-box { transform: translateY(0); }
    .lp-icon { width: 56px; height: 56px; border-radius: 50%; background: #E8F0FD; color: #1459C8; display: flex; align-items: center; justify-content: center; font-size: 22px; margin: 0 auto 16px; }
    .lp-title { font-size: 20px; font-weight: 800; color: #0B1120; margin-bottom: 8px; }
    .lp-sub   { font-size: 13px; color: #64748b; margin-bottom: 24px; line-height: 1.6; }
    .lp-btns  { display: flex; gap: 10px; }
    .lp-btn-p { flex: 1; padding: 12px; background: #1459C8; color: white; border: none; border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; text-decoration: none; display: flex; align-items: center; justify-content: center; transition: background .2s; }
    .lp-btn-p:hover { background: #0D3D8F; color: white; }
    .lp-btn-s { flex: 1; padding: 12px; background: #f1f5f9; color: #374151; border: none; border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; text-decoration: none; display: flex; align-items: center; justify-content: center; transition: background .2s; }
    .lp-btn-s:hover { background: #e2e8f0; color: #374151; }

    @media (max-width: 991px) {
      .info-grid    { grid-template-columns: 1fr; }
      .sidebar-card { position: static; }
      .profile-card { flex-direction: column; align-items: center; text-align: center; }
      .profile-tags { justify-content: center; }
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<!-- Hero -->
<div class="page-hero">
  <div class="container">
    <div class="breadcrumb-hero">
      <a href="/">Home</a>
      <i class="fas fa-chevron-right" style="font-size:10px;"></i>
      <a href="/doctors">Doctors</a>
      <i class="fas fa-chevron-right" style="font-size:10px;"></i>
      <span>Dr. <%= doctor.name %></span>
    </div>
  </div>
</div>

<!-- Profile Card overlapping hero -->
<div class="profile-section">
  <div class="container">
    <div class="profile-card">
      <div class="profile-avatar">
        <% if (doctor.profileImage) { %>
          <img src="<%= doctor.profileImage %>" alt="Dr. <%= doctor.name %>">
        <% } else { %>
          <%= doctor.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2) %>
        <% } %>
      </div>

      <div class="profile-main">
        <div class="profile-name">Dr. <%= doctor.name %></div>
        <div class="profile-spec"><%= doctor.specialization %></div>
        <div class="profile-dept"><%= doctor.department %> Department</div>
        <div class="profile-tags">
          <% if (doctor.qualification) { %>
            <span class="profile-tag tag-blue"><i class="fas fa-graduation-cap"></i> <%= doctor.qualification %></span>
          <% } %>
          <span class="profile-tag tag-green"><i class="fas fa-briefcase"></i> <%= doctor.experience || 0 %>+ Years Exp.</span>
          <% if (doctor.rating > 0) { %>
            <span class="profile-tag tag-amber"><i class="fas fa-star"></i> <%= Number(doctor.rating).toFixed(1) %> Rating</span>
          <% } %>
        </div>
      </div>

      <div class="profile-actions">
        <% if (locals.currentUser) { %>
          <a href="/patient/book-appointment/<%= doctor._id %>" class="btn-book-lg">
            <i class="fas fa-calendar-plus"></i> Book Appointment
          </a>
        <% } else { %>
          <button class="btn-book-lg" onclick="showLoginPrompt()">
            <i class="fas fa-calendar-plus"></i> Book Appointment
          </button>
        <% } %>
        <a href="/doctors" class="btn-back-lg">
          <i class="fas fa-arrow-left"></i> All Doctors
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Info Grid -->
<div class="container pb-5">
  <div class="info-grid">

    <div class="info-left">

      <!-- Stats -->
      <div class="info-card">
        <div class="info-card-head"><i class="fas fa-chart-bar"></i> Overview</div>
        <div class="info-card-body">
          <div class="stat-row">
            <div class="stat-cell">
              <div class="stat-cell-val"><%= doctor.experience || 0 %>+</div>
              <div class="stat-cell-lbl">Years Experience</div>
            </div>
            <div class="stat-cell">
              <div class="stat-cell-val">
                <% if (doctor.rating > 0) { %><%= Number(doctor.rating).toFixed(1) %><% } else { %>New<% } %>
              </div>
              <div class="stat-cell-lbl">Rating<% if (doctor.ratingCount > 0) { %> (<%= doctor.ratingCount %>)<% } %></div>
            </div>
            <div class="stat-cell">
              <div class="stat-cell-val">
                <% if (doctor.consultationFee > 0) { %>₹<%= doctor.consultationFee %><% } else { %>—<% } %>
              </div>
              <div class="stat-cell-lbl">Consult Fee</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bio -->
      <div class="info-card">
        <div class="info-card-head"><i class="fas fa-user-circle"></i> About Dr. <%= doctor.name.split(' ')[0] %></div>
        <div class="info-card-body">
          <% if (doctor.bio && doctor.bio.trim()) { %>
            <p class="bio-text"><%= doctor.bio %></p>
          <% } else { %>
            <p class="no-info">No bio added yet.</p>
          <% } %>
        </div>
      </div>

      <!-- Availability -->
      <div class="info-card">
        <div class="info-card-head"><i class="fas fa-clock"></i> Availability</div>
        <div class="info-card-body">
          <% if (doctor.availability && doctor.availability.length > 0) { %>
            <div class="avail-grid">
              <% doctor.availability.forEach(av => { %>
                <div class="avail-row">
                  <div class="avail-day"><%= av.day %></div>
                  <div class="avail-slots">
                    <% if (av.slots && av.slots.length > 0) { %>
                      <% av.slots.forEach(slot => { %>
                        <%
                          const [sh, sm] = slot.split(':').map(Number);
                          const fmt = `${sh%12||12}:${String(sm).padStart(2,'0')} ${sh>=12?'PM':'AM'}`;
                        %>
                        <span class="avail-slot"><%= fmt %></span>
                      <% }) %>
                    <% } else { %>
                      <span class="avail-none">No slots</span>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="no-info">No availability set yet. Please call to schedule.</p>
          <% } %>
        </div>
      </div>

    </div><!-- /info-left -->

    <!-- Sidebar -->
    <div class="sidebar-card">
      <div class="sidebar-book-hero">
        <div class="fee-display">
          <% if (doctor.consultationFee > 0) { %>₹<%= doctor.consultationFee %><% } else { %>Free<% } %>
        </div>
        <div class="fee-label">Consultation Fee</div>
      </div>
      <div class="sidebar-body">
        <div class="detail-row">
          <span class="detail-lbl">Specialization</span>
          <span class="detail-val"><%= doctor.specialization %></span>
        </div>
        <div class="detail-row">
          <span class="detail-lbl">Department</span>
          <span class="detail-val"><%= doctor.department %></span>
        </div>
        <% if (doctor.qualification) { %>
        <div class="detail-row">
          <span class="detail-lbl">Qualification</span>
          <span class="detail-val"><%= doctor.qualification %></span>
        </div>
        <% } %>
        <div class="detail-row">
          <span class="detail-lbl">Experience</span>
          <span class="detail-val"><%= doctor.experience || 0 %>+ Years</span>
        </div>
        <div class="detail-row">
          <span class="detail-lbl">Phone</span>
          <span class="detail-val"><%= doctor.phone || '—' %></span>
        </div>
        <div class="detail-row">
          <span class="detail-lbl">Member Since</span>
          <span class="detail-val">
            <%= new Date(doctor.createdAt).toLocaleDateString('en-US', { month:'short', year:'numeric' }) %>
          </span>
        </div>

        <div style="margin-top:16px;">
          <% if (locals.currentUser) { %>
            <a href="/patient/book-appointment/<%= doctor._id %>" class="btn-book-lg">
              <i class="fas fa-calendar-plus"></i> Book Now
            </a>
          <% } else { %>
            <button class="btn-book-lg" onclick="showLoginPrompt()" style="width:100%;">
              <i class="fas fa-calendar-plus"></i> Book Now
            </button>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Login Prompt Modal -->
<div class="lp-backdrop" id="loginPrompt">
  <div class="lp-box">
    <div class="lp-icon"><i class="fas fa-calendar-check"></i></div>
    <div class="lp-title">Login to Book</div>
    <div class="lp-sub">
      You need to be logged in to book an appointment with Dr. <%= doctor.name %>. It's free and takes less than a minute.
    </div>
    <div class="lp-btns">
      <a href="/patient/login?redirect=/patient/book-appointment/<%= doctor._id %>" class="lp-btn-p">
        <i class="fas fa-sign-in-alt me-2"></i> Login
      </a>
      <a href="/patient/signup" class="lp-btn-s">Sign Up Free</a>
    </div>
    <button onclick="hideLoginPrompt()" style="margin-top:14px;background:none;border:none;font-size:12px;color:#94a3b8;cursor:pointer;font-family:inherit;">
      Maybe later
    </button>
  </div>
</div>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function showLoginPrompt() {
    document.getElementById('loginPrompt').classList.add('show');
  }
  function hideLoginPrompt() {
    document.getElementById('loginPrompt').classList.remove('show');
  }
  document.getElementById('loginPrompt').addEventListener('click', function(e) {
    if (e.target === this) hideLoginPrompt();
  });
</script>
</body>
</html>
